---
import { siteConfig } from "../data/site";
import { getCompanyInfo, getCategoryTopicPages, getDynamicTopicPages, buildWaLink } from "../lib/api";
const LEAD_CAPTURE_URL = import.meta.env.PUBLIC_ESPO_BASE + "/LeadCapture/" + import.meta.env.PUBLIC_LEAD_CAPTURE_KEY;

const company = await getCompanyInfo("AGE");
const whatsappHref = buildWaLink(company?.whatsappNumber);
const categoryPages = await getCategoryTopicPages();
const dynamicTopicPages = await getDynamicTopicPages();

// Build category links dynamically from API
const categoryLinks = categoryPages.map((p) => ({
  label: p.name,
  href: `/category/${p.slug}`,
}));

// Build dynamic collection links from API
const collectionLinks = dynamicTopicPages.map((p) => ({
  label: p.name,
  href: `/collection/${p.slug}`,
}));

// Build dynamic quick links — replace "About Us" label with "About {alternateName[0]}"
const alternateName0 = company?.alternateName?.[0] ?? null;
const quickLinks = siteConfig.footerLinks.quick.map((item) =>
  item.href === "/about" && alternateName0
    ? { ...item, label: `About ${alternateName0}` }
    : item
);

// Build full address string + Google Maps link
const addressParts = [
  company?.addressStreet,
  company?.addressCity,
  company?.addressState,
  company?.addressCountry,
  company?.addressPostalCode,
].filter(Boolean);
const fullAddress = addressParts.join(", ");
const mapQuery = encodeURIComponent(fullAddress);
const mapLink = `https://www.google.com/maps/search/?api=1&query=${mapQuery}`;

// Structured address lines for display
const addressLine1 = company?.legalName;
const addressLine2 = [company?.addressStreet].filter(Boolean).join(", ");
const addressLine3 = [company?.addressCity, company?.addressState, company?.addressCountry, company?.addressPostalCode].filter(Boolean).join(", ");

const phone1 = company?.phone1 ?? null;
const phone1Dept = company?.phone1Dept ?? null;
const phone2 = company?.phone2 ?? null;
const phone2Dept = company?.phone2Dept ?? null;
const salesEmail = company?.salesEmail ?? null;
const supportEmail = company?.supportEmail ?? null;
const foundingYear = company?.foundingYear ?? 1971;
const recognitions = company?.recognitions ?? [];
const recognition = recognitions.join(". ");
const gstin = company?.gstin ?? null;

const socialLinks = [
  {
    label: "Facebook",
    href: company?.facebookUrl ?? "#",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>`,
  },
  {
    label: "Instagram",
    href: company?.instagramUrl ?? "#",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>`,
  },
  {
    label: "LinkedIn",
    href: company?.linkedinUrl ?? "#",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>`,
  },
  {
    label: "X",
    href: company?.xUrl ?? "#",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
  },
  {
    label: "YouTube",
    href: company?.youtubeUrl ?? "#",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 00-1.95 1.96A29 29 0 001 12a29 29 0 00.46 5.58A2.78 2.78 0 003.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 001.95-1.95A29 29 0 0023 12a29 29 0 00-.46-5.58zM9.75 15.02V8.98L15.5 12l-5.75 3.02z"/></svg>`,
  },
  {
    label: "Pinterest",
    href: company?.pinterestUrl ?? "#",
    svg: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>`,
  },
];
---

<footer class="bg-surface-container-highest text-on-surface py-12 md:py-16 px-6 md:px-12 font-body relative overflow-hidden">
  <div class="max-w-screen-2xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">

    <!-- Office Addresses -->
    <div class="space-y-6">
      <div class="bg-surface-container-low p-6 rounded-lg border border-outline-variant/20 space-y-6">
        <div>
          <h3 class="font-label flex items-center text-xs font-semibold uppercase tracking-widest mb-2 text-on-surface">
            <span class="w-2 h-2 rounded-full bg-primary mr-2"></span> Office Address
          </h3>
          <a
            href={mapLink}
            target="_blank"
            rel="noopener noreferrer"
            class="font-body text-xs text-on-surface-variant leading-relaxed hover:text-on-surface transition-colors"
          >
            {fullAddress}
          </a>
        </div>
        <div class="border-t border-outline-variant/20 pt-4">
          <h3 class="font-label flex items-center text-xs font-semibold uppercase tracking-widest mb-2 text-on-surface">
            <span class="w-2 h-2 rounded-full bg-primary mr-2"></span> Factory Address
          </h3>
          <a
            href="https://www.google.com/maps/search/?api=1&query=1+Mohan+Estate+Ramol+Road+Ahmedabad+Gujarat+India+382449"
            target="_blank"
            rel="noopener noreferrer"
            class="font-body text-xs text-on-surface-variant leading-relaxed hover:text-on-surface transition-colors"
          >
            1, Mohan Estate, Ramol Road, Ahmedabad Gujarat, India – 382449
          </a>
        </div>
        <div class="border-t border-outline-variant/20 pt-4">
          <h3 class="font-label flex items-center text-xs font-semibold uppercase tracking-widest mb-2 text-on-surface">
            <span class="w-2 h-2 rounded-full bg-primary mr-2"></span> Warehouse Address
          </h3>
          <a
            href="https://www.google.com/maps/search/?api=1&query=Nr+Ambuja+Synthetics+Old+Narol+Court+Narol+Ahmedabad+Gujarat+India+382405"
            target="_blank"
            rel="noopener noreferrer"
            class="font-body text-xs text-on-surface-variant leading-relaxed hover:text-on-surface transition-colors"
          >
            Nr. Ambuja Synthetics, B/H Old Narol Court Narol, Ahmedabad, Gujarat, India – 382405
          </a>
        </div>
        <div class="border-t border-outline-variant/20 pt-4">
          <h3 class="font-label flex items-center text-xs font-semibold uppercase tracking-widest mb-2 text-on-surface">
            <span class="w-2 h-2 rounded-full bg-primary mr-2"></span> UAE Office Address
          </h3>
          <a
            href="https://www.google.com/maps/search/?api=1&query=GSK+Worldwide+FZE+Ajman+Free+Zone+UAE"
            target="_blank"
            rel="noopener noreferrer"
            class="font-body text-xs text-on-surface-variant leading-relaxed hover:text-on-surface transition-colors"
          >
            GSK Worldwide FZE, Ajman Free Zone, UAE
          </a>
        </div>
      </div>
    </div>

    <!-- Quick Links + Collections -->
    <div class="space-y-10">
      <div>
        <h3 id="footer-nav-quick" class="font-label text-sm font-semibold uppercase tracking-widest mb-6 md:mb-8 text-on-surface">Quick Links</h3>
        <ul aria-labelledby="footer-nav-quick" class="grid grid-cols-2 md:grid-cols-1 gap-4 text-sm font-body">
          {quickLinks.map((item) => (
            <li>
              <a class="text-on-surface-variant hover:text-on-surface transition-all duration-200 ease-in-out" href={item.href}>{item.label}</a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h3 id="footer-nav-collections" class="font-label text-sm font-semibold uppercase tracking-widest mb-6 md:mb-8 text-on-surface">Collections</h3>
        <ul aria-labelledby="footer-nav-collections" class="grid grid-cols-2 md:grid-cols-1 gap-4 text-sm font-body">
          {collectionLinks.map((item) => (
            <li>
              <a class="text-on-surface-variant hover:text-on-surface transition-all duration-200 ease-in-out" href={item.href}>{item.label}</a>
            </li>
          ))}
          {collectionLinks.length === 0 && (
            <li class="text-on-surface-variant text-xs italic">No collections available</li>
          )}
        </ul>
      </div>
    </div>

    <!-- Information + Categories -->
    <div class="space-y-10">
      <div>
        <h3 id="footer-nav-info" class="font-label text-sm font-semibold uppercase tracking-widest mb-6 md:mb-8 text-on-surface">Information</h3>
        <ul aria-labelledby="footer-nav-info" class="grid grid-cols-2 md:grid-cols-1 gap-4 text-sm font-body">
          {siteConfig.footerLinks.products.map((item) => (
            <li>
              <a class="text-on-surface-variant hover:text-on-surface transition-all duration-200 ease-in-out" href={item.href}>{item.label}</a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <h3 id="footer-nav-categories" class="font-label text-sm font-semibold uppercase tracking-widest mb-6 md:mb-8 text-on-surface">Categories</h3>
        <ul aria-labelledby="footer-nav-categories" class="grid grid-cols-2 md:grid-cols-1 gap-4 text-sm font-body">
          <li>
            <a class="text-on-surface-variant hover:text-on-surface transition-all duration-200 ease-in-out" href="/fabric">All Fabrics</a>
          </li>
          {categoryLinks.map((item) => (
            <li>
              <a class="text-on-surface-variant hover:text-on-surface transition-all duration-200 ease-in-out" href={item.href}>{item.label}</a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Talk To Us -->
    <div class="space-y-6">
      <h3 id="footer-nav-contact" class="font-label text-sm font-semibold uppercase tracking-widest mb-6 italic text-on-surface">Talk To Us</h3>

      <div class="space-y-4 text-sm pt-4" aria-labelledby="footer-nav-contact" role="group">
        {phone1 && (
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <a href={`tel:${phone1}`} class="text-on-surface-variant hover:text-on-surface transition-colors">{phone1} ({phone1Dept})</a>
          </div>
        )}
        {phone2 && (
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <a href={`tel:${phone2}`} class="text-on-surface-variant hover:text-on-surface transition-colors">{phone2} ({phone2Dept})</a>
          </div>
        )}
        {salesEmail && (
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <div class="flex flex-col">
              <span class="text-[10px] text-primary font-bold uppercase">Sales Email</span>
              <a href={`mailto:${salesEmail}`} class="text-on-surface-variant hover:text-on-surface transition-colors">{salesEmail}</a>
            </div>
          </div>
        )}
        {supportEmail && (
          <div class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <div class="flex flex-col">
              <span class="text-[10px] text-primary font-bold uppercase">Support Email</span>
              <a href={`mailto:${supportEmail}`} class="text-on-surface-variant hover:text-on-surface transition-colors">{supportEmail}</a>
            </div>
          </div>
        )}
        {fullAddress && (
          <div class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <a
              href={mapLink}
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs text-on-surface-variant hover:text-on-surface transition-colors leading-relaxed"
            >
              {addressLine1 && <span class="block md:inline">{addressLine1}</span>}
              {addressLine2 && <span class="block md:inline md:before:content-[',_']">{addressLine2}</span>}
              {addressLine3 && <span class="block md:inline md:before:content-[',_']">{addressLine3}</span>}
            </a>
          </div>
        )}
      </div>
         {gstin && (
        <p class="text-xs text-on-surface-variant pt-2">
          <span class="font-semibold text-on-surface uppercase tracking-widest">GSTIN:</span> {gstin}
        </p>
      )}
      
      <p class="font-body text-sm text-on-surface-variant">Get new fabric arrivals &amp; bulk pricing alerts — straight to your inbox.</p>

      <!-- Newsletter -->
      <form id="footer-newsletter-form" class="relative" action="javascript:void(0)">
        <label for="footer-newsletter-email" class="sr-only">Email address</label>
        <input
          id="footer-newsletter-email"
          name="email"
          autocomplete="email"
          class="w-full bg-white text-primary rounded-full px-6 py-4 pr-16 focus:ring-2 focus:ring-secondary border border-outline-variant outline-none"
          placeholder="Subscribe with us"
          type="email"
          required
        />
        <button
          type="submit"
          id="footer-newsletter-btn"
          class="absolute right-2 top-2 bg-primary w-12 h-12 rounded-full flex items-center justify-center hover:bg-primary/80 transition-colors"
          aria-label="Subscribe"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </button>
      </form>
      <p id="footer-newsletter-success" class="hidden text-xs text-green-400">Thanks for subscribing!</p>
      <p id="footer-newsletter-error" class="hidden text-xs text-red-400">Something went wrong. Please try again.</p>

      <!-- Contact Details -->
     

      <!-- GSTIN -->
   

      <!-- Social Icons -->
      <div class="flex flex-wrap gap-5" role="list" aria-label="Social media links">
        {socialLinks.filter(s => s.href && s.href !== "#").map((s) => (
          <a
            href={s.href}
            aria-label={s.label}
            target="_blank"
            rel="noopener noreferrer"
            class="w-9 h-9 rounded-full bg-primary/10 flex items-center justify-center hover:bg-primary transition-colors text-primary hover:text-white [&_svg]:w-4 [&_svg]:h-4"
            set:html={`<span class="flex items-center justify-center">${s.svg}</span>`}
          />
        ))}
      </div>
    </div>
  </div>

  <!-- Sub Footer -->
  <div class="max-w-screen-2xl mx-auto mt-8 md:mt-16 pt-8 pb-32 md:pb-8 border-t border-outline-variant/30 text-center text-sm font-label">
    <div class="text-on-surface-variant flex flex-col md:flex-row md:flex-wrap justify-center items-center gap-y-2 md:gap-y-1 md:gap-x-3">
      <span>© {foundingYear}–{new Date().getFullYear()} {company?.legalName}</span>
      {fullAddress && (
        <>
          <span class="hidden md:inline text-outline-variant text-base">|</span>
          <span>{fullAddress}</span>
        </>
      )}
      {recognition && (
        <>
          <span class="hidden md:inline text-outline-variant text-base">|</span>
          <span>{recognition}</span>
        </>
      )}
      {whatsappHref && (
        <>
          <span class="hidden md:inline text-outline-variant text-base">|</span>
          <button
              type="button"
              data-wa-link={whatsappHref}
              aria-label="WhatsApp Us"
              class="text-on-surface-variant hover:text-on-surface transition-colors cursor-pointer"
            >WhatsApp Us</button>
        </>
      )}
    </div>
  </div>
</footer>

<script define:vars={{ LEAD_CAPTURE_URL }}>
  const ESPO_URL = LEAD_CAPTURE_URL;

  const form = document.getElementById('footer-newsletter-form');
  const emailInput = document.getElementById('footer-newsletter-email');
  const btn = document.getElementById('footer-newsletter-btn');
  const successMsg = document.getElementById('footer-newsletter-success');
  const errorMsg = document.getElementById('footer-newsletter-error');

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = emailInput.value.trim();
      if (!email) return;

      btn.disabled = true;
      successMsg.classList.add('hidden');
      errorMsg.classList.add('hidden');

      const gaEvent = (name) => {
        window.dataLayer = window.dataLayer || [];
        if (typeof window.gtag === 'function') window.gtag('event', name, { page_path: window.location.pathname });
        else window.dataLayer.push({ event: name, page_path: window.location.pathname });
      };
      gaEvent('footer_newsletter_subscribe_attempt');

      try {
        const res = await fetch(ESPO_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            emailAddress: email,
            description: 'Subscribed via Footer Newsletter',
          }),
        });

        if (res.ok) {
          form.reset();
          successMsg.classList.remove('hidden');
          gaEvent('footer_newsletter_subscribe_success');
        } else {
          errorMsg.classList.remove('hidden');
          gaEvent('footer_newsletter_subscribe_error');
        }
      } catch {
        errorMsg.classList.remove('hidden');
        gaEvent('footer_newsletter_subscribe_error');
      } finally {
        btn.disabled = false;
      }
    });
  }

  // Social media icon tracking
  function gaEvent(name) {
    window.dataLayer = window.dataLayer || [];
    if (typeof window.gtag === 'function') window.gtag('event', name, { page_path: window.location.pathname });
    else window.dataLayer.push({ event: name, page_path: window.location.pathname });
  }
  document.querySelectorAll('[aria-label="Social media links"] a').forEach((el) => {
    el.addEventListener('mousedown', () => {
      const label = el.getAttribute('aria-label') ?? 'social';
      gaEvent(`footer_social_${label.toLowerCase()}_click`);
    });
  });

  // Footer WhatsApp Us button
  document.querySelector('[aria-label="WhatsApp Us"]')?.addEventListener('mousedown', () => {
    gaEvent('footer_whatsapp_us_click');
  });

  // Footer phone & email clicks
  document.querySelectorAll('footer a[href^="tel:"]').forEach((el) => {
    el.addEventListener('mousedown', () => gaEvent('footer_phone_click'));
  });
  document.querySelectorAll('footer a[href^="mailto:"]').forEach((el) => {
    el.addEventListener('mousedown', () => {
      const label = el.textContent?.trim().includes('sales') ? 'footer_sales_email_click' : 'footer_support_email_click';
      gaEvent(label);
    });
  });
</script>
