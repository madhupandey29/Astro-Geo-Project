---
import "../styles/global.css";
import Header from "/src/layouts/Header.astro";
import Footer from "/src/layouts/Footer.astro";
import FloatingActions from "../components/common/FloatingActions.astro";
import LocalBusinessSchema from "../components/schema/LocalBusinessSchema.astro";
import BreadcrumbSchema from "../components/schema/BreadcrumbSchema.astro";
import { getSiteSettings } from "../lib/api";

interface Props {
  title?: string;
  description?: string;
  // Per-page SEO overrides
  canonical?: string;
  keywords?: string[];
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogType?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  twitterImage?: string;
  schemaMarkup?: object | object[];
  noindex?: boolean;
  breadcrumbs?: { name: string; url?: string }[];
}

const {
  title = "Amrita Fashions",
  description = "B2B fabric manufacturer and exporter.",
  canonical,
  keywords,
  ogTitle,
  ogDescription,
  ogImage,
  ogType = "website",
  twitterTitle,
  twitterDescription,
  twitterImage,
  schemaMarkup,
  noindex = false,
  breadcrumbs,
} = Astro.props;

// Site-wide settings from API (eCatalogue)
const site = await getSiteSettings("eCatalogue");

const siteBase = import.meta.env.PUBLIC_SITE_URL ?? "https://www.amrita-fashions.com";
const resolvedCanonical = canonical ?? `${siteBase}${Astro.url.pathname}`;
const resolvedOgTitle = ogTitle ?? title;
const resolvedOgDesc = ogDescription ?? description;
const resolvedTwitterTitle = twitterTitle ?? resolvedOgTitle;
const resolvedTwitterDesc = twitterDescription ?? resolvedOgDesc;
const resolvedTwitterImage = twitterImage ?? ogImage;

// robots: noindex prop overrides, otherwise use API robotsPolicy or default to index, follow
const robotsContent = noindex
  ? "noindex, nofollow"
  : (site?.robotsPolicy ?? "index, follow");

const schemaArray = schemaMarkup
  ? Array.isArray(schemaMarkup) ? schemaMarkup : [schemaMarkup]
  : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <!-- Preconnects (priority 90) — after title, before scripts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Preload self-hosted variable fonts -->
    <link rel="preload" href="/fonts/manrope-vf.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-vf.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/newsreader-vf.woff2" as="font" type="font/woff2" crossorigin />
    <!-- Font-face declarations inline — keeps fonts out of the CSS bundle -->
    <style is:inline>
      @font-face {
        font-family: "Manrope Variable";
        src: url("/fonts/manrope-vf.woff2") format("woff2-variations");
        font-weight: 200 800;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: "Inter Variable";
        src: url("/fonts/inter-vf.woff2") format("woff2-variations");
        font-weight: 100 900;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: "Newsreader Variable";
        src: url("/fonts/newsreader-vf.woff2") format("woff2-variations");
        font-weight: 200 800;
        font-style: normal;
        font-display: swap;
      }
    </style>
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <meta name="author" content="Amrita Global Enterprises" />
    <meta name="publisher" content="Amrita Global Enterprises" />
    {keywords && keywords.length > 0 && (
      <meta name="keywords" content={keywords.join(", ")} />
    )}
    <link rel="canonical" href={resolvedCanonical} />

    <!-- Site Verification -->
    {site?.googleVerification && (
      <meta name="google-site-verification" content={site.googleVerification} />
    )}
    {site?.bingVerification && (
      <meta name="msvalidate.01" content={site.bingVerification} />
    )}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={resolvedOgTitle} />
    <meta property="og:description" content={resolvedOgDesc} />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:site_name" content="Amrita Fashions" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:width" content="1200" />}
    {ogImage && <meta property="og:image:height" content="630" />}
    {ogImage && <meta property="og:image:type" content="image/jpeg" />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTwitterTitle} />
    <meta name="twitter:description" content={resolvedTwitterDesc} />
    {site?.twitterHandle && <meta name="twitter:site" content={site.twitterHandle} />}
    {resolvedTwitterImage && <meta name="twitter:image" content={resolvedTwitterImage} />}

    <!-- JSON-LD Structured Data -->
    {schemaArray && schemaArray.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <!-- Local Business / Organization Schema -->
    <LocalBusinessSchema />

    <!-- Breadcrumb Schema (skip on homepage) -->
    {breadcrumbs && breadcrumbs.length > 0 && (
      <BreadcrumbSchema items={breadcrumbs} />
    )}

    <!-- Analytics — deferred after page load so they don't block LCP/FCP -->
    {(site?.gaMeasurementId || site?.clarityId) && (
      <script is:inline set:html={`
        (function() {
          function loadAnalytics() {
            ${site?.gaMeasurementId ? `
            // Google Analytics
            window.dataLayer = window.dataLayer || [];
            function gtag(){dataLayer.push(arguments);}
            window.gtag = gtag;
            gtag('js', new Date());
            gtag('config', '${site.gaMeasurementId}');
            var gaScript = document.createElement('script');
            gaScript.async = true;
            gaScript.src = 'https://www.googletagmanager.com/gtag/js?id=${site.gaMeasurementId}';
            document.head.appendChild(gaScript);
            ` : ''}
            ${site?.clarityId ? `
            // Microsoft Clarity
            (function(c,l,a,r,i,t,y){
              c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
              t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
              y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
            })(window,document,"clarity","script","${site.clarityId}");
            ` : ''}
          }
          if (document.readyState === 'complete') {
            setTimeout(loadAnalytics, 1);
          } else {
            window.addEventListener('load', function() { setTimeout(loadAnalytics, 1); });
          }
        })();
      `}></script>
    )}

    <!-- Font stylesheet — non-blocking load, subset to only used icons -->
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&icon_names=add,anchor,arrow_back,arrow_forward,arrow_outward,arrow_right_alt,badge,bed,calendar_today,call,chat,chat_bubble,check,check_circle,checkroom,chevron_right,close,content_copy,corporate_fare,description,download,eco,expand_more,factory,file_download,filter_alt_off,filter_list,forum,gavel,history,hotel,image,local_shipping,location_on,location_pin,mail,map,palette,payments,person,play_circle,precision_manufacturing,progress_activity,public,public_off,schedule,search,search_off,share,smart_toy,star,support_agent,upload_file,verified,verified_user,work,workspace_premium&display=swap" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&icon_names=add,anchor,arrow_back,arrow_forward,arrow_outward,arrow_right_alt,badge,bed,calendar_today,call,chat,chat_bubble,check,check_circle,checkroom,chevron_right,close,content_copy,corporate_fare,description,download,eco,expand_more,factory,file_download,filter_alt_off,filter_list,forum,gavel,history,hotel,image,local_shipping,location_on,location_pin,mail,map,palette,payments,person,play_circle,precision_manufacturing,progress_activity,public,public_off,schedule,search,search_off,share,smart_toy,star,support_agent,upload_file,verified,verified_user,work,workspace_premium&display=swap" /></noscript>
    <style>
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      }
    </style>
  </head>
  <body class="min-h-screen bg-[var(--color-background)] text-[var(--color-text)]">
    <Header />
    <main class="pt-[94px] md:pt-[102px]">
      <slot />
    </main>
    <Footer />
    <FloatingActions />
  </body>
</html>
