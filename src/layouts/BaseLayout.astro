---
import "../styles/global.css";
import "../styles/print.css";
import Header from "/src/layouts/Header.astro";
import Footer from "/src/layouts/Footer.astro";
import FloatingActions from "../components/common/FloatingActions.astro";
import LocalBusinessSchema from "../components/schema/LocalBusinessSchema.astro";
import BreadcrumbSchema from "../components/schema/BreadcrumbSchema.astro";

import { getSiteSettings, getCompanyInfo } from "../lib/api";
const SITE_BASE = import.meta.env.PUBLIC_SITE_URL;

interface Props {
  title?: string;
  description?: string;
  // Per-page SEO overrides
  canonical?: string;
  keywords?: string[];
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogType?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  twitterImage?: string;
  schemaMarkup?: object | object[];
  noindex?: boolean;
  breadcrumbs?: { name: string; url?: string }[];
  // LCP image preload
  preloadImage?: string;
  preloadImageSrcset?: string;
  // Pass author name from pages that already fetch authors (about, support, blog, etc.)
  // Falls back to company name if not provided — avoids a redundant getAuthors() call in BaseLayout
  authorName?: string;
  // Page-specific WhatsApp pre-filled message for the floating button
  waMessage?: string;
}

// Site-wide settings from API (eCatalogue) — fetched before props destructuring so companyName is available as default
const [site, company] = await Promise.all([
  getSiteSettings("eCatalogue"),
  getCompanyInfo("AGE"),
]);

const companyName = company?.legalName ?? company?.name ?? "";

const {
  title = companyName,
  description = "B2B fabric manufacturer and exporter.",
  canonical,
  keywords,
  ogTitle,
  ogDescription,
  ogImage,
  ogType = "website",
  twitterTitle,
  twitterDescription,
  twitterImage,
  schemaMarkup,
  noindex = false,
  breadcrumbs,
  preloadImage,
  preloadImageSrcset,
  authorName: authorNameProp,
  waMessage,
} = Astro.props;
// Use prop if passed (pages that already fetched authors), otherwise fall back to company name
const authorName = authorNameProp ?? companyName;

const siteBase = SITE_BASE;
const rawPath = Astro.url.pathname.replace(/\.html$/, '').replace(/\/index$/, '');
const cleanPath = rawPath === '/' ? '' : rawPath;
const resolvedCanonical = canonical ?? undefined;
const resolvedOgTitle = ogTitle ?? title;
const resolvedOgDesc = ogDescription ?? description;
const resolvedTwitterTitle = twitterTitle ?? resolvedOgTitle;
const resolvedTwitterDesc = twitterDescription ?? resolvedOgDesc;

// Always resolve an absolute OG image — fallback to brand logo so og:image is never missing
const defaultOgImage = `${siteBase}/images/icons/my_logo.webp`;
const resolvedOgImage = ogImage
  ? (ogImage.startsWith("http") ? ogImage : `${siteBase}${ogImage}`)
  : defaultOgImage;
const resolvedTwitterImage = twitterImage
  ? (twitterImage.startsWith("http") ? twitterImage : `${siteBase}${twitterImage}`)
  : resolvedOgImage;

// robots: noindex prop overrides, otherwise use API robotsPolicy or default to index, follow
const robotsContent = noindex
  ? "noindex, nofollow"
  : (site?.robotsPolicy ?? "index, follow");

const schemaArray = schemaMarkup
  ? Array.isArray(schemaMarkup) ? schemaMarkup : [schemaMarkup]
  : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#041632" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>

    <!-- Preconnect to Cloudinary for faster image loads -->
    <link rel="preconnect" href="https://res.cloudinary.com" />

    <!-- LCP image preload (per-page, injected by pages that need it) -->
    {preloadImage && (
      <link
        rel="preload"
        as="image"
        href={preloadImage}
        imagesrcset={preloadImageSrcset || undefined}
        imagesizes="(max-width: 1024px) 100vw, 58vw"
        fetchpriority="high"
      />
    )}

    <!-- Preload self-hosted variable fonts -->
    <link rel="preload" href="/fonts/manrope-vf.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-vf.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/newsreader-vf.woff2" as="font" type="font/woff2" crossorigin />
    <!-- Font-face declarations inline — keeps fonts out of the CSS bundle -->
    <style is:inline>
      @font-face {
        font-family: "Manrope Variable";
        src: url("/fonts/manrope-vf.woff2") format("woff2-variations");
        font-weight: 200 800;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: "Inter Variable";
        src: url("/fonts/inter-vf.woff2") format("woff2-variations");
        font-weight: 100 900;
        font-style: normal;
        font-display: swap;
      }
      @font-face {
        font-family: "Newsreader Variable";
        src: url("/fonts/newsreader-vf.woff2") format("woff2-variations");
        font-weight: 200 800;
        font-style: normal;
        font-display: swap;
      }
    </style>
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <meta name="author" content={authorName} />
    <meta name="publisher" content={authorName} />
    {keywords && keywords.length > 0 && (
      <meta name="keywords" content={keywords.join(", ")} />
    )}
    {resolvedCanonical && <link rel="canonical" href={resolvedCanonical} />}
    <link rel="alternate" hreflang="en" href={resolvedCanonical ?? `${siteBase}${cleanPath}`} />
    <link rel="alternate" hreflang="x-default" href={resolvedCanonical ?? `${siteBase}${cleanPath}`} />

    <!-- Site Verification -->
    {site?.googleVerification && (
      <meta name="google-site-verification" content={site.googleVerification} />
    )}
    {site?.bingVerification && (
      <meta name="msvalidate.01" content={site.bingVerification} />
    )}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={resolvedOgTitle} />
    <meta property="og:description" content={resolvedOgDesc} />
    <meta property="og:url" content={resolvedCanonical ?? ""} />
    <meta property="og:site_name" content={companyName} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={resolvedOgTitle} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTwitterTitle} />
    <meta name="twitter:description" content={resolvedTwitterDesc} />
    {site?.twitterHandle && <meta name="twitter:site" content={site.twitterHandle} />}
    <meta name="twitter:image" content={resolvedTwitterImage} />

    <!-- JSON-LD Structured Data -->
    {schemaArray && schemaArray.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <!-- Local Business / Organization Schema -->
    <LocalBusinessSchema company={company} site={site} />

    <!-- Breadcrumb Schema (skip on homepage) -->
    {breadcrumbs && breadcrumbs.length > 0 && (
      <BreadcrumbSchema items={breadcrumbs} />
    )}

    {site?.gaMeasurementId && (
      <script type="text/partytown" src={`https://www.googletagmanager.com/gtag/js?id=${site.gaMeasurementId}`} />
      <script type="text/partytown" set:html={`
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        window.gtag = gtag;
        gtag('js', new Date());
        gtag('config', '${site.gaMeasurementId}');
      `} />
    )}
    {site?.clarityId && (
      <script type="text/partytown" set:html={`window.clarity=window.clarity||function(){(window.clarity.q=window.clarity.q||[]).push(arguments)};`} />
      <script type="text/partytown" src={`https://www.clarity.ms/tag/${site.clarityId}`} />
    )}

    <!-- Clarity custom event bridge: mirrors gtag events → clarity("set") tags -->
    <!-- Runs in main thread so clarity() is always available -->
    <script>
      type ClarityFn = (action: string, key: string, value?: string) => void;
      type GtagFn = (...args: unknown[]) => void;

      interface DataLayerItem {
        event?: string;
        page_path?: string;
        [key: string]: unknown;
      }

      function sendToClarity(eventName: string, pagePath: string): void {
        const w = window as unknown as { clarity?: ClarityFn };
        if (typeof w.clarity === 'function') {
          w.clarity('set', 'event', eventName);
          w.clarity('set', 'page', pagePath);
        }
      }

      function patchGtag(): void {
        const w = window as unknown as { gtag?: GtagFn; __clarityGtagPatched?: boolean };
        if (typeof w.gtag !== 'function' || w.__clarityGtagPatched) return;
        w.__clarityGtagPatched = true;
        const orig = w.gtag;
        w.gtag = (...args: unknown[]): void => {
          orig(...args);
          try {
            if (args[0] === 'event' && typeof args[1] === 'string') {
              const params = args[2] as DataLayerItem | undefined;
              const page = params?.page_path as string | undefined ?? window.location.pathname;
              sendToClarity(args[1], page);
            }
          } catch { /* ignore */ }
        };
      }

      // Patch gtag now and again after load (Partytown may initialize it late)
      patchGtag();
      window.addEventListener('load', patchGtag);

      // Also intercept dataLayer for events pushed before gtag is ready
      const w = window as unknown as { dataLayer?: DataLayerItem[] };
      w.dataLayer = w.dataLayer ?? [];
      const origPush = w.dataLayer.push.bind(w.dataLayer);
      w.dataLayer.push = (...items: DataLayerItem[]): number => {
        const result = origPush(...items);
        try {
          for (const obj of items) {
            if (obj?.event) {
              sendToClarity(obj.event, (obj.page_path as string | undefined) ?? window.location.pathname);
            }
          }
        } catch { /* ignore */ }
        return result;
      };
    </script>

    <!-- Material Symbols — self-hosted for long cache TTL, subset to used icons only -->
    <link rel="preload" href="/fonts/material-symbols-outlined.woff2" as="font" type="font/woff2" crossorigin />

    <style is:inline>
      @font-face {
        font-family: 'Material Symbols Outlined';
        font-style: normal;
        font-weight: 100 700;
        font-display: swap;
        src: url('/fonts/material-symbols-outlined.woff2') format('woff2');
      }
      .material-symbols-outlined {
        font-family: 'Material Symbols Outlined';
        font-weight: normal;
        font-style: normal;
        font-size: 24px;
        line-height: 1;
        letter-spacing: normal;
        text-transform: none;
        display: inline-block;
        white-space: nowrap;
        word-wrap: normal;
        direction: ltr;
        -webkit-font-feature-settings: 'liga';
        -webkit-font-smoothing: antialiased;
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      }
    </style>
  </head>
  <body class="min-h-screen bg-[var(--color-background)] text-[var(--color-text)]">
    <Header />
    <main class="pt-[94px] md:pt-[102px]">
      <slot />
    </main>
    <Footer />
    <FloatingActions waMessage={waMessage} />
    <!-- WhatsApp delegated click handler: opens data-wa-link URLs in a new tab -->
    <script is:inline>
      document.addEventListener('click', (e) => {
        const waBtn = e.target.closest('[data-wa-link]');
        if (waBtn) {
          const url = waBtn.getAttribute('data-wa-link');
          window.open(url, '_blank', 'noopener,noreferrer');
        }
      });
    </script>
  </body>
</html>
