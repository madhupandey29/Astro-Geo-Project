---
import "../styles/global.css";
import Header from "/src/layouts/Header.astro";
import Footer from "/src/layouts/Footer.astro";
import FloatingActions from "../components/common/FloatingActions.astro";
import LocalBusinessSchema from "../components/schema/LocalBusinessSchema.astro";
import { getSiteSettings } from "../lib/api";

interface Props {
  title?: string;
  description?: string;
  // Per-page SEO overrides
  canonical?: string;
  keywords?: string[];
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  ogType?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  twitterImage?: string;
  schemaMarkup?: object | object[];
  noindex?: boolean;
}

const {
  title = "Amrita Fashions",
  description = "B2B fabric manufacturer and exporter.",
  canonical,
  keywords,
  ogTitle,
  ogDescription,
  ogImage,
  ogType = "website",
  twitterTitle,
  twitterDescription,
  twitterImage,
  schemaMarkup,
  noindex = false,
} = Astro.props;

// Site-wide settings from API (eCatalogue)
const site = await getSiteSettings("eCatalogue");

const siteBase = import.meta.env.PUBLIC_SITE_URL ?? "https://www.amrita-fashions.com";
const resolvedCanonical = canonical ?? `${siteBase}${Astro.url.pathname}`;
const resolvedOgTitle = ogTitle ?? title;
const resolvedOgDesc = ogDescription ?? description;
const resolvedTwitterTitle = twitterTitle ?? resolvedOgTitle;
const resolvedTwitterDesc = twitterDescription ?? resolvedOgDesc;
const resolvedTwitterImage = twitterImage ?? ogImage;

// robots: noindex prop overrides, otherwise use API robotsPolicy or default to index, follow
const robotsContent = noindex
  ? "noindex, nofollow"
  : (site?.robotsPolicy ?? "index, follow");

const schemaArray = schemaMarkup
  ? Array.isArray(schemaMarkup) ? schemaMarkup : [schemaMarkup]
  : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <meta name="author" content="Amrita Global Enterprises" />
    <meta name="publisher" content="Amrita Global Enterprises" />
    {keywords && keywords.length > 0 && (
      <meta name="keywords" content={keywords.join(", ")} />
    )}
    <link rel="canonical" href={resolvedCanonical} />

    <!-- Site Verification -->
    {site?.googleVerification && (
      <meta name="google-site-verification" content={site.googleVerification} />
    )}
    {site?.bingVerification && (
      <meta name="msvalidate.01" content={site.bingVerification} />
    )}

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={resolvedOgTitle} />
    <meta property="og:description" content={resolvedOgDesc} />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:site_name" content="Amrita Fashions" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:width" content="1200" />}
    {ogImage && <meta property="og:image:height" content="630" />}
    {ogImage && <meta property="og:image:type" content="image/jpeg" />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTwitterTitle} />
    <meta name="twitter:description" content={resolvedTwitterDesc} />
    {site?.twitterHandle && <meta name="twitter:site" content={site.twitterHandle} />}
    {resolvedTwitterImage && <meta name="twitter:image" content={resolvedTwitterImage} />}

    <!-- JSON-LD Structured Data -->
    {schemaArray && schemaArray.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <!-- Local Business / Organization Schema -->
    <LocalBusinessSchema />

    <!-- Google Analytics -->
    {site?.gaMeasurementId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${site.gaMeasurementId}`}></script>
        <script define:vars={{ gaMeasurementId: site.gaMeasurementId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaMeasurementId);
        </script>
      </>
    )}

    <!-- Microsoft Clarity -->
    {site?.clarityId && (
      <script define:vars={{ clarityId: site.clarityId }}>
        (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window,document,"clarity","script",clarityId);
      </script>
    )}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" rel="stylesheet" />
    <style>
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      }
    </style>
  </head>
  <body class="min-h-screen bg-[var(--color-background)] text-[var(--color-text)]">
    <Header />
    <main class="pt-[94px] md:pt-[102px]">
      <slot />
    </main>
    <Footer />
    <FloatingActions />
  </body>
</html>
