---
import BaseLayout from "../layouts/BaseLayout.astro";
import AboutHero from "../components/about/AboutHero.astro";
import AboutTrustNumbers from "../components/about/AboutTrustNumbers.astro";
import AboutMissionVision from "../components/about/AboutMissionVision.astro";
import AboutTimeline from "../components/about/AboutTimeline.astro";
import AboutManufacturing from "../components/about/AboutManufacturing.astro";
import AboutLeadership from "../components/about/AboutLeadership.astro";
import AboutCTA from "../components/about/AboutCTA.astro";
import { getTopicPageBySlug, getAuthors, getCompanyInfo } from "../lib/api";
import { resolveCanonical } from "../lib/seo/canonical";

const ABOUT_OG_IMAGE = "https://lh3.googleusercontent.com/aida-public/AB6AXuB5rYWttbh6XITEOcBeURyt6qklLANwbPMgW8KAaSwC8g9iy78YJK_krbGLU41JN_Yu2nEohurOBCXQkaPvEDBXJG0Lw5ISGIDhR4vJhX5i6KEaRVD-sNd5KEpV5al1UXeoambztbcu5rhFcFo7R68Hcwe2vBDlFgZ9NcPpCHBxjrK2kQ6TccQLz504xGgx-f74-rmrGkNSaDamGvVIS8VVzLhT2eEwj9EVYJxLa8WK3QdrRaitaijNIHu9-rn8RD0vbfYse5ijTzlm";

const [aboutData, authors, company] = await Promise.all([
  getTopicPageBySlug("about"),
  getAuthors(),
  getCompanyInfo("AGE"),
]);
const companyName = company?.legalName ?? "";
---

<BaseLayout
  title={aboutData?.metaTitle ?? `About Us`}
  description={aboutData?.description ?? `For over five decades, ${companyName} has defined the intersection of technical precision and artistic mastery in the global fabric industry.`}
  keywords={aboutData?.keywords ?? undefined}
  canonical={resolveCanonical(aboutData?.canonicalUrl)}
  ogType={aboutData?.ogType ?? "website"}
  ogImage={aboutData?.image1CloudUrlHero ?? aboutData?.image1CloudUrl ?? ABOUT_OG_IMAGE}
  authorName={authors[0]?.name}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "About Us" },
  ]}
  waMessage="Hi, I'd like to know more about your company and your fabric manufacturing story."
>
  <AboutHero image={aboutData?.image1CloudUrlHero ?? aboutData?.image1CloudUrl ?? null} breadcrumbs={[{ name: "Home", href: "/" }, { name: "About Us" }]} />
  <AboutTrustNumbers />
  <AboutMissionVision mission={aboutData?.p1 ?? null} vision={aboutData?.p2 ?? null} image2={aboutData?.image2CloudUrl ?? null} />
  <AboutTimeline />
  <AboutManufacturing />
  <AboutLeadership authors={authors} />
  <AboutCTA phone={company?.phone1} />
</BaseLayout>
