---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { guides } from "../../data/guides";

export function getStaticPaths() {
  return guides.map((guide) => ({
    params: { slug: guide.slug },
    props: { guide },
  }));
}

const { guide } = Astro.props;
---

<BaseLayout
  title={`${guide.title} | Amrita Global Enterprises`}
  description={guide.excerpt}
>
  <main class="bg-white text-slate-900">
    <section class="max-w-4xl mx-auto px-4 lg:px-8 py-16">
      <p class="text-sm text-slate-500 mb-2">{guide.category} · {guide.readTime} · {guide.date}</p>
      <h1 class="text-4xl font-bold text-[#041632] mb-6">{guide.title}</h1>
      <p class="text-lg text-slate-600">{guide.excerpt}</p>
    </section>
  </main>
</BaseLayout>
