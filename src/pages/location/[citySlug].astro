---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { locations } from "../../data/locations";
import { fetchProducts } from "../../data/products";

export async function getStaticPaths() {
  const products = await fetchProducts();
  return locations.map((location) => ({
    params: { citySlug: location.slug },
    props: { location, products },
  }));
}

const { location, products } = Astro.props;
---

<BaseLayout
  title={`Fabric Supplier in ${location.city} | Amrita Global Enterprises`}
  description={location.heroSubtitle}
>
  <main class="bg-white text-slate-900">
    <section class="max-w-7xl mx-auto px-4 lg:px-8 py-16">
      <h1 class="text-4xl font-bold text-[#041632] mb-4">{location.heroTitle}</h1>
      <p class="text-lg text-slate-600 mb-12">{location.heroSubtitle}</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {products.map((product) => (
          <a href={`/fabric/${product.slug}`} class="block border rounded-xl overflow-hidden hover:shadow-lg transition-shadow">
            <img src={product.image} alt={product.imageAlt} class="w-full h-48 object-cover" width="400" height="192" loading="lazy" />
            <div class="p-4">
              <h2 class="font-semibold text-[#041632] text-lg mb-1">{product.name}</h2>
              <p class="text-sm text-slate-500">{product.specs.material} · {product.specs.weight}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>
</BaseLayout>
