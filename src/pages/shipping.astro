---
import BaseLayout from "../layouts/BaseLayout.astro";
import ShippingHero from "../components/shipping/ShippingHero.astro";
import ShippingProtection from "../components/shipping/ShippingProtection.astro";
import ShippingPorts from "../components/shipping/ShippingPorts.astro";
import ShippingFAQ from "../components/shipping/ShippingFAQ.astro";
import ShippingCTA from "../components/shipping/ShippingCTA.astro";
import { getTopicPageBySlug } from "../lib/api";
import { resolveCanonical } from "../lib/seo/canonical";

const seo = await getTopicPageBySlug("shipping");
---

<BaseLayout
  title={seo?.metaTitle ?? "Shipping & Logistics | Amrita Global Enterprises"}
  description={seo?.description ?? "Global textile logistics from Ahmedabad. FOB, CIF, DAP incoterms. Port Mundra and Kolkata connectivity. 50+ countries served since 1971."}
  keywords={seo?.keywords ?? undefined}
  canonical={resolveCanonical(seo?.canonicalUrl)}
  ogType={seo?.ogType ?? "website"}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Shipping & Logistics" },
  ]}
>
  <ShippingHero breadcrumbs={[{ name: "Home", href: "/" }, { name: "Shipping & Logistics" }]} />
  <ShippingProtection />
  <ShippingPorts />
  <ShippingFAQ />
  <ShippingCTA />
</BaseLayout>
