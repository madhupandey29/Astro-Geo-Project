---
import BaseLayout from "../layouts/BaseLayout.astro";

import CapabilitiesHero from "../components/capabilities/CapabilitiesHero.astro";
import CapabilitiesPillars from "../components/capabilities/CapabilitiesPillars.astro";
import CapabilitiesProcess from "../components/capabilities/CapabilitiesProcess.astro";
import CapabilitiesQualityHub from "../components/capabilities/CapabilitiesQuality.astro";
import CapabilitiesExportReadiness from "../components/capabilities/CapabilitiesExportReadiness.astro";
import CapabilitiesCertifications from "../components/capabilities/CapabilitiesCertifications.astro";
import CapabilitiesBottomCTA from "../components/capabilities/CapabilitiesBottomCTA.astro";
import { getCompanyInfo, getTopicPageBySlug } from "../lib/api";
import { resolveCanonical } from "../lib/seo/canonical";

const CAPABILITIES_OG_IMAGE = "https://lh3.googleusercontent.com/aida-public/AB6AXuDiUo6KfVsc6OW9-lgdOCBOESkxRHzy6W-mNiR9bY8Xkeq401k1p5oCVhNwgXBz80B_efZmjXD7fuc0Us0nrYJpLNmN1_Na7RFWQ2MhDYpqS3q1uzluVOmnsMh8m1hwzan3n2j3GYegAas8ABp8dO2oBwSbXlKv4Pw5n1kN1j1kN9BoruPe0lzAK35zDaMjYatvZSK7-eh7Ju5dpOOWY0LpoVjj_nCft8SVSE7asiEsabfUpLjwMNErUX8X9jsB5s766ztd7tWfZZn1";

const [company, seo] = await Promise.all([
  getCompanyInfo("AGE"),
  getTopicPageBySlug("capabilities"),
]);
---

<BaseLayout
  title={seo?.metaTitle}
  description={seo?.description ?? "Explore the manufacturing, quality, logistics, compliance, and technical capabilities of Amrita Fashions."}
  keywords={seo?.keywords ?? undefined}
  canonical={resolveCanonical(seo?.canonicalUrl)}
  ogType={seo?.ogType ?? "website"}
  ogImage={seo?.image1CloudUrlHero ?? seo?.image1CloudUrl ?? CAPABILITIES_OG_IMAGE}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Capabilities" },
  ]}
>
  <div class="bg-[#f8f9fa] text-[#191c1d]">
    <CapabilitiesHero breadcrumbs={[{ name: "Home", href: "/" }, { name: "Capabilities" }]} />
    <CapabilitiesPillars whatsapp={company?.whatsappNumber} phone={company?.phone1} image1={seo?.image1CloudUrl ?? undefined} />
    <CapabilitiesProcess />
    <CapabilitiesQualityHub image2={seo?.image2CloudUrl ?? undefined} />
    <CapabilitiesExportReadiness />
    <CapabilitiesCertifications />
    <CapabilitiesBottomCTA whatsapp={company?.whatsappNumber} phone={company?.phone1} />
  </div>
</BaseLayout>