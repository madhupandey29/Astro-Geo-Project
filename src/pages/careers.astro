---
import BaseLayout from "../layouts/BaseLayout.astro";
import CareersHero from "../components/careers/CareersHero.astro";
import CareersPositions from "../components/careers/CareersPositions.astro";
import CareersProcess from "../components/careers/CareersProcess.astro";
import CareersForm from "../components/careers/CareersForm.astro";
import { getTopicPageBySlug, getCompanyInfo } from "../lib/api";
import { resolveCanonical } from "../lib/seo/canonical";

const [seo, company] = await Promise.all([
  getTopicPageBySlug("careers"),
  getCompanyInfo("AGE"),
]);
const companyName = company?.legalName ?? "";
---

<BaseLayout
  title={seo?.metaTitle}
  description={seo?.description ?? `Join the Best Textile Supplier Award 2023 winner. Explore open roles in operations, global sales, and supply chain at ${companyName}.`}
  keywords={seo?.keywords ?? undefined}
  canonical={resolveCanonical(seo?.canonicalUrl)}
  ogType={seo?.ogType ?? "website"}
  ogImage={seo?.image1CloudUrlHero ?? seo?.image1CloudUrl ?? undefined}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Careers" },
  ]}
  waMessage="Hi, I'm looking for a great opportunity at your company. Can you tell me about current openings?"
>
  <CareersHero heroImage={seo?.image1CloudUrlHero ?? seo?.image1CloudUrl ?? undefined} breadcrumbs={[{ name: "Home", href: "/" }, { name: "Careers" }]} />
  <CareersPositions />
  <CareersProcess />
  <CareersForm />
</BaseLayout>
