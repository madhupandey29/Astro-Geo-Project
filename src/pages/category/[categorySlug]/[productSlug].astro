---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../../components/common/Breadcrumbs.astro";
import ProductDetailHero from "../../../components/product/ProductDetailHero.astro";
import ProductDetailBody from "../../../components/product/ProductDetailBody.astro";
import ProductDetailRelated from "../../../components/product/ProductDetailRelated.astro";
import { fetchProducts, type Product } from "../../../data/products";
import { getCategoryTopicPages } from "../../../lib/api";
const SITE_BASE = import.meta.env.PUBLIC_SITE_URL;

export async function getStaticPaths() {
  const [products, categories] = await Promise.all([
    fetchProducts(),
    getCategoryTopicPages(),
  ]);

  const paths: {
    params: { categorySlug: string; productSlug: string };
    props: { product: Product; collectionProducts: Product[]; categoryName: string };
  }[] = [];

  for (const cat of categories) {
    const catProducts = products.filter(
      (p) => p.slug && p.category.toLowerCase().trim() === cat.name.toLowerCase().trim()
    );
    for (const product of catProducts) {
      const collectionProducts = products.filter(
        (p) => p.collectionId === product.collectionId && p.id !== product.id && p.slug
      );
      paths.push({
        params: { categorySlug: cat.slug, productSlug: product.slug },
        props: { product, collectionProducts, categoryName: cat.name },
      });
    }
  }

  return paths;
}

const { product, collectionProducts, categoryName } = Astro.props as {
  product: Product;
  collectionProducts: Product[];
  categoryName: string;
};

const { categorySlug } = Astro.params;
const canonicalUrl = `${SITE_BASE}/fabric/${product.slug}`;
---

<style>
  .hide-scrollbar::-webkit-scrollbar { display: none; }
  .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<BaseLayout
  title={`${product.name} | Amrita Global Enterprises`}
  description={product.shortDesc}
  canonical={canonicalUrl}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: categoryName, url: `/category/${categorySlug}` },
    { name: product.name },
  ]}
>
  <div class="max-w-7xl mx-auto px-4 lg:px-8 pt-4">
    <Breadcrumbs
      items={[
        { name: "Home", href: "/" },
        { name: categoryName, href: `/category/${categorySlug}` },
        { name: product.name },
      ]}
      variant="light"
    />
  </div>
  <ProductDetailHero product={product} />
  <ProductDetailBody product={product} />
  <ProductDetailRelated product={product} collectionProducts={collectionProducts} />
</BaseLayout>
