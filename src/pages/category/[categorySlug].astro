---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { categories } from "../../data/categories";
import { products } from "../../data/products";

export function getStaticPaths() {
  return categories.map((category) => ({
    params: { categorySlug: category.slug },
    props: { category },
  }));
}

const { category } = Astro.props;
const categoryProducts = products.filter((p) => p.categorySlug === category.slug);
---

<BaseLayout
  title={`${category.name} | Amrita Global Enterprises`}
  description={category.description}
>
  <main class="bg-white text-slate-900">
    <section class="max-w-7xl mx-auto px-4 lg:px-8 py-16">
      <h1 class="text-4xl font-bold text-[#041632] mb-4">{category.heroTitle}</h1>
      <p class="text-lg text-slate-600 mb-12">{category.heroSubtitle}</p>

      {categoryProducts.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {categoryProducts.map((product) => (
            <a href={`/fabric/${product.slug}`} class="block border rounded-xl overflow-hidden hover:shadow-lg transition-shadow">
              <img src={product.image} alt={product.imageAlt} class="w-full h-48 object-cover" />
              <div class="p-4">
                <h2 class="font-semibold text-[#041632] text-lg mb-1">{product.name}</h2>
                <p class="text-sm text-slate-500">{product.specs.material} · {product.specs.weight}</p>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-slate-500">No products found in this category yet.</p>
      )}
    </section>
  </main>
</BaseLayout>
