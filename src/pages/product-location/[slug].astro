---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PLHero from "../../components/productandlocation/PLHero.astro";
import PLTrustMetrics from "../../components/productandlocation/PLTrustMetrics.astro";
import PLProductDetail from "../../components/productandlocation/PLProductDetail.astro";
import PLLocation from "../../components/productandlocation/PLLocation.astro";
import PLSuitability from "../../components/productandlocation/PLSuitability.astro";
import PLCollection from "../../components/productandlocation/PLCollection.astro";
import PLInquiryForm from "../../components/productandlocation/PLInquiryForm.astro";
import PLFAQ from "../../components/productandlocation/PLFAQ.astro";
import { getAllProductLocations, getCompanyInfo } from "../../lib/api";
import type { ApiProductLocation } from "../../lib/api";
import { stripHtml } from "../../data/products";

const SITE_BASE = import.meta.env.PUBLIC_SITE_URL;

export async function getStaticPaths() {
  const all = await getAllProductLocations();
  return all
    .filter((item) => item.slug)
    .map((item) => ({
      params: { slug: item.slug },
      props: { data: item },
    }));
}

const { data } = Astro.props as { data: ApiProductLocation };
const company = await getCompanyInfo("AGE");
const companyName = company?.legalName ?? "";
const product = data.product;
const location = data.location;

const pageTitle =
  data.title?.trim() ||
  (product && location ? `${product.productTitle || product.name} in ${location.name}` : null) ||
  "Product & Location";

const metaDescription =
  stripHtml(data.fulldescription).slice(0, 155) ||
  stripHtml(product?.fullProductDescription).slice(0, 155) ||
  (product && location
    ? `${product.name} available in ${location.name} for bulk B2B fabric sourcing from ${companyName}.`
    : `B2B fabric supply by product and location. ${companyName}.`);

const ogImage =
  data.image1CloudUrlHero ||
  product?.image1CloudUrlHero ||
  location?.image1CloudUrlHero ||
  data.image1CloudUrl ||
  product?.image1CloudUrl ||
  location?.image1CloudUrl ||
  undefined;

const canonicalUrl = `${SITE_BASE}/product-location/${data.slug}`;

// ── JSON-LD ───────────────────────────────────────────────────────────────────
const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Product & Location", url: "/product-location" },
  { name: pageTitle },
];

const additionalProperties = product && location ? [
  { name: "Structure",       value: product.structure },
  { name: "GSM",             value: String(product.gsm) },
  { name: "Width",           value: `${product.cm} cm / ${product.inch} inch` },
  { name: "Design",          value: product.design },
  { name: "Supply Model",    value: "Never-Out-of-Stock" },
  { name: "Location Served", value: location.name },
].filter((p) => p.value).map(({ name, value }) => ({
  "@type": "PropertyValue",
  name,
  value,
})) : [];

const faqItems = [
  { q: data.productlocationQ1, a: data.productlocationA1 },
  { q: data.productlocationQ2, a: data.productlocationA2 },
  { q: data.productlocationQ3, a: data.productlocationA3 },
  { q: data.productlocationQ4, a: data.productlocationA4 },
  { q: data.productlocationQ5, a: data.productlocationA5 },
].filter((f) => f.q && f.a);

const faqSchema = faqItems.length > 0
  ? {
      "@type": "FAQPage",
      "@id": `${canonicalUrl}#faq`,
      mainEntity: faqItems.map(({ q, a }) => ({
        "@type": "Question",
        name: q,
        acceptedAnswer: { "@type": "Answer", text: a },
      })),
    }
  : null;

const graphSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebPage",
      "@id": `${canonicalUrl}#webpage`,
      url: canonicalUrl,
      name: pageTitle,
      description: metaDescription,
      inLanguage: "en",
      ...(ogImage ? { primaryImageOfPage: { "@type": "ImageObject", url: ogImage } } : {}),
      about: { "@id": `${canonicalUrl}#product` },
      isPartOf: { "@id": `${SITE_BASE}/#website` },
    },
    {
      "@type": "BreadcrumbList",
      "@id": `${canonicalUrl}#breadcrumb`,
      itemListElement: breadcrumbs.map((item, i) => ({
        "@type": "ListItem",
        position: i + 1,
        name: item.name,
        ...(item.url ? { item: `${SITE_BASE}${item.url}` } : {}),
      })),
    },
    {
      "@type": "Product",
      "@id": `${canonicalUrl}#product`,
      name: product?.name,
      description: metaDescription,
      image: [ogImage].filter(Boolean),
      brand: { "@type": "Brand", name: companyName },
      category: product?.category,
      material: Array.isArray(product?.content) ? product.content.join(", ") : product?.content,
      color: Array.isArray(product?.color) ? product.color.join(", ") : product?.color,
      additionalProperty: additionalProperties,
      offers: {
        "@type": "Offer",
        "@id": `${canonicalUrl}#offer`,
        url: canonicalUrl,
        availability: "https://schema.org/InStock",
        priceCurrency: "INR",
        seller: { "@type": "Organization", name: companyName },
      },
    },
    ...(faqSchema ? [faqSchema] : []),
  ],
};
---

<BaseLayout
  title={`${pageTitle}`}
  description={metaDescription}
  canonical={canonicalUrl}
  keywords={data.keywords?.length ? data.keywords : undefined}
  ogImage={ogImage}
  ogType="product"
  schemaMarkup={graphSchema}
  breadcrumbs={breadcrumbs}
  preloadImage={ogImage}
  waMessage={product && location
    ? `Hi, I'm interested in ${product.name} available in ${location.name}. Can you share more details?`
    : `Hi, I'm interested in ${pageTitle}. Can you share more details?`}
>
  <PLHero
    data={data}
    breadcrumbs={[
      { name: "Home", href: "/" },
      { name: "Product & Location", href: "/product-location" },
      { name: pageTitle },
    ]}
  />
  <PLTrustMetrics />
  <PLProductDetail data={data} />
  <PLLocation data={data} />
  <PLSuitability data={data} />
  <PLCollection data={data} />
  <PLInquiryForm data={data} />
  <PLFAQ data={data} />
</BaseLayout>
