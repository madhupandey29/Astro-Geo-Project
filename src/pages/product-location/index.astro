---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PLListingHero from "../../components/productandlocation/PLListingHero.astro";
import PLGrid from "../../components/productandlocation/PLGrid.astro";
import { getAllProductLocations, getTopicPageBySlug } from "../../lib/api";

const SITE_BASE = import.meta.env.PUBLIC_SITE_URL;

const [items, seo] = await Promise.all([
  getAllProductLocations(),
  getTopicPageBySlug("product-location"),
]);

const breadcrumbs = [
  { name: "Home", url: "/" },
  { name: "Product & Location" },
];

const listSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Product & Location Combinations — Amrita Global Enterprises",
  url: `${SITE_BASE}/product-location`,
  numberOfItems: items.length,
  itemListElement: items.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    url: `${SITE_BASE}/product-location/${item.slug}`,
    name: item.title ?? `${item.productName} in ${item.locationName}`,
  })),
};
---

<BaseLayout
  title={seo?.metaTitle}
  description={seo?.description ?? "Browse all fabric supply combinations by product and city. Bulk B2B sourcing from Amrita Global Enterprises."}
  keywords={seo?.keywords ?? undefined}
  canonical={`${SITE_BASE}/product-location`}
  ogType="website"
  ogImage={seo?.image1CloudUrlHero ?? seo?.image1CloudUrl ?? undefined}
  schemaMarkup={[listSchema]}
  breadcrumbs={breadcrumbs}
>
  <PLListingHero
    total={items.length}
    breadcrumbs={[{ name: "Home", href: "/" }, { name: "Product & Location" }]}
  />
  <PLGrid items={items} />
</BaseLayout>
