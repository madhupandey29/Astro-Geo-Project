---
import BaseLayout from "../layouts/BaseLayout.astro";
import FAQHero from "../components/faq/FAQHero.astro";
import FAQAccordion from "../components/faq/FAQAccordion.astro";
import FAQCTA from "../components/faq/FAQCTA.astro";
import { getWebsiteFAQCategories, getTopicPageBySlug } from "../lib/api";
import { resolveCanonical } from "../lib/seo/canonical";
import { faqCategories } from "../data/faqs";

const [apiCategories, seo] = await Promise.all([
  getWebsiteFAQCategories(),
  getTopicPageBySlug("faq"),
]);
const categories = apiCategories.length > 0 ? apiCategories : faqCategories;
---

<BaseLayout
  title={seo?.metaTitle}
  description={seo?.description ?? "Expert answers for fabric buyers — sourcing, manufacturing, logistics, pricing, and MOQ questions answered by Amrita Global Enterprises."}
  keywords={seo?.keywords ?? undefined}
  canonical={resolveCanonical(seo?.canonicalUrl)}
  ogType={seo?.ogType ?? "website"}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "FAQ" },
  ]}
>
  <FAQHero breadcrumbs={[{ name: "Home", href: "/" }, { name: "FAQ" }]} />
  <FAQAccordion categories={categories} />
  <FAQCTA />
</BaseLayout>
