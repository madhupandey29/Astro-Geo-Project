---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ProductHero from "../../../components/product/ProductHero.astro";
import ProductIntro from "../../../components/product/ProductIntro.astro";
import ProductSection from "../../../components/product/ProductSection.astro";
import ProductCTA from "../../../components/product/ProductCTA.astro";
import ProductGuide from "../../../components/product/ProductGuide.astro";
import ProductFAQ from "../../../components/product/ProductFAQ.astro";
import { fetchProductsPage } from "../../../data/products";
import { getProducts, getFilterValues } from "../../../lib/api";

export async function getStaticPaths() {
  const first = await getProducts(1, 20);
  return Array.from({ length: first.totalPages - 1 }, (_, i) => ({
    params: { page: String(i + 2) },
  }));
}

const pageNum = Number(Astro.params.page);
const [{ products: allProducts, total, totalPages }, filters] = await Promise.all([
  fetchProductsPage(pageNum),
  getFilterValues(),
]);

const products = allProducts.map((p) => ({
  id: p.id,
  name: p.name,
  category: p.category,
  weight: p.specs.weight,
  width: p.specs.width,
  color: p.hex?.[0] ?? "#041632",
  image: p.image,
  imageSrcset: p.image1Srcset || undefined,
  href: p.slug ? `/fabric/${p.slug}` : null,
  filterCategory: p.category,
  filterColor: p.colorNames.join("|"),
  filterStructure: p.structure,
  filterContent: p.content,
  filterGsm: String(p.gsm),
}));

const renderedCount = products.length;

const faqItems = [
  {
    question: "What is your Minimum Order Quantity (MOQ)?",
    answer: "Our standard MOQ for stock items is 100 meters per color.",
  },
  {
    question: "Do you provide Oeko-Tex certifications?",
    answer: "Yes, selected products can be supplied with relevant testing and certification documents based on buyer requirements.",
  },
];
---

<BaseLayout
  title={`Fabric Catalog — Page ${pageNum} | Amrita Global Enterprises`}
  description="Browse our full fabric catalog including cotton twill, woven fabrics, and performance textiles."
>
  <main class="bg-white text-slate-900">
    <ProductHero />
    <ProductIntro />
    <ProductSection
      products={products}
      categories={filters.category}
      colors={filters.color}
      structures={filters.structure}
      contents={filters.content}
      designs={filters.design}
      finishes={filters.finish}
      currentPage={pageNum}
      totalPages={totalPages}
      total={total}
      pageCount={renderedCount}
    />
    <ProductCTA />
    <ProductGuide />
    <ProductFAQ items={faqItems} />
  </main>
</BaseLayout>
