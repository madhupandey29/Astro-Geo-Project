---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getTopicPageBySlug, getDynamicTopicPages, getCategoryTopicPages, getCompanyInfo, buildWaLink, getAllProductLocations } from "../lib/api";
import { resolveCanonical } from "../lib/seo/canonical";
import { fetchBlogPosts } from "../lib/blog";
import { fetchProducts } from "../data/products";
import CloudinaryImage from "../components/common/CloudinaryImage.astro";

const seo = await getTopicPageBySlug("sitemap");

const [collections, categoryPages, blogPosts, products, productLocations, company] = await Promise.all([
  getDynamicTopicPages(),
  getCategoryTopicPages(),
  fetchBlogPosts().catch(() => []),
  fetchProducts().catch(() => []),
  getAllProductLocations().catch(() => []).then(r => r.filter(pl => pl.name?.toLowerCase() !== "test")),
  getCompanyInfo("AGE"),
]);

const whatsappHref = buildWaLink(company?.whatsappNumber);



const PREVIEW = 4;

const linkClass = "flex items-center gap-3 hover:text-[#775a19] transition-colors";
const dotClass = "w-1.5 h-1.5 rounded-full bg-[#775a19] shrink-0";
---

<BaseLayout
  title={seo?.metaTitle}
  description={seo?.description ?? "Navigate through our comprehensive directory of textile manufacturing solutions, technical capabilities, and global trade infrastructures."}
  keywords={seo?.keywords ?? undefined}
  canonical={resolveCanonical(seo?.canonicalUrl)}
  ogType={seo?.ogType ?? "website"}
  ogImage={seo?.image1CloudUrl ?? undefined}
  waMessage="Hi, I was browsing your sitemap and would like to know more about your fabric offerings."
>
  <!-- Hero -->
  <header class="max-w-7xl mx-auto px-6 md:px-8 py-12 md:py-24 text-center">
    <h1 class="font-serif text-4xl md:text-7xl font-bold text-[#1B2B48] tracking-tight mb-4 md:mb-6">Sitemap — Complete Page Directory</h1>
    <p class="font-body text-base md:text-xl text-slate-500 max-w-2xl mx-auto leading-relaxed">
      Navigate through our comprehensive directory of textile manufacturing solutions, technical capabilities, and global trade infrastructures.
    </p>
    <div class="mt-8 md:mt-12 w-16 md:w-24 h-1 bg-[#775a19] mx-auto rounded-full opacity-30"></div>
  </header>

  <!-- Sitemap Grid -->
  <section class="max-w-7xl mx-auto px-6 md:px-8 mb-16 md:mb-24">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6">

      <!-- Core Pages -->
      <div class="md:col-span-4 bg-slate-50 p-6 md:p-8 rounded-xl">
        <h2 class="font-serif text-xl md:text-2xl font-bold text-[#1B2B48] mb-6 border-b border-slate-200 pb-4">Core Pages</h2>
        <ul class="space-y-4 text-slate-700">
          {[
            { label: "Home", href: "/" },
            { label: "About Us", href: "/about" },
            { label: "Capabilities", href: "/capabilities" },
            { label: "Certifications", href: "/certifications" },
            { label: "Careers", href: "/careers" },
            { label: "Support & Contact", href: "/support" },
            { label: "FAQ", href: "/faq" },
            { label: "Shipping & Logistics", href: "/shipping" },
            { label: "Ahmedabad Hub", href: "/ahmedabad-hub" },
          ].map(({ label, href }) => (
            <li>
              <a class={linkClass} href={href}>
                <span class={dotClass}></span>
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Products & Fabric Catalog -->
      <div class="md:col-span-8 bg-white p-6 md:p-8 rounded-xl shadow-sm border border-slate-100">
        <h2 class="font-serif text-xl md:text-2xl font-bold text-[#1B2B48] mb-6 border-b border-slate-200 pb-4">Products &amp; Fabric Catalog</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-slate-600 mb-3">Catalog</p>
            <ul class="space-y-4 text-slate-700 mb-6">
              <li>
                <a class={linkClass} href="/fabric">
                  <span class={dotClass}></span>
                  All Fabrics
                </a>
              </li>
            </ul>

            <p class="text-xs font-semibold uppercase tracking-widest text-slate-600 mb-3">Categories</p>
            <ul class="space-y-4 text-slate-700 mb-6">
              {categoryPages.map((cat) => (
                <li>
                  <a class={linkClass} href={`/category/${cat.slug}`}>
                    <span class={dotClass}></span>
                    {cat.name}
                  </a>
                </li>
              ))}
            </ul>

            <p class="text-xs font-semibold uppercase tracking-widest text-slate-600 mb-3">Collections</p>
            <ul class="space-y-4 text-slate-700">
              {collections.map((col) => (
                <li>
                  <a class={linkClass} href={`/collection/${col.slug}`}>
                    <span class={dotClass}></span>
                    {col.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
          <div class="relative overflow-hidden rounded-lg aspect-video hidden md:block">
            <CloudinaryImage
              src={seo?.image1CloudUrl ?? seo?.image1CloudUrlWeb ?? ""}
              alt="Industrial weaving loom"
              width={512}
              height={288}
              widths={[400, 512, 800]}
              sizes="(min-width: 768px) 33vw, 0px"
              crop="fill"
              loading="lazy"
              class="absolute inset-0 w-full h-full object-cover opacity-20 grayscale"
            />
          </div>
        </div>
      </div>

      <!-- All Products -->
      <div class="md:col-span-12 bg-white p-6 md:p-8 rounded-xl shadow-sm border border-slate-100" id="products-section">
        <h2 class="font-serif text-xl md:text-2xl font-bold text-[#1B2B48] mb-6 border-b border-slate-200 pb-4">All Products</h2>
        <ul class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 text-slate-700" id="products-list">
          {products.slice(0, PREVIEW).map((p) => (
            <li>
              <a class={linkClass} href={`/fabric/${p.slug}`}>
                <span class={dotClass}></span>
                <span class="text-sm">{p.name}</span>
              </a>
            </li>
          ))}
          {products.slice(PREVIEW).map((p) => (
            <li class="product-extra hidden">
              <a class={linkClass} href={`/fabric/${p.slug}`}>
                <span class={dotClass}></span>
                <span class="text-sm">{p.name}</span>
              </a>
            </li>
          ))}
        </ul>
        {products.length > PREVIEW && (
          <div class="mt-6 text-center">
            <button
              id="products-toggle"
              class="text-sm font-semibold text-[#775a19] border border-[#775a19] px-6 py-2 rounded-lg hover:bg-[#775a19] hover:text-white transition-all"
            >
              View All {products.length} Products
            </button>
          </div>
        )}
      </div>

      <!-- Product + Location Pages -->
      <div class="md:col-span-12 bg-white p-6 md:p-8 rounded-xl shadow-sm border border-slate-100" id="pl-section">
        <h2 class="font-serif text-xl md:text-2xl font-bold text-[#1B2B48] mb-6 border-b border-slate-200 pb-4">Product &amp; Location Pages</h2>
        <ul class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 text-slate-700" id="pl-list">
          <li>
            <a class={linkClass} href="/fabric-manufacturer">
              <span class={dotClass}></span>
              <span class="text-sm font-semibold">All Product Locations</span>
            </a>
          </li>
          {productLocations.slice(0, PREVIEW).map((pl) => (
            <li>
              <a class={linkClass} href={`/fabric-manufacturer/${pl.slug}`}>
                <span class={dotClass}></span>
                <span class="text-sm">{pl.name}</span>
              </a>
            </li>
          ))}
          {productLocations.slice(PREVIEW).map((pl) => (
            <li class="pl-extra hidden">
              <a class={linkClass} href={`/fabric-manufacturer/${pl.slug}`}>
                <span class={dotClass}></span>
                <span class="text-sm">{pl.name}</span>
              </a>
            </li>
          ))}
        </ul>
        {productLocations.length > PREVIEW && (
          <div class="mt-6 text-center">
            <button
              id="pl-toggle"
              class="text-sm font-semibold text-[#775a19] border border-[#775a19] px-6 py-2 rounded-lg hover:bg-[#775a19] hover:text-white transition-all"
            >
              View All {productLocations.length} Locations
            </button>
          </div>
        )}
      </div>


      <!-- Knowledge Center -->
      <div class="md:col-span-8 bg-slate-50 p-6 md:p-8 rounded-xl">
        <h2 class="font-serif text-xl md:text-2xl font-bold text-[#1B2B48] mb-6 border-b border-slate-200 pb-4">Knowledge Center</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <!-- Blog -->
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-slate-600 mb-3">Blog</p>
            <ul class="space-y-4 text-slate-700 mb-4">
              <li>
                <a class={linkClass} href="/blog">
                  <span class={dotClass}></span>
                  Blog & Insights
                </a>
              </li>
              {blogPosts.slice(0, PREVIEW).map((post) => (
                <li>
                  <a class={linkClass} href={`/blog/${post.slug}`}>
                    <span class={dotClass}></span>
                    <span class="text-sm">{post.title}</span>
                  </a>
                </li>
              ))}
              {blogPosts.slice(PREVIEW).map((post) => (
                <li class="blog-extra hidden">
                  <a class={linkClass} href={`/blog/${post.slug}`}>
                    <span class={dotClass}></span>
                    <span class="text-sm">{post.title}</span>
                  </a>
                </li>
              ))}
            </ul>
            {blogPosts.length > PREVIEW && (
              <button
                id="blog-toggle"
                class="text-xs font-semibold text-[#775a19] border border-[#775a19] px-4 py-1.5 rounded-lg hover:bg-[#775a19] hover:text-white transition-all"
              >
                View All {blogPosts.length} Posts
              </button>
            )}
          </div>

          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-slate-600 mb-3 mt-6">Help</p>
            <ul class="space-y-4 text-slate-700">
              <li>
                <a class={linkClass} href="/faq">
                  <span class={dotClass}></span>
                  FAQ
                </a>
              </li>
              <li>
                <a class={linkClass} href="/certifications">
                  <span class={dotClass}></span>
                  Certifications
                </a>
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Corporate & Legal -->
      <div class="md:col-span-12 bg-[#1B2B48] text-white p-8 md:p-12 rounded-xl relative overflow-hidden">
        <div class="relative z-10">
          <h2 class="font-serif text-2xl md:text-3xl font-bold mb-8 text-center md:text-left">Corporate &amp; Legal</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <ul class="space-y-4 text-white/80">
              {[
                { label: "Careers", href: "/careers" },
                { label: "Shipping & Logistics", href: "/shipping" },
                { label: "Ahmedabad Hub", href: "/ahmedabad-hub" },
              ].map(({ label, href }) => (
                <li>
                  <a class="flex items-center gap-3 hover:text-[#c9a84c] transition-colors" href={href}>
                    <span class="w-1.5 h-1.5 rounded-full bg-[#775a19] shrink-0"></span>
                    {label}
                  </a>
                </li>
              ))}
            </ul>
            <ul class="space-y-4 text-white/80 border-t border-white/10 pt-4 md:border-0 md:pt-0">
              {[
                { label: "Terms & Conditions", href: "/terms-and-conditions" },
                { label: "Trade Compliance", href: "/certifications" },
                { label: "Support & Contact", href: "/support" },
              ].map(({ label, href }) => (
                <li>
                  <a class="flex items-center gap-3 hover:text-[#c9a84c] transition-colors" href={href}>
                    <span class="w-1.5 h-1.5 rounded-full bg-[#775a19] shrink-0"></span>
                    {label}
                  </a>
                </li>
              ))}
            </ul>
            <ul class="space-y-4 text-white/80 border-t border-white/10 pt-4 md:border-0 md:pt-0">
              {[
                { label: "XML Sitemap", href: "/sitemap.xml", newTab: true },
              ].map(({ label, href, newTab }) => (
                <li>
                  <a class="flex items-center gap-3 hover:text-[#c9a84c] transition-colors" href={href} target={newTab ? "_blank" : undefined} rel={newTab ? "noopener noreferrer" : undefined}>
                    <span class="w-1.5 h-1.5 rounded-full bg-[#775a19] shrink-0"></span>
                    {label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>
        <div class="absolute top-0 right-0 w-1/3 h-full opacity-10 pointer-events-none hidden md:block">
          <CloudinaryImage
            src={seo?.image2CloudUrlWeb ?? seo?.image2CloudUrl ?? ""}
            alt="Textile pattern"
            width={512}
            height={512}
            widths={[300, 512, 800]}
            sizes="33vw"
            crop="fill"
            loading="lazy"
            class="w-full h-full object-cover"
          />
        </div>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-4xl mx-auto px-6 md:px-8 py-12 md:py-20 bg-slate-50 rounded-3xl text-center shadow-xl border border-white/40 mb-16 md:mb-24">
    <h2 class="font-serif text-2xl md:text-4xl font-bold text-[#1B2B48] mb-4">Need customized advice?</h2>
    <p class="text-slate-500 mb-10 text-base md:text-lg">Our specialists are available for consultation regarding bulk orders and industrial specifications.</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/support"
        class="bg-[#1B2B48] text-white px-8 py-4 rounded-lg font-bold hover:bg-[#775a19] transition-all shadow-lg flex items-center justify-center gap-2"
      >
        <span class="material-symbols-outlined text-lg">mail</span>
        Contact Specialists
      </a>
      {whatsappHref && (
        <a
          href={whatsappHref}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-white text-[#1B2B48] border border-slate-200 px-8 py-4 rounded-lg font-bold hover:bg-slate-100 transition-all flex items-center justify-center gap-2"
        >
          <span class="material-symbols-outlined text-lg text-green-600">chat</span>
          WhatsApp Inquire
        </a>
      )}
    </div>
  </section>

  <script>
    function setupToggle(btnId: string, itemClass: string, totalLabel: string) {
      const btn = document.getElementById(btnId);
      if (!btn) return;
      let expanded = false;
      btn.addEventListener("click", () => {
        expanded = !expanded;
        document.querySelectorAll(`.${itemClass}`).forEach((el) => {
          el.classList.toggle("hidden", !expanded);
        });
        btn.textContent = expanded ? "Show Less" : totalLabel;
      });
    }

    setupToggle("products-toggle", "product-extra", document.getElementById("products-toggle")?.textContent ?? "View More");
    setupToggle("blog-toggle", "blog-extra", document.getElementById("blog-toggle")?.textContent ?? "View More");
    setupToggle("pl-toggle", "pl-extra", document.getElementById("pl-toggle")?.textContent ?? "View More");
  </script>
</BaseLayout>
