---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogPostCTA from "../../components/blog/BlogPostCTA.astro";
import BlogDynamicPostHero from "../../components/blog/BlogDynamicPostHero.astro";
import BlogDynamicPostBody from "../../components/blog/BlogDynamicPostBody.astro";
import { fetchBlogPosts, getPostImage } from "../../lib/blog";
import { getCompanyInfo } from "../../lib/api";
const SITE_BASE = import.meta.env.PUBLIC_SITE_URL;

export async function getStaticPaths() {
  const posts = await fetchBlogPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const company = await getCompanyInfo("AGE");

// F2 FIX: use SITE_BASE directly — no local alias needed
const canonicalUrl = `${SITE_BASE}/blog/${post.slug}`;
const heroImage = getPostImage(post);

// JSON-LD: Article schema
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": canonicalUrl,
  url: canonicalUrl,
  headline: post.title,
  name: post.title,
  description: post.excerpt ?? undefined,
  image: {
    "@type": "ImageObject",
    url: heroImage,
  },
  datePublished: post.publishedAt,
  dateModified: post.publishedAt,
  ...(post.category ? { articleSection: post.category } : {}),
  ...(post.tags?.length ? { keywords: post.tags.join(", ") } : {}),
  ...(post.readingTimeMin ? { timeRequired: `PT${post.readingTimeMin}M` } : {}),
  author: {
    "@type": "Organization",
    name: company?.legalName ?? "Amrita Global Enterprises",
    url: SITE_BASE,
  },
  publisher: {
    "@type": "Organization",
    name: company?.legalName ?? "Amrita Global Enterprises",
    logo: {
      "@type": "ImageObject",
      url: company?.logoUrl ? decodeURIComponent(company.logoUrl) : `${SITE_BASE}/favicon.svg`,
    },
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": canonicalUrl,
  },
};

// JSON-LD: FAQPage schema (from q1/q2/q3 + a1/a2/a3)
const faqPairs = [
  { q: post.q1, a: post.a1 },
  { q: post.q2, a: post.a2 },
  { q: post.q3, a: post.a3 },
].filter((item) => item.q && item.a);

const faqSchema = faqPairs.length > 0
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: faqPairs.map(({ q, a }) => ({
        "@type": "Question",
        name: q,
        acceptedAnswer: { "@type": "Answer", text: a },
      })),
    }
  : null;

const schemas = [articleSchema, faqSchema].filter(Boolean);
---

<BaseLayout
  title={`${post.title} | Amrita Global`}
  description={post.excerpt ?? undefined}
  canonical={canonicalUrl}
  keywords={post.tags?.length ? post.tags : undefined}
  noindex={post.robots ? post.robots.includes("noindex") : false}
  ogTitle={post.title}
  ogDescription={post.excerpt ?? undefined}
  ogImage={heroImage}
  ogType="article"
  twitterTitle={post.title}
  twitterDescription={post.excerpt ?? undefined}
  twitterImage={heroImage}
  schemaMarkup={schemas}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Blog", url: "/blog" },
    { name: post.title },
  ]}
>
  <BlogDynamicPostHero post={post} breadcrumbs={[
    { name: "Home", href: "/" },
    { name: "Blog", href: "/blog" },
    { name: post.title },
  ]} />
  <BlogDynamicPostBody post={post} />
  <BlogPostCTA whatsapp={company?.whatsappNumber} />
</BaseLayout>
