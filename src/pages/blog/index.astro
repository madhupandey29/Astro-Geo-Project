---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogHero from "../../components/blog/BlogHero.astro";
import BlogNewsletter from "../../components/blog/BlogNewsletter.astro";
import BlogDynamicGrid from "../../components/blog/BlogDynamicGrid.astro";
import { fetchBlogPosts, getPostImage } from "../../lib/blog";
import { getTopicPageBySlug, getCompanyInfo } from "../../lib/api";
import { resolveCanonical } from "../../lib/seo/canonical";
const SITE_BASE = import.meta.env.PUBLIC_SITE_URL;

const [posts, seo, company] = await Promise.all([
  fetchBlogPosts(),
  getTopicPageBySlug("blog"),
  getCompanyInfo("AGE"),
]);
const companyName = company?.legalName ?? "";
const featured = posts.find((p) => p.isFeatured) ?? posts[0];
const rest = posts.filter((p) => p !== featured);

// Extract unique non-null categories, sorted alphabetically
const categories = [...new Set(posts.map((p) => p.category).filter(Boolean) as string[])].sort();
const BLOG_OG_IMAGE = seo?.image1CloudUrlHero ?? seo?.image1CloudUrl ?? (featured ? getPostImage(featured) : undefined);

// F2 FIX: use SITE_BASE directly — no local alias needed
const blogListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: `Blog Articles – ${companyName}`,
  url: `${SITE_BASE}/blog`,
  itemListElement: posts.map((post, index) => ({
    "@type": "ListItem",
    position: index + 1,
    url: `${SITE_BASE}/blog/${post.slug}`,
    name: post.title,
    image: getPostImage(post),
    description: post.excerpt ?? undefined,
  })),
};
---

<BaseLayout
  title={seo?.metaTitle}
  description={seo?.description ?? `Industry insights, technical guides, and manufacturing breakthroughs from ${companyName}.`}
  keywords={seo?.keywords ?? undefined}
  canonical={resolveCanonical(seo?.canonicalUrl)}
  ogType={seo?.ogType ?? "blog"}
  ogImage={BLOG_OG_IMAGE}
  schemaMarkup={[blogListSchema]}
  breadcrumbs={[
    { name: "Home", url: "/" },
    { name: "Blog" },
  ]}
  waMessage="Hi, I read one of your blog articles and would like to know more about your fabrics."
>
  <BlogHero breadcrumbs={[{ name: "Home", href: "/" }, { name: "Blog" }]} categories={categories} />
  <BlogDynamicGrid featured={featured} posts={rest} />
  <BlogNewsletter />
</BaseLayout>
