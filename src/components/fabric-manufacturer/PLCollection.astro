---
import type { ApiProductLocation } from "../../lib/api";
import { getProductsByCollectionId } from "../../lib/api";
import Carousel from "../common/Carousel.astro";

interface Props { data: ApiProductLocation; }
const { data } = Astro.props;
const { product } = data;

// Fetch real collection products (exclude current product)
const collectionProducts = await getProductsByCollectionId(product.collectionId, product.id);

// Build cards from collection products — show up to 6
const cards = collectionProducts
  .filter((p) => p.image1CloudUrl)
  .slice(0, 6)
  .map((p) => ({
    img: p.image1CloudUrlHero ?? p.image1CloudUrl ?? "",
    alt: p.altTextImage1 ?? p.name,
    name: p.productTitle ?? p.name,
    sub: `${p.gsm} GSM • ${p.structure}`,
    href: p.productslug ? `/fabric/${p.productslug}` : "/fabric",
  }));

// Fallback to product's own images if no collection products
if (cards.length === 0) {
  const { collection } = product;
  [
    { img: product.image1CloudUrlHero ?? product.image1CloudUrl ?? "", alt: product.altTextImage1 ?? product.name, name: product.productTitle ?? product.name, sub: `${product.gsm} GSM • ${product.design}`, href: "/fabric" },
    { img: product.image2CloudUrl ?? collection?.collectionImage1CloudUrl ?? "", alt: product.altTextImage2 ?? collection?.altTextCollectionImage1 ?? product.collectionName, name: product.collectionName, sub: `${product.content.join(", ")} • ${product.structure}`, href: "/fabric" },
    { img: product.image3CloudUrl ?? collection?.collectionImage1CloudUrl ?? "", alt: product.altTextImage3 ?? collection?.altTextCollectionImage1 ?? product.collectionName, name: `${product.productTitle ?? product.name} — ${product.color.join(", ")}`, sub: `${product.cm} cm • ${product.salesMOQ} ${product.uM} MOQ`, href: "/fabric" },
  ].filter((c) => c.img).forEach((c) => cards.push(c));
}
---

{cards.length > 0 && (
  <section class="py-12 md:py-24 bg-[#faf9ff]">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
      <div class="flex justify-between items-end mb-8 md:mb-12">
        <div>
          <span class="text-[#385b99] font-label text-sm uppercase tracking-widest mb-2 block">The Series</span>
          <h2 class="text-2xl md:text-4xl font-headline">Explore the {product.collectionName}</h2>
        </div>
      </div>

      <Carousel
        cols={{ mobile: 1, tablet: 1, desktop: 3 }}
        gap="gap-8"
        showArrows={cards.length > 1}
        arrowStyle="outline"
        id="pl-collection"
      >
        {cards.map(({ img, alt, name, sub, href }) => (
          <div class="group">
            <div class="aspect-[3/4] mb-6 overflow-hidden rounded-lg bg-[#f4f3f9]">
              <img
                src={img}
                alt={alt}
                title={name}
                width="600"
                height="800"
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                loading="lazy"
              />
            </div>
            <h4 class="text-xl font-headline mb-1">{name}</h4>
            <p class="text-[#747781] text-sm font-label mb-4">{sub}</p>
            <a href={href} class="text-[#385b99] font-bold text-sm uppercase tracking-widest flex items-center gap-2 group-hover:gap-4 transition-all font-label">
              View Specs
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </a>
          </div>
        ))}
      </Carousel>
    </div>
  </section>
)}
