---
import Breadcrumbs from "../common/Breadcrumbs.astro";

interface Props {
  total: number;
  breadcrumbs?: { name: string; href?: string }[];
}
const { total, breadcrumbs } = Astro.props;
---

<section class="pl-listing-hero relative flex items-start overflow-hidden bg-[#041632] text-white">
  <style>
    .pl-listing-hero {
      min-height: calc(100dvh - 94px);
      height: calc(100dvh - 94px);
    }
    @media (min-width: 768px) {
      .pl-listing-hero { min-height: calc(100dvh - 102px); height: calc(100dvh - 102px); }
    }
  </style>
  <div class="absolute inset-0">
    <img
      class="w-full h-full object-cover opacity-30"
      src="https://res.cloudinary.com/age-fabric/image/upload/v1775652305/17_y6ajol.jpg"
      alt="Fabric supply across India"
      width="1600"
      height="900"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-[#041632] via-[#041632]/85 to-[#041632]/40"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-[#041632]/60 via-transparent to-transparent"></div>
  </div>
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-0 bottom-0 left-[20%] w-px bg-white/5"></div>
    <div class="absolute top-0 bottom-0 left-[40%] w-px bg-white/5"></div>
    <div class="absolute top-0 bottom-0 left-[60%] w-px bg-white/5"></div>
    <div class="absolute top-0 bottom-0 left-[80%] w-px bg-white/5"></div>
  </div>
  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-12 w-full pt-[12px] pb-10 md:pt-[12px] md:pb-16">
    <div class="max-w-3xl">
      {breadcrumbs && breadcrumbs.length > 1 && (
        <div class="mb-6">
          <Breadcrumbs items={breadcrumbs} variant="dark" />
        </div>
      )}
      <span class="inline-block px-4 py-1.5 rounded-full border font-label text-xs uppercase tracking-[0.2em] mb-6 font-bold"
        style="border-color:rgba(232,184,75,0.3); color:var(--color-secondary-light)">
        B2B Fabric Supply · Pan India
      </span>
      <h1 class="font-headline text-5xl md:text-7xl leading-[1.05] tracking-tight mb-6">
        Fabrics &amp; <em class="italic" style="color:var(--color-secondary-light)">Export Solutions</em>
      </h1>
      <p class="font-body text-lg md:text-xl leading-relaxed mb-10 max-w-xl" style="color:var(--color-navy-dim)">
        Precision-sourced fabrics delivered to your city. Every combination is engineered for bulk B2B supply across India's textile hubs.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 mb-14">
        <a href="#grid" class="px-8 py-4 rounded-md font-label font-bold flex items-center justify-center gap-3 transition-all duration-300 shadow-xl"
          style="background:var(--color-secondary); color:var(--color-text-inverse)"
          onclick="window.gtag?.('event','pl_hero_cta_browse_combinations',{page_path:window.location.pathname})">
          Browse All Combinations
          <span class="material-symbols-outlined text-sm">arrow_forward</span>
        </a>
        <a href="/support" class="px-8 py-4 rounded-md font-label font-bold flex items-center justify-center gap-3 transition-all"
          style="background:rgba(255,255,255,0.06); color:var(--color-text-inverse); border:1px solid rgba(255,255,255,0.2)"
          onclick="window.gtag?.('event','pl_hero_cta_request_quote',{page_path:window.location.pathname})">
          Request a Quote
        </a>
      </div>
    </div>
  </div>
</section>

<div class="border-b py-5" style="background:var(--color-surface-soft); border-color:var(--color-border)">
  <div class="max-w-7xl mx-auto px-6 md:px-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 items-center opacity-70 hover:opacity-100 transition-opacity duration-500">
      {[
        { icon: "verified",          label: "ISO 9001:2015" },
        { icon: "workspace_premium", label: "OEKO-TEX Standard" },
        { icon: "local_shipping",    label: "Pan India Delivery" },
        { icon: "support_agent",     label: "Dedicated B2B Support" },
      ].map(({ icon, label }) => (
        <div class="flex items-center justify-center gap-2">
          <span class="material-symbols-outlined text-2xl" style="font-variation-settings:'FILL' 1; color:var(--color-primary)">{icon}</span>
          <span class="font-label text-xs font-bold tracking-tight uppercase" style="color:var(--color-text)">{label}</span>
        </div>
      ))}
    </div>
  </div>
</div>
