---
import type { ApiProduct } from "../../lib/api";

interface Props {
  name: string;
  products: ApiProduct[];
}
const { name, products } = Astro.props;

const trackId = `cg-track-${Math.random().toString(36).slice(2, 7)}`;
---

<section class="py-24 bg-[#faf9ff]">
  <div class="max-w-7xl mx-auto px-6">
    <div class="mb-16 text-center">
      <h2 class="font-headline text-5xl text-[#1a1b20] mb-4">{name} Collection</h2>
      <div class="w-24 h-1 bg-[#755700] mx-auto"></div>
    </div>

    {products.length === 0 ? (
      <p class="text-center text-[#747781] py-12">No products found in this category yet.</p>
    ) : (
      <div class="cg-outer" data-cg-carousel>
        <div class="cg-nav-buttons">
          <button class="cg-nav-btn cg-nav-prev" aria-label="Previous">←</button>
          <button class="cg-nav-btn cg-nav-next" aria-label="Next">→</button>
        </div>

        <div id={trackId} class="cg-track">
          {products.map((p) => (
            <a href={`/fabric/${p.productslug}`} class="cg-card group cursor-pointer">
              <div class="relative aspect-[4/5] overflow-hidden mb-6 bg-[#eeedf3]">
                {p.image1CloudUrlCard || p.image1CloudUrl ? (
                  <img
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                    src={p.image1CloudUrlCard ?? p.image1CloudUrl ?? ""}
                    alt={p.altTextImage1 ?? p.productTitle}
                    loading="lazy"
                  />
                ) : (
                  <div class="w-full h-full bg-[#d1d5db]" />
                )}
                {p.fabricCode && (
                  <div class="absolute top-4 left-4 bg-[#041632] text-white text-[10px] font-label font-bold uppercase tracking-widest px-3 py-1">
                    {p.fabricCode}
                  </div>
                )}
              </div>
              <h3 class="font-headline text-2xl text-[#385b99] group-hover:text-[#755700] transition-colors">
                {p.productTitle || p.name}
              </h3>
              <p class="font-label text-xs text-[#747781] uppercase tracking-widest mt-1 mb-4">
                {p.structure} · {p.content?.join(", ")}
              </p>
              <div class="flex justify-between items-center border-t border-[#c3c6d1]/30 pt-4">
                <span class="text-sm font-semibold text-[#1a1b20]">
                  {p.gsm ? `${p.gsm} GSM` : p.inch ? `${p.inch}"` : ""}
                </span>
                <span class="material-symbols-outlined text-[#385b99] group-hover:translate-x-1 transition-transform">
                  arrow_forward
                </span>
              </div>
            </a>
          ))}
        </div>

        <div class="cg-dots"></div>
      </div>
    )}
  </div>
</section>

<style>
  .cg-outer {
    position: relative;
    padding: 0 2.25rem;
  }
  .cg-track {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    scroll-behavior: smooth;
  }
  .cg-track::-webkit-scrollbar { display: none; }
  .cg-card {
    scroll-snap-align: start;
    flex-shrink: 0;
    width: 260px;
  }
  @media (min-width: 768px) {
    .cg-card { width: 300px; }
  }
  @media (min-width: 1024px) {
    .cg-card { width: 340px; }
  }
  .cg-arrow {
    position: absolute;
    top: 38%;
    transform: translateY(-50%);
    z-index: 10;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    background: #020d1f;
    border: none;
    box-shadow: 0 4px 16px rgba(2,13,31,0.45);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #ffffff;
    transition: background 0.18s, box-shadow 0.18s;
    padding: 0;
  }
  .cg-arrow-prev { left: 0; }
  .cg-arrow-next { right: 0; }
  .cg-arrow:hover {
    background: #775a19;
    box-shadow: 0 6px 20px rgba(119,90,25,0.4);
  }
  .cg-arrow svg { display: block; flex-shrink: 0; }
</style>
