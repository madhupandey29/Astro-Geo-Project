---
import type { ApiProduct } from "../../lib/api";
import CloudinaryImage from "../common/CloudinaryImage.astro";

interface Props {
  name: string;
  products: ApiProduct[];
}
const { name, products } = Astro.props;

const trackId = `cg-track-${Math.random().toString(36).slice(2, 7)}`;
---

<section class="py-24 bg-[#faf9ff]">
  <div class="max-w-7xl mx-auto px-6">
    <div class="mb-16 text-center">
      <h2 class="font-headline text-5xl text-[#1a1b20] mb-4">{name} Collection</h2>
      <div class="w-24 h-1 bg-[#755700] mx-auto"></div>
    </div>

    {products.length === 0 ? (
      <p class="text-center text-[#747781] py-12">No products found in this category yet.</p>
    ) : (
      <div class="cg-outer">
        <button
          class="cg-arrow cg-arrow-prev"
          aria-label="Previous"
          onclick={`(function(){var t=document.getElementById('${trackId}');var c=t.querySelector('.cg-card');var cols=window.innerWidth>=1024?4:window.innerWidth>=640?2:1;t.scrollBy({left:-c.offsetWidth*cols,behavior:'smooth'});})()`}
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
        </button>

        <div id={trackId} class="cg-track">
          {products.map((p) => (
            <a href={`/fabric/${p.productslug}`} class="cg-card group cursor-pointer">
              <div class="relative aspect-[4/5] overflow-hidden mb-6 bg-[#eeedf3]">
                {p.image1CloudUrlCard || p.image1CloudUrl ? (
                  <CloudinaryImage
                    src={p.image1CloudUrlCard ?? p.image1CloudUrl}
                    alt={p.altTextImage1 ?? p.productTitle ?? p.name}
                    width={400}
                    height={500}
                    widths={[200, 400, 600, 800]}
                    sizes="(min-width: 1024px) 25vw, (min-width: 640px) 50vw, 100vw"
                    crop="fill"
                    loading="lazy"
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                  />
                ) : (
                  <div class="w-full h-full bg-[#d1d5db]" />
                )}
                {p.fabricCode && (
                  <div class="absolute top-4 left-4 bg-[#041632] text-white text-[10px] font-label font-bold uppercase tracking-widest px-3 py-1">
                    {p.fabricCode}
                  </div>
                )}
              </div>
              <h3 class="font-headline text-2xl text-[#385b99] group-hover:text-[#755700] transition-colors">
                {p.productTitle || p.name}
              </h3>
              <p class="font-label text-xs text-[#747781] uppercase tracking-widest mt-1 mb-4">
                {p.structure} · {p.content?.join(", ")}
              </p>
              <div class="flex justify-between items-center border-t border-[#c3c6d1]/30 pt-4">
                <span class="text-sm font-semibold text-[#1a1b20]">
                  {p.gsm ? `${p.gsm} GSM` : p.inch ? `${p.inch}"` : ""}
                </span>
                <span class="material-symbols-outlined text-[#385b99] group-hover:translate-x-1 transition-transform">
                  arrow_forward
                </span>
              </div>
            </a>
          ))}
        </div>

        <div class="cg-dots"></div>
        <button
          class="cg-arrow cg-arrow-next"
          aria-label="Next"
          onclick={`(function(){var t=document.getElementById('${trackId}');var c=t.querySelector('.cg-card');var cols=window.innerWidth>=1024?4:window.innerWidth>=640?2:1;t.scrollBy({left:c.offsetWidth*cols,behavior:'smooth'});})()`}
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"/>
          </svg>
        </button>
      </div>
    )}
  </div>
</section>

<style>
  .cg-outer {
    position: relative;
    margin: 0 -1.5rem;
    overflow: hidden;
  }
  @media (min-width: 640px) {
    .cg-outer { margin: 0 -2rem; }
  }
  @media (min-width: 1024px) {
    .cg-outer { margin: 0 3rem; overflow: visible; }
  }
  .cg-track {
    display: flex;
    gap: 0;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    scroll-behavior: smooth;
  }
  .cg-track::-webkit-scrollbar { display: none; }
  @media (min-width: 1024px) {
    .cg-track { overflow: hidden; }
  }
  .cg-card {
    scroll-snap-align: start;
    flex-shrink: 0;
    width: 100%;
    padding: 0 0.5rem;
    box-sizing: border-box;
  }
  @media (min-width: 640px) {
    .cg-card { width: 50%; }
  }
  @media (min-width: 1024px) {
    .cg-card { width: 25%; }
  }
  .cg-arrow {
    position: absolute;
    top: 38%;
    transform: translateY(-50%);
    z-index: 10;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: #020d1f;
    border: none;
    box-shadow: 0 4px 16px rgba(2,13,31,0.45);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #ffffff;
    transition: background 0.18s, box-shadow 0.18s;
    padding: 0;
  }
  .cg-arrow-prev { left: 1rem; }
  .cg-arrow-next { right: 1rem; }
  @media (min-width: 1024px) {
    .cg-arrow-prev { left: -3rem; }
    .cg-arrow-next { right: -3rem; }
  }
  .cg-arrow:hover {
    background: #775a19;
    box-shadow: 0 6px 20px rgba(119,90,25,0.4);
  }
  .cg-arrow svg { display: block; flex-shrink: 0; }
  .cg-dots { display: none; }
</style>

