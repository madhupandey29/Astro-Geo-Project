---
interface Props {
  name: string;
  p1: string | null;
  p2: string | null;
}
const { name, p1, p2 } = Astro.props;
---

{(p1 || p2) && (
  <section class="py-24 bg-[#faf9ff]">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-12 gap-12 items-start">
        <div class="md:col-span-7">
          <h2 class="font-headline text-4xl text-[#385b99] mb-8 leading-tight">
            {name}
          </h2>
          <div class="space-y-6 text-[#434750] text-lg leading-relaxed rich-content">
            {p1 && <div set:html={p1} />}
            {p2 && <div set:html={p2} />}
          </div>
        </div>

        <div class="md:col-span-5 grid grid-cols-2 gap-4">
          <div class="bg-[#f4f3f9] p-8 rounded-lg aspect-square flex flex-col justify-end">
            <span class="text-4xl font-headline text-[#755700] mb-2">B2B</span>
            <span class="font-label text-xs uppercase tracking-widest text-[#747781]">Bulk Supply Ready</span>
          </div>
          <div class="bg-[#385b99] p-8 rounded-lg aspect-square flex flex-col justify-end text-white">
            <span class="text-4xl font-headline mb-2">OEM</span>
            <span class="font-label text-xs uppercase tracking-widest opacity-80">Private Label</span>
          </div>
        </div>
      </div>
    </div>
  </section>
)}
