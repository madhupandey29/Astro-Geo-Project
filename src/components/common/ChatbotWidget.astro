---
const API_BASE   = (import.meta.env.PUBLIC_API_BASE_URL as string | undefined)?.replace(/\/$/, '') ?? '';
const CHAT_URL   = `${API_BASE}/api/chat/message`;
const HEALTH_URL = `${API_BASE}/api/chat/health`;
const COMPANY    = "Amrita Global Enterprise";
const WELCOME    = `Welcome to ${COMPANY}! 👋\nI'm your fabric catalogue assistant. Ask me about fabrics, collections, or anything related to our products. I can also help you get a quote or connect you with our team.`;
---

<!-- ═══════════════════════════════════════════════════════════
     CHATBOT WIDGET
     • FAB button  — bottom-right, appears after scroll (same threshold as FloatingActions)
     • Chat window — slides up from FAB on click, anchored bottom-right
     ═══════════════════════════════════════════════════════════ -->

<!-- FAB — bottom-left, sits ABOVE the call button -->
<button
  id="cb-fab"
  aria-label="Open chat"
  aria-expanded="false"
  class="fixed left-4 z-[201] w-12 h-12 flex items-center justify-center rounded-xl shadow-lg
         bg-[#385b99] hover:scale-105 active:scale-95 transition-transform
         opacity-0 pointer-events-none focus:outline-none focus-visible:ring-2 focus-visible:ring-[#385b99]"
  style="bottom: 74px;"
>
  <svg id="cb-icon-chat" viewBox="0 0 24 24" fill="white" class="w-6 h-6" aria-hidden="true">
    <path d="M21 12.22C21 6.73 16.74 3 12 3c-4.69 0-9 3.65-9 9.28-.6.34-1 .98-1 1.72v2c0 1.1.9 2 2 2h1v-6.1c0-3.87 3.13-7 7-7s7 3.13 7 7V19h-8v2h8c1.1 0 2-.9 2-2v-1.22c.59-.31 1-.92 1-1.64v-2.3c0-.7-.41-1.31-1-1.62z"/>
    <circle cx="9" cy="13" r="1.25"/>
    <circle cx="15" cy="13" r="1.25"/>
  </svg>
  <!-- close icon (when open) -->
  <svg id="cb-icon-close" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"
       stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 hidden" aria-hidden="true">
    <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
  </svg>
  <!-- unread badge -->
  <span id="cb-badge"
    class="hidden absolute -top-1 -right-1 min-w-[18px] h-[18px] px-1
           rounded-full bg-red-500 text-white text-[10px] font-bold
           flex items-center justify-center leading-none"
    aria-live="polite"
  ></span>
</button>

<!-- Chat window — bottom sheet on mobile, popover on desktop -->
<div
  id="cb-window"
  role="dialog"
  aria-label={`${COMPANY} Chat`}
  aria-modal="true"
  class="fixed z-[200] flex flex-col rounded-2xl overflow-hidden
         transition-all duration-300
         scale-95 opacity-0 pointer-events-none"
  style="background:#ffffff;
         box-shadow:0px 32px 64px rgba(0,0,0,0.18);
         border:1px solid rgba(195,198,209,0.2);"
>
  <!-- ── Header ── -->
  <header class="flex justify-between items-center px-5 py-4 flex-shrink-0 bg-white border-b border-[#e8e7ed]">
    <div class="flex items-center gap-3">
      <!-- Logo avatar -->
      <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0 bg-white overflow-hidden border border-[#e8e7ed]">
        <img src="/images/icons/my_logo.webp" alt="Amrita Global Enterprise" class="w-full h-full object-contain p-0.5" />
      </div>
      <div>
        <p class="font-headline font-bold text-lg leading-tight text-[#1a1b20] tracking-tight">{COMPANY}</p>
        <div class="flex items-center gap-1.5 mt-0.5">
          <span id="cb-status-dot" class="w-2 h-2 rounded-full bg-green-400 inline-block"></span>
          <span id="cb-status-text" class="font-label text-[10px] uppercase tracking-wider text-[#747781]">Online</span>
        </div>
      </div>
    </div>
    <div class="flex gap-1">
      <button id="cb-reset" aria-label="Start new conversation" title="New conversation"
              class="p-2 text-[#747781] hover:bg-[#f4f3f9] rounded-full transition-colors">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true">
          <polyline points="1 4 1 10 7 10"/>
          <path d="M3.51 15a9 9 0 1 0 .49-3.5"/>
        </svg>
      </button>
      <button id="cb-close" aria-label="Close chat"
              class="p-2 text-[#747781] hover:bg-[#f4f3f9] rounded-full transition-colors">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
             stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </header>

  <!-- ── Messages ── -->
  <div id="cb-messages"
       role="log" aria-live="polite" aria-label="Chat messages"
       class="flex-1 overflow-y-auto cb-scroll bg-white"
       style="padding:20px 20px 8px; display:flex; flex-direction:column; gap:16px;">
  </div>

  <!-- ── Quick starters ── -->
  <div id="cb-starters"
       class="px-5 pb-3 pt-2 flex flex-wrap gap-2 bg-white flex-shrink-0"
       style="row-gap: 8px; column-gap: 8px;">
  </div>

  <!-- ── Input ── -->
  <footer class="px-5 py-4 bg-white border-t border-[#e8e7ed] flex items-center gap-3 flex-shrink-0">
    <input
      id="cb-input"
      type="text"
      maxlength="1000"
      placeholder="Type your message..."
      aria-label="Message input"
      class="font-body flex-1 bg-white border border-[#c3c6d1] rounded-xl py-3.5 px-5
             text-sm text-[#1a1b20] placeholder:text-[#747781]/60
             focus:outline-none focus:border-[#385b99] focus:ring-0 transition-colors shadow-inner"
    />
    <button
      id="cb-send"
      type="button"
      aria-label="Send message"
      disabled
      class="w-12 h-12 flex-shrink-0 flex items-center justify-center rounded-xl
             bg-[#385b99] text-white transition-all active:scale-95
             disabled:opacity-40 disabled:cursor-not-allowed hover:bg-[#1f4682]"
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"
           stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </button>
  </footer>
</div>

<!-- Mobile backdrop -->
<div id="cb-backdrop"
     class="fixed inset-0 z-[199] bg-black/40 hidden"
     aria-hidden="true">
</div>

<!-- ── Scrollbar style (can't do ::-webkit-scrollbar in Tailwind without a plugin) ── -->
<style is:global>
  .cb-scroll::-webkit-scrollbar        { width: 4px; }
  .cb-scroll::-webkit-scrollbar-track  { background: transparent; }
  .cb-scroll::-webkit-scrollbar-thumb  { background: #c3c6d1; border-radius: 10px; }
  #cb-messages { scrollbar-width: thin; scrollbar-color: #c3c6d1 transparent; }

  @keyframes cb-bounce {
    0%,80%,100% { transform:translateY(0);   opacity:.4; }
    40%          { transform:translateY(-5px); opacity:1;  }
  }
  .cb-dot {
    display:inline-block; width:6px; height:6px; border-radius:50%;
    background: #385b99;
    animation:cb-bounce 1.2s infinite ease-in-out;
  }
  .cb-dot:nth-child(2) { animation-delay:.2s; }
  .cb-dot:nth-child(3) { animation-delay:.4s; }

  /* Markdown inside bot bubbles */
  .cb-md { font-family: "Inter Variable", Inter, sans-serif; font-weight: 400; font-size: 14px; }
  .cb-md p           { margin:0 0 .35em; font-weight: 400; }
  .cb-md p:last-child { margin-bottom:0; }
  .cb-md ul, .cb-md ol { margin:.25em 0 .35em 1.1em; padding:0; }
  .cb-md li          { margin-bottom:.15em; }
  .cb-md h4, .cb-md h5, .cb-md h6 { font-weight:600; margin:.4em 0 .2em; }
  .cb-md code        { background: #f0eff5; color: #385b99; padding:.1em .3em; border-radius:3px; font-size:.85em; }
  .cb-md a           { color: #385b99; text-decoration:underline; }
  .cb-md hr          { border:none; border-top:1px solid #c3c6d1; margin:.5em 0; }
  .cb-md strong      { font-weight:600; }
  .cb-md em          { font-style:italic; }

  /* Quick-starter chips */
  .cb-chip {
    font-family: "Inter Variable", Inter, sans-serif;
    font-size: .75rem;
    font-weight: 400;
    padding: .3rem .75rem;
    border-radius: .75rem;
    border: 1px solid #c3c6d1;
    color: #385b99;
    background: #ffffff;
    cursor: pointer;
    transition: background .15s, border-color .15s;
    white-space: nowrap;
    display: inline-block;
    line-height: 1.5;
  }
  .cb-chip:hover { background: #f4f3f9; border-color: #385b99; }

  /* Mobile bottom sheet safe area */
  @media (max-width: 639px) {
    #cb-window footer {
      padding-bottom: max(1rem, env(safe-area-inset-bottom, 1rem));
    }
  }
</style>

<script define:vars={{ CHAT_URL, HEALTH_URL, WELCOME, COMPANY }}>
/* ─────────────────────────────────────────────────────────────
   CHATBOT WIDGET — vanilla JS port of the React chatbot logic
   ───────────────────────────────────────────────────────────── */

const LS_KEY = 'age_chat_v2';

const QUICK_STARTERS = [
  'Show me your fabric catalogue',
  'I need cotton fabric',
  'Get a quote',
  'Tell me about Amrita Global',
];

/* ── Time helper ── */
function fmtTime(d) {
  return d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
}

/* ── localStorage helpers ── */
function loadStore() {
  try { return JSON.parse(localStorage.getItem(LS_KEY) || 'null'); } catch { return null; }
}
function saveStore(data) {
  try { localStorage.setItem(LS_KEY, JSON.stringify(data)); } catch {}
}
function clearStore() {
  try { localStorage.removeItem(LS_KEY); } catch {}
}

/* ── Welcome message ── */
const WELCOME_MSG = {
  id: 'welcome',
  role: 'bot',
  text: WELCOME,
  time: fmtTime(new Date()),
  suggestions: [],
  links: [],
};

/* ── Init store (reuse session across refreshes) ── */
function initStore() {
  const ex = loadStore();
  if (ex?.sessionId) {
    return {
      sessionId: ex.sessionId,
      context:   ex.context   || {},
      messages:  Array.isArray(ex.messages) && ex.messages.length ? ex.messages : [WELCOME_MSG],
    };
  }
  const sessionId = `sess_${Date.now()}_${Math.random().toString(36).slice(2, 9)}`;
  const store = { sessionId, context: {}, messages: [WELCOME_MSG] };
  saveStore(store);
  return store;
}

/* ── Markdown → HTML string ── */
function renderMarkdown(text) {
  if (!text) return '';
  const esc = s => s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  const inline = str => str
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g,     '<em>$1</em>')
    .replace(/`([^`]+)`/g,     '<code>$1</code>')
    .replace(/\[([^\]]+)\]\((https?:\/\/[^)]+)\)/g,
             '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>');

  const lines = text.split('\n');
  let html = '', i = 0;
  while (i < lines.length) {
    const line = lines[i];
    if (/^---+$/.test(line.trim())) { html += '<hr>'; i++; continue; }
    const hm = line.match(/^(#{1,3})\s+(.+)/);
    if (hm) {
      const lv = hm[1].length + 2;
      html += `<h${lv}>${inline(esc(hm[2]))}</h${lv}>`;
      i++; continue;
    }
    if (/^[-•]\s/.test(line)) {
      html += '<ul>';
      while (i < lines.length && /^[-•]\s/.test(lines[i]))
        html += `<li>${inline(esc(lines[i++].replace(/^[-•]\s/, '')))}</li>`;
      html += '</ul>'; continue;
    }
    if (/^\d+\.\s/.test(line)) {
      html += '<ol>';
      while (i < lines.length && /^\d+\.\s/.test(lines[i]))
        html += `<li>${inline(esc(lines[i++].replace(/^\d+\.\s/, '')))}</li>`;
      html += '</ol>'; continue;
    }
    if (line.trim() === '') { html += '<div style="height:.35em"></div>'; i++; continue; }
    html += `<p>${inline(esc(line))}</p>`;
    i++;
  }
  return html;
}

/* ── DOM refs ── */
const fab        = document.getElementById('cb-fab');
const win        = document.getElementById('cb-window');
const msgList    = document.getElementById('cb-messages');
const starters   = document.getElementById('cb-starters');
const inputEl    = document.getElementById('cb-input');
const sendBtn    = document.getElementById('cb-send');
const closeBtn   = document.getElementById('cb-close');
const resetBtn   = document.getElementById('cb-reset');
const backdrop   = document.getElementById('cb-backdrop');
const badge      = document.getElementById('cb-badge');
const iconChat   = document.getElementById('cb-icon-chat');
const iconClose  = document.getElementById('cb-icon-close');
const statusDot  = document.getElementById('cb-status-dot');
const statusText = document.getElementById('cb-status-text');

/* ── State ── */
let store        = initStore();
let msgs         = store.messages;
let ctx          = store.context;
let sessionId    = store.sessionId;
let isOpen       = false;
let isLoading    = false;
let unread       = 0;
let showStarters = msgs.length <= 1;

/* ── Persist ── */
function persist() {
  saveStore({ sessionId, context: ctx, messages: msgs });
}

/* ── Build a single message row (DOM node) ── */
function makeBubble(msg) {
  const isBot = msg.role === 'bot';

  /* container — timestamp above, then bubble row */
  const container = document.createElement('div');
  container.style.cssText = 'display:flex; flex-direction:column; gap:5px;';

  /* timestamp ABOVE bubble — "ASSISTANT • 09:41 AM" style */
  const time = document.createElement('div');
  time.style.cssText = `font-family:"Inter Variable",Inter,sans-serif; font-size:10px; color:#747781; text-transform:uppercase; letter-spacing:0.08em; font-weight:500; ${isBot ? 'padding-left:42px;' : 'text-align:right; padding-right:42px;'}`;
  time.textContent = `${isBot ? 'ASSISTANT' : 'YOU'} • ${msg.time}`;

  /* bubble row */
  const row = document.createElement('div');
  row.style.cssText = `display:flex; align-items:flex-end; gap:10px; ${isBot ? '' : 'flex-direction:row-reverse;'}`;

  /* avatar — 32px solid blue circle */
  const av = document.createElement('div');
  av.setAttribute('aria-hidden', 'true');
  av.style.cssText = 'flex-shrink:0; width:32px; height:32px; border-radius:50%; display:flex; align-items:center; justify-content:center; background:#385b99;';
  if (isBot) {
    av.innerHTML = `<svg viewBox="0 0 24 24" fill="white" style="width:16px;height:16px;">
      <path d="M21 12.22C21 6.73 16.74 3 12 3c-4.69 0-9 3.65-9 9.28-.6.34-1 .98-1 1.72v2c0 1.1.9 2 2 2h1v-6.1c0-3.87 3.13-7 7-7s7 3.13 7 7V19h-8v2h8c1.1 0 2-.9 2-2v-1.22c.59-.31 1-.92 1-1.64v-2.3c0-.7-.41-1.31-1-1.62z"/>
      <circle cx="9" cy="13" r="1.25"/><circle cx="15" cy="13" r="1.25"/>
    </svg>`;
  } else {
    av.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"
      stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;">
      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
      <circle cx="12" cy="7" r="4"/>
    </svg>`;
  }

  /* bubble — Newsreader font, matches reference */
  const bubble = document.createElement('div');
  if (isBot) {
    bubble.style.cssText = 'max-width:80%; background:#eeedf3; border:1px solid rgba(195,198,209,0.15); border-radius:0 12px 12px 12px; padding:12px 14px; color:#1a1b20; font-family:"Inter Variable",Inter,sans-serif; font-size:14px; font-weight:400; line-height:1.6;';
  } else {
    bubble.style.cssText = 'max-width:80%; background:#385b99; border-radius:12px 0 12px 12px; padding:12px 14px; color:white; font-family:"Inter Variable",Inter,sans-serif; font-size:14px; font-weight:400; line-height:1.6; box-shadow:0 2px 8px rgba(56,91,153,0.25);';
  }

  if (isBot) {
    const md = document.createElement('div');
    md.className = 'cb-md';
    md.innerHTML = renderMarkdown(msg.text);
    bubble.appendChild(md);

    /* suggestion chips */
    if (msg.suggestions?.length) {
      const chips = document.createElement('div');
      chips.style.cssText = 'display:flex;flex-wrap:wrap;gap:6px;margin-top:10px;';
      msg.suggestions.forEach(s => {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'cb-chip';
        btn.textContent = s.fabricCode || s.label;
        btn.addEventListener('click', () => {
          if (s.url) window.open(s.url, '_blank', 'noopener');
          else sendMessage(`Tell me more about ${s.label || s.fabricCode}`);
        });
        chips.appendChild(btn);
      });
      bubble.appendChild(chips);
    }

    /* link pills */
    if (msg.links?.length) {
      const linksDiv = document.createElement('div');
      linksDiv.style.cssText = 'display:flex;flex-direction:column;gap:6px;margin-top:10px;';
      msg.links.forEach(l => {
        const a = document.createElement('a');
        a.href = l.url; a.target = '_blank'; a.rel = 'noopener noreferrer';
        a.style.cssText = 'display:flex;align-items:center;gap:8px;padding:8px 10px;background:white;border-radius:8px;border:1px solid #e2e8f0;font-family:"Inter Variable",Inter,sans-serif;font-size:12px;color:#385b99;text-decoration:none;';
        a.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="#755700" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round" style="width:16px;height:16px;flex-shrink:0;">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
        </svg><span>${l.label}</span>`;
        linksDiv.appendChild(a);
      });
      bubble.appendChild(linksDiv);
    }
  } else {
    const p = document.createElement('p');
    p.style.margin = '0';
    p.textContent = msg.text;
    bubble.appendChild(p);
  }

  row.appendChild(av);
  row.appendChild(bubble);
  container.appendChild(time);
  container.appendChild(row);
  return container;
}

/* ── Typing indicator ── */
function makeTyping() {
  const row = document.createElement('div');
  row.id = 'cb-typing';
  row.style.cssText = 'display:flex; gap:10px; align-items:flex-end;';

  const av = document.createElement('div');
  av.setAttribute('aria-hidden', 'true');
  av.style.cssText = 'flex-shrink:0; width:32px; height:32px; border-radius:50%; display:flex; align-items:center; justify-content:center; background:#385b99;';
  av.innerHTML = `<svg viewBox="0 0 24 24" fill="white" style="width:16px;height:16px;">
    <path d="M21 12.22C21 6.73 16.74 3 12 3c-4.69 0-9 3.65-9 9.28-.6.34-1 .98-1 1.72v2c0 1.1.9 2 2 2h1v-6.1c0-3.87 3.13-7 7-7s7 3.13 7 7V19h-8v2h8c1.1 0 2-.9 2-2v-1.22c.59-.31 1-.92 1-1.64v-2.3c0-.7-.41-1.31-1-1.62z"/>
    <circle cx="9" cy="13" r="1.25"/><circle cx="15" cy="13" r="1.25"/>
  </svg>`;

  const bubble = document.createElement('div');
  bubble.style.cssText = 'background:#eeedf3; border:1px solid rgba(195,198,209,0.15); border-radius:0 12px 12px 12px; padding:12px 14px; display:flex; align-items:center; gap:5px;';
  bubble.innerHTML = '<span class="cb-dot"></span><span class="cb-dot"></span><span class="cb-dot"></span>';

  row.appendChild(av);
  row.appendChild(bubble);
  return row;
}

function scrollBottom() {
  msgList.scrollTop = msgList.scrollHeight;
}

/* ── Render all messages from state ── */
function renderAll() {
  msgList.innerHTML = '';
  msgs.forEach(m => msgList.appendChild(makeBubble(m)));
  scrollBottom();
}

/* ── Render quick-starter chips ── */
function renderStarters() {
  starters.innerHTML = '';
  if (!showStarters) return;
  QUICK_STARTERS.forEach(q => {
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'cb-chip';
    btn.textContent = q;
    btn.addEventListener('click', () => sendMessage(q));
    starters.appendChild(btn);
  });
}

/* ── Open / close ── */
function isMobile() {
  return window.innerWidth < 640;
}

function applyWindowPosition() {
  if (isMobile()) {
    // Bottom sheet — full width, anchored to bottom
    win.style.left         = '0';
    win.style.right        = '0';
    win.style.bottom       = '0';
    win.style.top          = 'auto';
    win.style.width        = '100%';
    win.style.maxHeight    = '85dvh';
    win.style.borderRadius = '20px 20px 0 0';
  } else {
    // Desktop popover — right of FAB
    win.style.left         = '76px';
    win.style.right        = '';
    win.style.bottom       = '16px';
    win.style.top          = 'auto';
    win.style.width        = '380px';
    win.style.maxHeight    = '620px';
    win.style.borderRadius = '16px';
  }
}

function openChat() {
  isOpen = true;
  unread = 0;
  badge.classList.add('hidden');
  badge.textContent = '';
  fab.setAttribute('aria-expanded', 'true');
  fab.setAttribute('aria-label', 'Close chat');
  iconChat.classList.add('hidden');
  iconClose.classList.remove('hidden');
  applyWindowPosition();
  win.style.transform   = 'scale(1)';
  win.style.opacity     = '1';
  win.style.pointerEvents = 'auto';
  backdrop.classList.remove('hidden');
  // Prevent body scroll on mobile when chat is open
  if (isMobile()) document.body.style.overflow = 'hidden';
  renderAll();
  renderStarters();
  setTimeout(() => inputEl.focus(), 100);
}

function closeChat() {
  isOpen = false;
  fab.setAttribute('aria-expanded', 'false');
  fab.setAttribute('aria-label', 'Open chat');
  iconChat.classList.remove('hidden');
  iconClose.classList.add('hidden');
  win.style.transform     = isMobile() ? 'translateY(100%)' : 'scale(0.95)';
  win.style.opacity       = '0';
  win.style.pointerEvents = 'none';
  backdrop.classList.add('hidden');
  document.body.style.overflow = '';
}

fab.addEventListener('click', () => isOpen ? closeChat() : openChat());
closeBtn.addEventListener('click', closeChat);
backdrop.addEventListener('click', closeChat);

/* ── Reset ── */
resetBtn.addEventListener('click', () => {
  clearStore();
  sessionId = `sess_${Date.now()}_${Math.random().toString(36).slice(2, 9)}`;
  ctx = {};
  msgs = [{ ...WELCOME_MSG, id: 'welcome', time: fmtTime(new Date()) }];
  showStarters = true;
  unread = 0;
  badge.classList.add('hidden');
  badge.textContent = '';
  persist();
  renderAll();
  renderStarters();
});

/* ── Send message ── */
async function sendMessage(text) {
  const trimmed = text.trim();
  if (!trimmed || isLoading) return;

  showStarters = false;
  renderStarters();
  inputEl.value = '';
  sendBtn.disabled = true;

  const userMsg = {
    id:          `u_${Date.now()}`,
    role:        'user',
    text:        trimmed,
    time:        fmtTime(new Date()),
    suggestions: [],
    links:       [],
  };
  msgs.push(userMsg);
  msgList.appendChild(makeBubble(userMsg));
  scrollBottom();

  isLoading = true;
  const typingEl = makeTyping();
  msgList.appendChild(typingEl);
  scrollBottom();

  try {
    const res  = await fetch(CHAT_URL, {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({
        message:      trimmed,
        context:      ctx,
        sessionId,
        cPageUrl:     window.location.href,
        cUserAgent:   navigator.userAgent,
      }),
    });
    const data = await res.json();
    if (!res.ok || !data.ok) throw new Error(data.error || 'Server error');

    if (data.context) ctx = data.context;

    const chips = (data.suggestions  || []).filter(s => s.fabricCode || s.label);
    const links = (data.suggestionsV2 || [])
      .filter(s => s.url)
      .slice(0, 4)
      .map(s => ({ url: s.url, label: s.label || s.entity }));

    const botMsg = {
      id:          `b_${Date.now()}`,
      role:        'bot',
      text:        data.replyText || "I'm here to help!",
      time:        fmtTime(new Date()),
      suggestions: chips,
      links,
    };
    msgs.push(botMsg);
    typingEl.remove();
    msgList.appendChild(makeBubble(botMsg));
    scrollBottom();

    if (!isOpen) {
      unread++;
      badge.textContent = String(unread);
      badge.classList.remove('hidden');
    }
  } catch (err) {
    const errMsg = {
      id:          `e_${Date.now()}`,
      role:        'bot',
      text:        `Sorry, I couldn't reach the server right now. Please try again in a moment. (${err.message})`,
      time:        fmtTime(new Date()),
      suggestions: [],
      links:       [],
    };
    msgs.push(errMsg);
    typingEl.remove();
    msgList.appendChild(makeBubble(errMsg));
    scrollBottom();
  } finally {
    isLoading = false;
    persist();
    setTimeout(() => inputEl.focus(), 50);
  }
}

/* ── Form submit & keyboard ── */
sendBtn.addEventListener('click', () => sendMessage(inputEl.value));

inputEl.addEventListener('keydown', e => {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendMessage(inputEl.value);
  }
});

inputEl.addEventListener('input', () => {
  sendBtn.disabled = isLoading || !inputEl.value.trim();
});

/* ── Health check ── */
if (HEALTH_URL) {
  fetch(HEALTH_URL)
    .then(r => {
      statusDot.style.background  = r.ok ? '#86efac' : '#fca5a5';
      statusText.textContent      = r.ok ? 'Online'  : 'Offline';
    })
    .catch(() => {
      statusDot.style.background = '#fca5a5';
      statusText.textContent     = 'Offline';
    });
}

/* ── FAB visibility — same scroll threshold as FloatingActions ── */
const SCROLL_THRESHOLD = window.innerHeight * 0.8;

function updateFabVisibility() {
  const visible = window.scrollY > SCROLL_THRESHOLD;
  fab.style.opacity       = visible ? '1' : '0';
  fab.style.pointerEvents = visible ? 'auto' : 'none';
  fab.style.transition    = 'opacity 0.3s';

  // Keep chat window hidden when FAB is hidden
  if (!visible && isOpen) closeChat();
}

window.addEventListener('scroll', updateFabVisibility, { passive: true });
window.addEventListener('resize', () => {
  if (isOpen) applyWindowPosition();
});
applyWindowPosition();
updateFabVisibility();
</script>