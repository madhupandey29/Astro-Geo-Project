---
/**
 * Reusable Cloudinary responsive image component.
 * Strips any existing transforms from the source URL and rebuilds
 * a proper srcset with width descriptors + correct crop/ratio per slot.
 *
 * Usage:
 *   <CloudinaryImage
 *     src={cloudinaryUrl}
 *     alt="description"
 *     width={400} height={533}
 *     sizes="(min-width: 1024px) 25vw, (min-width: 640px) 50vw, 100vw"
 *     widths={[200, 400, 800]}
 *     crop="fill"
 *   />
 */
import { rebuildCloudinaryUrl } from "../../data/products";

interface Props {
  src: string | null | undefined;
  alt: string;
  width: number;
  height: number;
  sizes: string;
  /** Width breakpoints for srcset. Defaults to [320, 480, 640, 800] */
  widths?: number[];
  /** Cloudinary crop mode. "fill" for cards, "limit" for hero/editorial */
  crop?: "fill" | "limit";
  /** Cloudinary gravity. "auto" works for most content images */
  gravity?: string;
  loading?: "lazy" | "eager";
  fetchpriority?: "high" | "low" | "auto";
  class?: string;
  title?: string;
}

const {
  src,
  alt,
  width,
  height,
  sizes,
  widths = [320, 480, 640, 800],
  crop = "fill",
  gravity = "auto",
  loading = "lazy",
  fetchpriority,
  class: className,
  title,
} = Astro.props;

function buildUrl(sourceUrl: string, w: number): string {
  const h = Math.round((w * height) / width);
  const t =
    crop === "limit"
      ? `f_auto,q_auto,c_limit,w_${w}`
      : `f_auto,q_auto,c_fill,g_${gravity},w_${w},h_${h}`;
  return rebuildCloudinaryUrl(sourceUrl, t);
}

const safeSrc = src ?? "";
// Use the second width as the fallback src (not the smallest, not the largest)
const fallbackWidth = widths[Math.min(1, widths.length - 1)];
const fallback = safeSrc ? buildUrl(safeSrc, fallbackWidth) : safeSrc;
const srcset = safeSrc
  ? widths.map((w) => `${buildUrl(safeSrc, w)} ${w}w`).join(", ")
  : undefined;
---

<img
  src={fallback || safeSrc}
  srcset={srcset}
  sizes={sizes}
  width={width}
  height={height}
  alt={alt}
  title={title}
  loading={loading}
  fetchpriority={fetchpriority}
  class={className}
  decoding={loading === "eager" ? "sync" : "async"}
/>
