---
/**
 * Reusable Cloudinary responsive image component.
 * Strips any existing transforms from the source URL and rebuilds
 * a proper srcset with width descriptors + correct crop/ratio per slot.
 *
 * Usage:
 *   <CloudinaryImage
 *     src={cloudinaryUrl}
 *     alt="description"
 *     width={400} height={533}
 *     sizes="(min-width: 1024px) 25vw, (min-width: 640px) 50vw, 100vw"
 *     widths={[200, 400, 800]}
 *     crop="fill"
 *   />
 */
import {
  buildCloudinarySrcset,
  buildCloudinaryUrl,
  isCloudinaryUrl,
} from "../../lib/utils/cloudinary";

interface Props {
  src: string | null | undefined;
  alt: string;
  width: number;
  height: number;
  sizes: string;
  /** Width breakpoints for srcset. Defaults to [320, 480, 640, 800] */
  widths?: number[];
  /** Cloudinary crop mode. "fill" for cards, "limit" for hero/editorial */
  crop?: "fill" | "limit";
  /** Cloudinary gravity. "auto" works for most content images */
  gravity?: string;
  loading?: "lazy" | "eager";
  fetchpriority?: "high" | "low" | "auto";
  class?: string;
  title?: string;
  decoding?: "sync" | "async" | "auto";
  /** Use explicit AVIF/WebP sources. Defaults to "picture" for lazy images, "auto" for eager images. */
  formatStrategy?: "auto" | "picture";
}

const {
  src,
  alt,
  width,
  height,
  sizes,
  widths = [320, 480, 640, 800],
  crop = "fill",
  gravity = "auto",
  loading = "lazy",
  fetchpriority,
  class: className,
  title,
  decoding,
  formatStrategy = loading === "lazy" ? "picture" : "auto",
} = Astro.props;

const safeSrc = src ?? "";
const isCloudinary = isCloudinaryUrl(safeSrc);

// Pick a fallback close to the intended slot width (better than "always 2nd entry")
const fallbackWidth =
  widths.find((w) => w >= width) ?? widths[Math.max(0, widths.length - 1)];
const transformOptions = {
  aspectWidth: width,
  aspectHeight: height,
  crop,
  gravity,
  quality: "q_auto",
};
const fallback = safeSrc && isCloudinary
  ? buildCloudinaryUrl(safeSrc, { ...transformOptions, width: fallbackWidth, format: "f_auto" })
  : safeSrc;
const fallbackSrcset = safeSrc && isCloudinary
  ? buildCloudinarySrcset(safeSrc, widths, { ...transformOptions, format: "f_auto" })
  : undefined;
const avifSrcset = safeSrc && isCloudinary && formatStrategy === "picture"
  ? buildCloudinarySrcset(safeSrc, widths, { ...transformOptions, format: "f_avif" })
  : undefined;
const webpSrcset = safeSrc && isCloudinary && formatStrategy === "picture"
  ? buildCloudinarySrcset(safeSrc, widths, { ...transformOptions, format: "f_webp" })
  : undefined;
const resolvedDecoding = decoding ?? (loading === "eager" ? "sync" : "async");
---

{formatStrategy === "picture" && isCloudinary ? (
  <picture>
    {avifSrcset && <source type="image/avif" srcset={avifSrcset} sizes={sizes} />}
    {webpSrcset && <source type="image/webp" srcset={webpSrcset} sizes={sizes} />}
    <img
      src={fallback || safeSrc}
      srcset={fallbackSrcset}
      sizes={sizes}
      width={width}
      height={height}
      alt={alt}
      title={title}
      loading={loading}
      fetchpriority={fetchpriority}
      class={className}
      decoding={resolvedDecoding}
    />
  </picture>
) : (
  <img
    src={fallback || safeSrc}
    srcset={fallbackSrcset}
    sizes={sizes}
    width={width}
    height={height}
    alt={alt}
    title={title}
    loading={loading}
    fetchpriority={fetchpriority}
    class={className}
    decoding={resolvedDecoding}
  />
)}
