---
/**
 * MultiStepContactForm — reusable multi-step form shell.
 *
 * Props
 * ─────
 * formId          unique id prefix so multiple instances on a page don't clash
 * variant         "page" (default) | "modal" — modal skips section/padding wrapper
 * sectionIcon     material-symbol name shown above the heading (optional, page only)
 * badge           small label above the heading
 * heading         main heading text
 * subheading      paragraph below the heading
 * steps           array of { label: string } — drives the stepper dots
 * submitLabel     text on the final submit button
 * successTitle    heading shown after success
 * successMessage  body text shown after success
 */

interface Step { label: string }

interface Props {
  formId?: string;
  variant?: "page" | "modal";
  sectionIcon?: string;
  badge?: string;
  heading?: string;
  subheading?: string;
  steps?: Step[];
  submitLabel?: string;
  successTitle?: string;
  successMessage?: string;
}

const {
  formId      = "msf",
  variant     = "page",
  sectionIcon,
  badge       = "Contact Us",
  heading     = "Get in Touch",
  subheading  = "Fill out the form below and we'll get back to you shortly.",
  steps       = [{ label: "Step 1" }, { label: "Step 2" }, { label: "Step 3" }],
  submitLabel = "Submit",
  successTitle   = "Submitted",
  successMessage = "Thank you. We'll be in touch shortly.",
} = Astro.props;

const isModal = variant === "modal";
---

{isModal ? (
  <!-- Modal variant: bare inner content, no section wrapper -->
  <div class="msf-modal-inner">
    <!-- Stepper -->
    <div class="flex items-center justify-center gap-0 mb-2" id={`${formId}-stepper`}>
      <div class="h-px w-16 bg-[#d1d5db]"></div>
      {steps.map((step, i) => (
        <>
          <div
            id={`${formId}-dot-${i}`}
            class={`w-9 h-9 rounded-full flex items-center justify-center text-sm font-sans font-semibold z-10 transition-all duration-300 ${i === 0 ? "bg-[#041632] text-white" : "border-2 border-[#d1d5db] text-[#9ca3af]"}`}
            title={step.label}
          >{i + 1}</div>
          {i < steps.length - 1 && (
            <div id={`${formId}-line-${i}`} class="h-px w-16 bg-[#d1d5db] transition-colors duration-300"></div>
          )}
        </>
      ))}
      <div class="h-px w-16 bg-[#d1d5db]"></div>
    </div>
    <p id={`${formId}-step-label`} class="text-center font-sans text-xs tracking-widest uppercase text-[#5a6a85] mb-6">
      {steps[0]?.label ?? `Step 1 of ${steps.length}`}
    </p>

    <form id={formId} novalidate>
      <input type="text" name="_hp" class="hidden" tabindex="-1" autocomplete="off" />
      <slot />
      <div id={`${formId}-success`} class="hidden text-center py-8 space-y-4">
        <span class="material-symbols-outlined text-5xl text-[#775a19]" style="font-variation-settings: 'FILL' 1;">check_circle</span>
        <h3 class="font-serif text-2xl text-[#041632] italic">{successTitle}</h3>
        <p class="text-sm text-[#44474d]">{successMessage}</p>
      </div>
      <div id={`${formId}-error`} class="hidden px-4 py-3 bg-red-50 border border-red-200 text-red-800 text-sm mt-4"></div>
    </form>
  </div>
) : (
  <!-- Page variant: full section wrapper -->
  <section class="py-12 md:py-28 px-4 sm:px-6 md:px-8 bg-[#f3f4f5]">
    <div class="max-w-2xl mx-auto">
      <div class="text-center mb-8 md:mb-10">
        {sectionIcon && (
          <span class="material-symbols-outlined text-4xl text-[#775a19] mb-4 block" style="font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;">{sectionIcon}</span>
        )}
        <span class="inline-block px-4 py-1 mb-5 border border-[#775a19] text-[#775a19] font-sans text-xs tracking-[0.2em] uppercase">{badge}</span>
        <h2 class="font-serif text-2xl md:text-4xl text-[#041632] mb-3 leading-tight italic">{heading}</h2>
        <p class="text-[#5a6a85] text-sm px-2">{subheading}</p>
      </div>

      <div class="bg-white border border-[#e1e3e4] p-5 sm:p-8 md:p-12">
        <div class="flex items-center justify-center gap-0 mb-2" id={`${formId}-stepper`}>
          <div class="h-px w-8 sm:w-16 bg-[#d1d5db]"></div>
          {steps.map((step, i) => (
            <>
              <div
                id={`${formId}-dot-${i}`}
                class={`w-8 h-8 sm:w-9 sm:h-9 rounded-full flex items-center justify-center text-sm font-sans font-semibold z-10 transition-all duration-300 ${i === 0 ? "bg-[#041632] text-white" : "border-2 border-[#d1d5db] text-[#9ca3af]"}`}
                title={step.label}
              >{i + 1}</div>
              {i < steps.length - 1 && (
                <div id={`${formId}-line-${i}`} class="h-px w-8 sm:w-16 bg-[#d1d5db] transition-colors duration-300"></div>
              )}
            </>
          ))}
          <div class="h-px w-8 sm:w-16 bg-[#d1d5db]"></div>
        </div>
        <p id={`${formId}-step-label`} class="text-center font-sans text-xs tracking-widest uppercase text-[#5a6a85] mb-6 md:mb-8">
          {steps[0]?.label ?? `Step 1 of ${steps.length}`}
        </p>

        <form id={formId} novalidate>
          <input type="text" name="_hp" class="hidden" tabindex="-1" autocomplete="off" />
          <slot />
          <div id={`${formId}-success`} class="hidden text-center py-8 space-y-4">
            <span class="material-symbols-outlined text-5xl text-[#775a19]" style="font-variation-settings: 'FILL' 1;">check_circle</span>
            <h3 class="font-serif text-2xl text-[#041632] italic">{successTitle}</h3>
            <p class="text-sm text-[#44474d]">{successMessage}</p>
          </div>
          <div id={`${formId}-error`} class="hidden px-4 py-3 bg-red-50 border border-red-200 text-red-800 text-sm mt-4"></div>
        </form>
      </div>
    </div>
  </section>
)}

<style>
  :global(.msf-label) {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #041632;
    margin-bottom: 0.5rem;
  }
  :global(.msf-input) {
    width: 100%;
    border: 1px solid #d1d5db;
    padding: 0.75rem 1rem;
    font-size: 1rem; /* 16px prevents iOS zoom on focus */
    color: #041632;
    background: #f3f4f5;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  @media (min-width: 640px) {
    :global(.msf-input) { font-size: 0.875rem; }
  }
  :global(.msf-input:focus) {
    border-color: #775a19;
    box-shadow: 0 0 0 1px #775a19;
    background: white;
  }
  :global(.msf-btn-primary) {
    background: #041632;
    color: white;
    padding: 0.875rem 1.5rem;
    font-size: 0.75rem;
    font-family: var(--font-sans, sans-serif);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: 100%;
  }
  @media (min-width: 480px) {
    :global(.msf-btn-primary) { width: auto; padding: 0.875rem 2rem; }
  }
  :global(.msf-btn-primary:hover) { background: #775a19; }
  :global(.msf-btn-primary:disabled) { opacity: 0.5; cursor: not-allowed; }
  :global(.msf-btn-secondary) {
    background: white;
    color: #041632;
    padding: 0.875rem 1.5rem;
    font-size: 0.75rem;
    font-family: var(--font-sans, sans-serif);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: 1px solid #d1d5db;
    cursor: pointer;
    transition: border-color 0.2s;
    width: 100%;
  }
  @media (min-width: 480px) {
    :global(.msf-btn-secondary) { width: auto; padding: 0.875rem 2rem; }
  }
  :global(.msf-btn-secondary:hover) { border-color: #041632; }
  :global(.msf-nav-row) {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-top: 0.5rem;
  }
  @media (min-width: 480px) {
    :global(.msf-nav-row) { flex-direction: row; justify-content: space-between; }
    :global(.msf-nav-row.end) { justify-content: flex-end; }
  }
</style>
