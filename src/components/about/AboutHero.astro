---
import Breadcrumbs from "../common/Breadcrumbs.astro";
import { getCompanyInfo } from "../../lib/api";

interface Props {
  image?: string | null;
  breadcrumbs?: { name: string; href?: string }[];
}
const { image, breadcrumbs } = Astro.props;
const company = await getCompanyInfo("AGE");
const companyName = company?.legalName ?? "";

function buildHeroUrl(
  url: string,
  width: number,
  format: "f_auto" | "f_avif" | "f_webp" = "f_auto",
  quality: string = "q_auto:eco"
): string {
  if (!url.includes("res.cloudinary.com")) return url;
  const uploadIdx = url.indexOf("/upload/");
  if (uploadIdx === -1) return url;
  const base = url.slice(0, uploadIdx + "/upload/".length);
  const segments = url.slice(base.length).split("/");
  let i = 0;
  while (i < segments.length) {
    const seg = segments[i];
    if (/^v\d+$/.test(seg)) break;
    if (seg.includes(",") || /^[fqwchgbdeo]_/.test(seg)) { i++; } else break;
  }
  const publicPart = segments.slice(i).join("/");
  return `${base}${format},${quality},w_${width},c_fill/${publicPart}`;
}

const FALLBACK_HERO = "https://res.cloudinary.com/age-fabric/image/upload/About1_j3mzld.jpg";
const rawImage = image ?? FALLBACK_HERO;

const mobileWidths = [400, 768];
const desktopWidths = [1024, 1280];

const heroSrc = buildHeroUrl(rawImage, 1024, "f_auto", "q_auto:eco");

const avifSrcset = [
  ...mobileWidths.map((w) => `${buildHeroUrl(rawImage, w, "f_avif", "q_30")} ${w}w`),
  ...desktopWidths.map((w) => `${buildHeroUrl(rawImage, w, "f_avif", "q_auto:eco")} ${w}w`),
].join(", ");

const webpSrcset = [
  ...mobileWidths.map((w) => `${buildHeroUrl(rawImage, w, "f_webp", "q_30")} ${w}w`),
  ...desktopWidths.map((w) => `${buildHeroUrl(rawImage, w, "f_webp", "q_auto:eco")} ${w}w`),
].join(", ");

const fallbackSrcset = [
  ...mobileWidths.map((w) => `${buildHeroUrl(rawImage, w, "f_auto", "q_30")} ${w}w`),
  ...desktopWidths.map((w) => `${buildHeroUrl(rawImage, w, "f_auto", "q_auto:eco")} ${w}w`),
].join(", ");

const sizes = "(max-width: 768px) 100vw, (max-width: 1280px) 1024px, 1280px";
---
<style>
  .gold-text {
    background: linear-gradient(to right, #775a19, #fed488);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: transparent;
  }
</style>
<header class="about-hero relative flex items-start overflow-hidden bg-[#041632] pt-3">
  <style>
    .about-hero {
      min-height: calc(100dvh - 94px);
    }
    @media (min-width: 768px) {
      .about-hero { min-height: calc(100dvh - 102px); }
    }
  </style>
  <div class="absolute inset-0 opacity-70">
    <picture>
      <source type="image/avif" srcset={avifSrcset} sizes={sizes} />
      <source type="image/webp" srcset={webpSrcset} sizes={sizes} />
      <img
        src={heroSrc}
        srcset={fallbackSrcset}
        sizes={sizes}
        alt="Industrial textile loom threads close up"
        title="Industrial textile loom threads close up"
        width="1024"
        height="870"
        class="w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
    </picture>
    <div class="absolute inset-0 bg-gradient-to-r from-[#041632] via-[#041632]/60 to-transparent"></div>
  </div>
  <div class="relative z-10 max-w-7xl mx-auto px-8 w-full pt-3">
    <div class="max-w-3xl">
      {breadcrumbs && breadcrumbs.length > 1 && (
        <div class="mb-6">
          <Breadcrumbs items={breadcrumbs} variant="dark" />
        </div>
      )}
      <span class="inline-block px-4 py-1 mb-6 border border-[#775a19] text-[#ffdea5] font-sans text-xs tracking-[0.2em] uppercase">
        Est. 1971 | Ahmedabad, India
      </span>
      <h1 class="font-serif text-6xl md:text-7xl leading-tight mb-8">
        <span class="text-white">A Legacy of</span><br/>
        <span class="italic gold-text">Textile Excellence</span><br/>
        <span class="text-white">Since 1971</span>
      </h1>
      <p class="text-[#8393b5] text-xl md:text-2xl leading-relaxed font-light max-w-2xl">
        For over five decades, {companyName} has defined the intersection of technical precision and artistic mastery in the global fabric industry.
      </p>
    </div>
  </div>
  <div class="absolute bottom-12 right-12 hidden lg:block">
    <div class="flex items-center gap-4 text-[#775a19] rotate-90 origin-right">
      <span class="font-sans tracking-widest text-xs uppercase">Scroll to Explore</span>
      <div class="w-12 h-px bg-[#775a19]"></div>
    </div>
  </div>
</header>
