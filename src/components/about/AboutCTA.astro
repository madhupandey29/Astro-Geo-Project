---
import { getCompanyInfo } from "../../lib/api";

interface Props {
  phone?: string | null;
}
const { phone } = Astro.props;
const phoneHref = phone ? `tel:${phone.replace(/\s/g, '')}` : 'tel:';
const company = await getCompanyInfo("AGE");
const companyName = company?.legalName ?? "";
---

<section class="py-24 bg-[#041632] text-white">
  <div class="max-w-7xl mx-auto px-8 text-center">
    <h2 class="font-serif text-5xl mb-8">
      Ready to Weave <span class="italic text-[#ffdea5]">the Future?</span>
    </h2>
    <p class="text-[#8393b5] text-xl max-w-2xl mx-auto mb-12">
      Join hands with India's most trusted textile conglomerate for your next
      global collection.
    </p>
    <div class="flex flex-col sm:flex-row gap-6 justify-center">
      <a
        href={phoneHref}
        class="bg-[#775a19] text-white px-10 py-4 rounded-sm font-sans uppercase tracking-widest hover:bg-[#ffdea5] hover:text-[#041632] transition-all"
      >
        Partner with {companyName}
      </a>
      <a
        href="/fabric"
        class="border border-[#75777e] text-white px-10 py-4 rounded-sm font-sans uppercase tracking-widest hover:bg-white/10 transition-all"
      >
        Download Portfolio
      </a>
    </div>
  </div>
</section>
