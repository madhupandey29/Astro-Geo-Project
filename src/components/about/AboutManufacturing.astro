---
---
<section class="py-32 bg-[#e7e8e9]">
  <div class="max-w-7xl mx-auto px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div class="order-2 lg:order-1">
        <span class="font-sans text-xs uppercase tracking-widest text-[#775a19] font-bold mb-4 block">Infrastructure</span>
        <h2 class="font-serif text-5xl text-[#041632] mb-8 leading-tight">
          Strategic Hubs: From <span class="italic">Safal Prelude</span> to the Factory Floor
        </h2>
        <div class="space-y-6">
          <div class="bg-white p-8 flex gap-6">
            <span class="material-symbols-outlined text-[#041632] text-3xl">corporate_fare</span>
            <div>
              <h3 class="font-bold text-[#041632] text-lg">404 Safal Prelude, Ahmedabad</h3>
              <p class="text-[#44474d] text-sm mt-1">Our corporate nerve center. Housing design studios, global logistics coordination, and the executive board.</p>
            </div>
          </div>
          <div class="bg-white p-8 flex gap-6">
            <span class="material-symbols-outlined text-[#041632] text-3xl">precision_manufacturing</span>
            <div>
              <h3 class="font-bold text-[#041632] text-lg">The Integrated Mill</h3>
              <p class="text-[#44474d] text-sm mt-1">State-of-the-art weaving and processing units featuring Swiss and German machinery for unmatched precision.</p>
            </div>
          </div>
        </div>
      </div>
      <div class="order-1 lg:order-2 grid grid-cols-2 gap-4">
        <div class="space-y-4">
          <div class="h-64 overflow-hidden">
            <img src="https://res.cloudinary.com/age-fabric/image/upload/v1775655126/21_wnjesc.jpg" alt="Modern office building exterior" title="Modern office building exterior" width="280" height="256" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="h-48 overflow-hidden">
            <img src="https://res.cloudinary.com/age-fabric/image/upload/v1775655067/19_b5qovh.jpg" alt="Robotic arm in textile factory" title="Robotic arm in textile factory" width="280" height="192" class="w-full h-full object-cover" loading="lazy" />
          </div>
        </div>
        <div class="pt-12 space-y-4">
          <div class="h-48 overflow-hidden">
            <img src="https://res.cloudinary.com/age-fabric/image/upload/v1775655124/20_zjtk2y.jpg" alt="Navy blue suit fabric close up" title="Navy blue suit fabric close up" width="280" height="192" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="h-64 overflow-hidden">
            <img src="https://res.cloudinary.com/age-fabric/image/upload/v1775655065/18_f7x5gw.jpg" alt="Wide shot of textile weaving floor" title="Wide shot of textile weaving floor" width="280" height="256" class="w-full h-full object-cover" loading="lazy" />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
