---
import Breadcrumbs from "../common/Breadcrumbs.astro";
import type { ApiBlogPost } from "../../lib/blog";
import { formatDate, getPostImage, cloudinarySrcset } from "../../lib/blog";

interface Props {
  post: ApiBlogPost;
  breadcrumbs?: { name: string; href?: string }[];
}
const { post, breadcrumbs } = Astro.props;
---
<header class="max-w-5xl mx-auto px-4 md:px-8 pt-3 md:pt-3 pb-10 md:pb-12">
  {breadcrumbs && breadcrumbs.length > 1 ? (
    <div class="mb-8">
      <Breadcrumbs items={breadcrumbs} variant="light" />
    </div>
  ) : (
    <nav class="flex items-center gap-2 text-[10px] font-sans uppercase tracking-widest text-[#44474d] mb-8 overflow-x-auto whitespace-nowrap">
      <a href="/" class="text-[#44474d] hover:text-[#041632] transition-colors">Home</a>
      <span class="material-symbols-outlined text-sm">chevron_right</span>
      <a href="/blog" class="text-[#44474d] hover:text-[#041632] transition-colors">Insights</a>
      <span class="material-symbols-outlined text-sm">chevron_right</span>
      <span class="text-[#775a19] font-bold">{post.category}</span>
    </nav>
  )}

  <span class="inline-block px-3 py-1 bg-[#fed488] text-[#261900] text-[10px] font-bold uppercase tracking-[0.2em] rounded-sm mb-6">
    {post.category}
  </span>

  <h1 class="font-serif text-4xl md:text-6xl text-[#041632] leading-tight mb-8">
    {post.title}
  </h1>

  <div class="flex flex-wrap items-center gap-6 text-xs font-sans text-[#44474d] mb-10">
    <div class="flex items-center gap-2">
      <span class="material-symbols-outlined text-[#775a19] text-base">schedule</span>
      <span>{post.readingTimeMin} min read</span>
    </div>
    <div class="flex items-center gap-2">
      <span class="material-symbols-outlined text-[#775a19] text-base">calendar_today</span>
      <span>{formatDate(post.publishedAt)}</span>
    </div>
    {post.tags.length > 0 && (
      <div class="flex items-center gap-2 flex-wrap">
        {post.tags.map((tag) => (
          <span class="px-2 py-0.5 bg-[#f3f4f5] text-[#44474d] rounded text-[10px] font-bold uppercase tracking-wider">{tag}</span>
        ))}
      </div>
    )}
  </div>

  <div class="relative h-[300px] md:h-[500px] w-full overflow-hidden rounded-xl shadow-lg">
    {(() => {
      const img = getPostImage(post);
      const srcset = cloudinarySrcset(img, [400, 768, 960]);
      return (
        <img
          src={img}
          srcset={srcset}
          sizes="(max-width: 640px) 100vw, (max-width: 1024px) 768px, 960px"
          alt={post.featuredImageAlt ?? post.title}
          title={post.featuredImageAlt ?? post.title}
          width="960"
          height="500"
          class="w-full h-full object-cover"
          loading="eager"
          fetchpriority="high"
          decoding="async"
        />
      );
    })()}
    <div class="absolute inset-0 bg-gradient-to-t from-[#041632]/40 to-transparent"></div>
  </div>
</header>
