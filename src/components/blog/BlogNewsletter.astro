---
const LEAD_CAPTURE_URL = import.meta.env.PUBLIC_ESPO_BASE + "/LeadCapture/" + import.meta.env.PUBLIC_LEAD_CAPTURE_KEY;
---
<section class="px-8 py-20 bg-[#e7e8e9] relative overflow-hidden">
  <div class="max-w-4xl mx-auto text-center relative z-10">
    <span class="material-symbols-outlined text-[#775a19] text-5xl mb-6 block" style="font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 48;">mail</span>
    <h2 class="font-serif text-4xl text-[#041632] font-bold mb-6 italic">Stay Woven Into the Future</h2>
    <p class="text-[#44474d] text-lg mb-10 max-w-xl mx-auto">
      Receive our monthly intelligence report on textile engineering, market shifts, and manufacturing breakthroughs.
    </p>
    <form id="newsletter-form" data-url={LEAD_CAPTURE_URL} class="flex flex-col md:flex-row gap-4 max-w-lg mx-auto" novalidate>
      <label for="newsletter-email" class="sr-only">Corporate Email Address</label>
      <input
        id="newsletter-email"
        name="email"
        autocomplete="email"
        type="email"
        placeholder="Corporate Email Address"
        required
        class="flex-1 px-6 py-4 bg-white border-none rounded-lg focus:outline-none focus:ring-2 focus:ring-[#775a19] transition-all font-sans text-sm"
      />
      <button
        type="submit"
        id="newsletter-btn"
        class="bg-[#041632] text-white px-8 py-4 rounded-lg font-sans font-bold uppercase tracking-widest text-xs hover:bg-[#775a19] transition-colors shadow-lg disabled:opacity-50 disabled:cursor-not-allowed"
      >
        Subscribe
      </button>
    </form>
    <p id="newsletter-success" class="hidden mt-4 text-sm text-green-700 font-sans">Thanks for subscribing! We'll be in touch.</p>
    <p id="newsletter-error" class="hidden mt-4 text-sm text-red-600 font-sans">Something went wrong. Please try again.</p>
    <p class="mt-6 text-xs text-[#5a5c63] font-sans uppercase tracking-widest">Private &amp; Secure. Industry Only.</p>
  </div>

  <!-- Decorative blobs -->
  <div class="absolute top-0 right-0 w-64 h-64 bg-[#775a19]/5 rounded-full -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-96 h-96 bg-[#041632]/5 rounded-full translate-y-1/2 -translate-x-1/2 pointer-events-none"></div>
</section>

<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement;
  const emailInput = document.getElementById('newsletter-email') as HTMLInputElement;
  const btn = document.getElementById('newsletter-btn') as HTMLButtonElement;
  const successMsg = document.getElementById('newsletter-success')!;
  const errorMsg = document.getElementById('newsletter-error')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = emailInput.value.trim();
    if (!email) return;

    const ESPO_URL = form.dataset.url!;

    btn.disabled = true;
    btn.textContent = 'Subscribing...';
    successMsg.classList.add('hidden');
    errorMsg.classList.add('hidden');

    try {
      const res = await fetch(ESPO_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          emailAddress: email,
          description: 'Subscribed via Blog Newsletter',
        }),
      });

      if (res.ok) {
        form.reset();
        successMsg.classList.remove('hidden');
      } else {
        errorMsg.classList.remove('hidden');
      }
    } catch {
      errorMsg.classList.remove('hidden');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Subscribe';
    }
  });
</script>
