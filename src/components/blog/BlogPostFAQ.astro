---
import type { BlogPost } from "../../data/blog";
interface Props { post: BlogPost }
const { post } = Astro.props;
---
<section class="max-w-3xl mx-auto px-8 pb-24">
  <h2 class="font-serif text-3xl md:text-4xl text-[#041632] mb-12 text-center">Frequently Asked Questions</h2>
  <div class="space-y-4">
    {post.faq.map((item) => (
      <details class="group bg-[#f3f4f5] rounded-xl p-5 md:p-6 cursor-pointer border border-transparent hover:border-[#c5c6ce]/30 transition-all">
        <summary class="flex justify-between items-center font-bold text-[#041632] list-none text-sm md:text-base">
          {item.q}
          <span class="material-symbols-outlined group-open:rotate-180 transition-transform shrink-0 ml-4">expand_more</span>
        </summary>
        <div class="mt-4 text-[#44474d] text-sm md:text-base leading-relaxed">{item.a}</div>
      </details>
    ))}
  </div>
</section>
