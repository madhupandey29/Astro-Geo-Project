---
---
<section class="bg-[#f3f4f5] py-16 px-4 md:px-8">
  <div class="max-w-5xl mx-auto">
    <div class="bg-[#041632] p-8 md:p-16 relative overflow-hidden flex flex-col md:flex-row items-center justify-between gap-8">
      <div class="pointer-events-none absolute top-0 right-0 w-64 h-64 bg-[#775a19] opacity-10 -mr-32 -mt-32 blur-3xl"></div>

      <div class="relative z-10 text-center md:text-left">
        <h2 class="font-headline text-3xl md:text-4xl text-white italic mb-4">
          Can't find your answer?
        </h2>
        <p class="text-[#8393b5] max-w-md text-sm md:text-base">
          Our global procurement experts are online to help with specific technical queries or bulk pricing inquiries.
        </p>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 w-full md:w-auto relative z-10 shrink-0">
        <a
          href="/support"
          class="px-8 py-4 bg-[#775a19] text-white font-bold hover:bg-[#fed488] hover:text-[#041632] transition-all flex items-center gap-3 justify-center uppercase tracking-widest text-sm"
          onclick="window.gtag?.('event','faq_cta_chat_expert',{page_path:window.location.pathname})"
        >
          <span class="material-symbols-outlined text-base">forum</span>
          Chat Expert
        </a>
        <a
          href="/support"
          class="px-8 py-4 border border-white/20 text-white font-bold hover:bg-white/10 transition-all text-center uppercase tracking-widest text-sm"
          onclick="window.gtag?.('event','faq_cta_contact_sales',{page_path:window.location.pathname})"
        >
          Contact Sales
        </a>
      </div>
    </div>
  </div>
</section>
