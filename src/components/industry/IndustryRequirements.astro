---
export interface Requirement {
  icon: string;
  title: string;
  description: string;
}

export interface Props {
  heading?: string;
  requirements?: Requirement[];
}

const {
  heading = "Technical Mandates",
  requirements = [
    {
      icon: "check_circle",
      title: "Tensile Integrity",
      description: "Required for Hospitality and Industrial Uniforms to withstand 300+ commercial wash cycles without pilling.",
    },
    {
      icon: "palette",
      title: "Color Fastness",
      description: "Crucial for Export and Apparel markets ensuring vibrancy under ISO 105-B02 light fastness standards.",
    },
    {
      icon: "badge",
      title: "Breathability Index",
      description: "Specific to high-performance Uniform sectors, balancing synthetic strength with natural cotton comfort.",
    },
  ],
} = Astro.props;
---

<section class="py-20 px-6 bg-[#f6f7f8]">
  <h2 class="font-headline text-3xl text-[#041632] mb-10 text-center">{heading}</h2>
  <div class="space-y-8 max-w-2xl mx-auto">
    {requirements.map((req) => (
      <div class="flex gap-6 items-start">
        <div class="w-12 h-12 shrink-0 bg-white rounded-full flex items-center justify-center shadow-sm">
          <span class="material-symbols-outlined text-[#8d6708]" style="font-variation-settings:'FILL' 1">{req.icon}</span>
        </div>
        <div>
          <h4 class="font-body font-bold text-[#041632] text-lg mb-1">{req.title}</h4>
          <p class="text-sm text-[#44474d] leading-relaxed">{req.description}</p>
        </div>
      </div>
    ))}
  </div>
</section>
