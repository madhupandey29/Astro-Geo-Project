---
import ResponsiveImage from "../common/ResponsiveImage.astro";

export interface Props {
  collectionLabel?: string;
  productName?: string;
  productDescription?: string;
  productImage?: string;
  productImageAlt?: string;
  threadCount?: string;
  durability?: string;
  ctaLabel?: string;
}

const {
  collectionLabel = "Signature Collection",
  productName = "Majestica-767",
  productDescription = "The gold standard for the luxury hospitality sector worldwide.",
  productImage = "https://lh3.googleusercontent.com/aida-public/AB6AXuB3B2Jt7CC8Nns3jJVvEOm4Fjjk-qfv4cBHwyrIx35h1t-pvG40m_Klhy6VfAPWNtIDn8XFXaOjNTMjGxK0L4f5N7dMdBvFGeLzsBJHFFs4AKPRsc8l64wNrn201tWhqUaAMYpbB7tZiRpokN7LogZOnAGCc1A9A8-h1N0kq7ld4QPCiAHJDQ46DF9ijcMz5Jd7tGVZ7hJ3LsybFK3Mly9stI3eKrOdwMUIvHHLPhufOnbO39M0I6E_uxLn3RtspDrd0dFWWuBuQUEt",
  productImageAlt = "Premium folded white hotel linens with crisp texture",
  threadCount = "800 TC Sateen",
  durability = "Industrial Grade",
  ctaLabel = "Request Swatch Pack",
} = Astro.props;
---

<section class="py-20 px-6 bg-[#f8f9fa]">
  <div class="bg-[#041632] rounded-2xl overflow-hidden shadow-xl">
    <div class="p-8 pb-0">
      <div class="flex items-center gap-2 mb-4">
        <span class="w-2 h-2 rounded-full bg-[#8d6708]"></span>
        <span class="font-label text-[10px] font-semibold tracking-widest uppercase text-[#e8b84b]">{collectionLabel}</span>
      </div>
      <h2 class="font-headline text-4xl text-[#ffffff] mb-2">{productName}</h2>
      <p class="text-sm text-[#b7c7eb] mb-6">{productDescription}</p>
    </div>
    <div class="px-8">
      <ResponsiveImage
        src={productImage}
        alt={productImageAlt}
        title={productImageAlt}
        width={800}
        height={224}
        widths={[320, 480, 640, 800]}
        sizes="(max-width: 768px) 100vw, 800px"
        crop="fill"
        loading="lazy"
        class="w-full h-56 object-cover rounded-t-xl shadow-lg"
      />
    </div>
    <div class="p-8 bg-[#f3f4f6]">
      <div class="grid grid-cols-2 gap-4 mb-6">
        <div>
          <p class="font-label text-[10px] uppercase tracking-wider text-[#64748b] mb-1">Thread Count</p>
          <p class="font-body font-bold text-[#041632]">{threadCount}</p>
        </div>
        <div>
          <p class="font-label text-[10px] uppercase tracking-wider text-[#64748b] mb-1">Durability</p>
          <p class="font-body font-bold text-[#041632]">{durability}</p>
        </div>
      </div>
      <button class="w-full py-4 rounded-xl text-[#ffffff] font-body font-semibold flex items-center justify-center gap-2 hover:opacity-90 transition-opacity" style="background: linear-gradient(135deg, #041632 0%, #1b2b48 100%);">
        {ctaLabel}
        <span class="material-symbols-outlined text-sm">file_download</span>
      </button>
    </div>
  </div>
</section>
