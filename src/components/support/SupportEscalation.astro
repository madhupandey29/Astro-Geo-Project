---
const steps = [
  {
    number: "01",
    title: "Ticket Initiation",
    desc: "Submit issue via portal or WhatsApp. A unique ID is assigned within 15 minutes.",
    // clipboard / assignment icon
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><line x1="9" y1="12" x2="15" y2="12"/><line x1="9" y1="16" x2="13" y2="16"/></svg>`,
  },
  {
    number: "02",
    title: "Technical Review",
    desc: "Engineering leads assess impact. Root cause analysis performed and timeline shared.",
    // settings / engineering icon
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>`,
  },
  {
    number: "03",
    title: "Resolution & Audit",
    desc: "Fix implemented. Client confirms satisfaction, followed by a quality audit.",
    // shield check / verified icon
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>`,
  },
];
---
<section class="py-12 md:py-28 bg-[#f3f4f5]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 md:px-8 flex flex-col md:flex-row gap-10 md:gap-16 items-start">
    <div class="w-full md:w-1/3 md:sticky md:top-28">
      <span class="inline-block px-4 py-1 mb-4 border border-[#775a19] text-[#775a19] font-sans text-xs tracking-[0.2em] uppercase">
        Structured Process
      </span>
      <h2 class="font-serif text-4xl md:text-5xl text-[#041632] mb-6 leading-tight">Escalation Protocol</h2>
      <p class="text-[#44474d] leading-relaxed">Our structured 3-step process ensures no bottleneck remains unresolved. We prioritize production continuity above all.</p>
    </div>

    <div class="w-full md:w-2/3 flex flex-col gap-4 md:gap-6">
      {steps.map((step) => (
        <div class="bg-white rounded-lg p-5 sm:p-8 flex items-start gap-4 sm:gap-6 border border-[#9ca3af] hover:border-[#775a19] transition-colors">
          <div class="w-10 h-10 sm:w-12 sm:h-12 bg-[#041632]/5 rounded-lg flex items-center justify-center flex-shrink-0 text-[#1B2B48]">
            <Fragment set:html={step.svg} />
          </div>
          <div>
            <h3 class="font-serif text-lg sm:text-xl text-[#041632] mb-1 sm:mb-2">{step.title}</h3>
            <p class="text-sm text-[#44474d] leading-relaxed">{step.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
