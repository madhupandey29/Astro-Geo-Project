---
const steps = [
  {
    number: "01",
    icon: "assignment",
    title: "Ticket Initiation",
    desc: "Submit issue via portal or WhatsApp. A unique ID is assigned within 15 minutes.",
  },
  {
    number: "02",
    icon: "engineering",
    title: "Technical Review",
    desc: "Engineering leads assess impact. Root cause analysis performed and timeline shared.",
  },
  {
    number: "03",
    icon: "verified",
    title: "Resolution & Audit",
    desc: "Fix implemented. Client confirms satisfaction, followed by a quality audit.",
  },
];
---
<section class="py-20 md:py-28 bg-[#f3f4f5]">
  <div class="max-w-7xl mx-auto px-8 flex flex-col md:flex-row gap-16 items-start">
    <div class="w-full md:w-1/3 md:sticky md:top-28">
      <span class="inline-block px-4 py-1 mb-4 border border-[#775a19] text-[#775a19] font-sans text-xs tracking-[0.2em] uppercase">
        Structured Process
      </span>
      <h2 class="font-serif text-4xl md:text-5xl text-[#041632] mb-6 leading-tight">Escalation Protocol</h2>
      <p class="text-[#44474d] leading-relaxed">Our structured 3-step process ensures no bottleneck remains unresolved. We prioritize production continuity above all.</p>
    </div>

    <div class="w-full md:w-2/3 flex flex-col gap-6">
      {steps.map((step) => (
        <div class="bg-white rounded-lg p-8 flex items-start gap-6 relative overflow-hidden border border-[#e1e3e4] hover:border-[#775a19] transition-colors group">
          <span class="text-6xl md:text-8xl font-serif italic text-[#e1e3e4] absolute -right-2 -bottom-3 select-none group-hover:text-[#ffdea5] transition-colors">
            {step.number}
          </span>
          <div class="w-12 h-12 bg-[#041632]/5 rounded-lg flex items-center justify-center flex-shrink-0">
            <span class="material-symbols-outlined text-[#1B2B48]">{step.icon}</span>
          </div>
          <div class="relative z-10">
            <h3 class="font-serif text-xl text-[#041632] mb-2">{step.title}</h3>
            <p class="text-sm text-[#44474d] leading-relaxed max-w-md">{step.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
