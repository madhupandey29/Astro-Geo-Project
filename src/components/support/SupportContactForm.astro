---
import MultiStepContactForm from "../common/MultiStepContactForm.astro";
const LEAD_CAPTURE_URL = import.meta.env.PUBLIC_ESPO_BASE + "/LeadCapture/" + import.meta.env.PUBLIC_LEAD_CAPTURE_KEY;
---

<MultiStepContactForm
  formId="scf"
  badge="Direct Inquiry"
  heading="Send us a Message"
  subheading="Fill out the form below and we'll get back to you shortly."
  steps={[
    { label: "Personal" },
    { label: "Company" },
    { label: "Details" },
  ]}
  submitLabel="Submit Request"
  successTitle="Message Sent"
  successMessage="Thank you! Your inquiry has been received. We'll be in touch shortly."
>

  <!-- STEP 1: Personal Info -->
  <div id="scf-step-0" class="space-y-5">
    <div>
      <label for="scf-salutation" class="msf-label">Salutation</label>
      <select id="scf-salutation" name="salutationName" class="msf-input">
        <option value="">Select salutation</option>
        <option value="Mr.">Mr.</option>
        <option value="Ms.">Ms.</option>
        <option value="Mrs.">Mrs.</option>
        <option value="Dr.">Dr.</option>
        <option value="Prof.">Prof.</option>
      </select>
    </div>
    <div>
      <label for="scf-firstName" class="msf-label">First Name <span class="text-[#775a19]">*</span></label>
      <input id="scf-firstName" type="text" name="firstName" required class="msf-input" placeholder="Your first name" />
    </div>
    <div>
      <label for="scf-lastName" class="msf-label">Last Name <span class="text-[#775a19]">*</span></label>
      <input id="scf-lastName" type="text" name="lastName" required class="msf-input" placeholder="Your last name" />
    </div>
    <div>
      <label for="scf-middleName" class="msf-label">Middle Name</label>
      <input id="scf-middleName" type="text" name="middleName" class="msf-input" placeholder="Optional" />
    </div>
    <div>
      <label for="scf-email" class="msf-label">Email Address <span class="text-[#775a19]">*</span></label>
      <input id="scf-email" type="email" name="emailAddress" class="msf-input" placeholder="your@company.com" />
    </div>
    <div>
      <label for="scf-phone" class="msf-label">Phone Number <span class="text-[#775a19]">*</span></label>
      <input id="scf-phone" type="tel" name="phoneNumber" class="msf-input" placeholder="+91 00000 00000" />
      <p class="text-xs text-[#5a6a85] mt-1">Please provide at least an email or phone number.</p>
    </div>
    <div class="msf-nav-row end">
      <button type="button" id="scf-next-0" class="msf-btn-primary">Next Step</button>
    </div>
  </div>

  <!-- STEP 2: Company & Address -->
  <div id="scf-step-1" class="space-y-5 hidden">
    <div>
      <label for="scf-company" class="msf-label">Company Name</label>
      <input id="scf-company" type="text" name="accountName" class="msf-input" placeholder="Your company name" />
    </div>
    <div>
      <label for="scf-street" class="msf-label">Street Address</label>
      <input id="scf-street" type="text" name="addressStreet" class="msf-input" placeholder="Street address" />
    </div>
    <div>
      <label for="scf-city" class="msf-label">City</label>
      <input id="scf-city" type="text" name="addressCity" class="msf-input" placeholder="City" />
    </div>
    <div>
      <label for="scf-state" class="msf-label">State / Province</label>
      <input id="scf-state" type="text" name="addressState" class="msf-input" placeholder="State or Province" />
    </div>
    <div>
      <label for="scf-country" class="msf-label">Country</label>
      <input id="scf-country" type="text" name="addressCountry" class="msf-input" placeholder="Country" />
    </div>
    <div>
      <label for="scf-postal" class="msf-label">Postal Code</label>
      <input id="scf-postal" type="text" name="addressPostalCode" class="msf-input" placeholder="Postal / ZIP code" />
    </div>
    <div class="msf-nav-row">
      <button type="button" id="scf-prev-1" class="msf-btn-secondary">Previous</button>
      <button type="button" id="scf-next-1" class="msf-btn-primary">Next Step</button>
    </div>
  </div>

  <!-- STEP 3: Business Details -->
  <div id="scf-step-2" class="space-y-5 hidden">
    <div>
      <label for="scf-bizType" class="msf-label">Business Type</label>
      <select id="scf-bizType" name="cBusinessType" class="msf-input">
        <option value="">Select business type</option>
        <option value="fabric-importer">Fabric Importer</option>
        <option value="fabric-exporter">Fabric Exporter</option>
        <option value="garment-manufacturer">Garment Manufacturer</option>
        <option value="retailer">Retailer</option>
        <option value="wholesaler">Wholesaler</option>
        <option value="buying-agent">Buying Agent</option>
        <option value="other">Other</option>
      </select>
    </div>
    <div>
      <label for="scf-fabricCat" class="msf-label">Fabric Category</label>
      <select id="scf-fabricCat" name="cFabricCategory" class="msf-input">
        <option value="">Select fabric category</option>
        <option value="cotton">Cotton</option>
        <option value="denim">Denim</option>
        <option value="polyester">Polyester</option>
        <option value="knit">Knit</option>
        <option value="woven">Woven</option>
        <option value="blended">Blended</option>
        <option value="other">Other</option>
      </select>
    </div>
    <div>
      <label for="scf-amount" class="msf-label">Opportunity Amount</label>
      <div class="flex flex-col sm:flex-row gap-3">
        <input id="scf-amount" type="number" name="opportunityAmount" class="msf-input flex-1" placeholder="0.00" min="0" step="0.01" />
        <label for="scf-currency" class="sr-only">Currency</label>
        <select id="scf-currency" name="opportunityAmountCurrency" class="msf-input sm:w-28">
          <option value="USD">USD</option>
          <option value="INR">INR</option>
          <option value="EUR">EUR</option>
          <option value="GBP">GBP</option>
        </select>
      </div>
    </div>
    <div>
      <label for="scf-description" class="msf-label">Description</label>
      <textarea id="scf-description" name="description" rows="4" class="msf-input resize-none" placeholder="Describe your requirements or any additional information"></textarea>
    </div>
    <div class="msf-nav-row">
      <button type="button" id="scf-prev-2" class="msf-btn-secondary">Previous</button>
      <button type="submit" id="scf-submit" class="msf-btn-primary">
        <span id="scf-submit-text">Submit Request</span>
        <span id="scf-submit-spinner" class="material-symbols-outlined animate-spin text-base hidden">progress_activity</span>
      </button>
    </div>
  </div>

</MultiStepContactForm>

<script define:vars={{ LEAD_CAPTURE_URL }}>
  const FORM_ID    = 'scf';
  const STEP_COUNT = 3;

  const form      = document.getElementById(FORM_ID);
  const stepLabel = document.getElementById(`${FORM_ID}-step-label`);
  const stepLabels = ['Personal', 'Company', 'Details'];

  let current = 0;

  const g = (name) =>
    form.querySelector(`[name="${name}"]`)?.value?.trim() ?? '';

  function collectPayload() {
    const payload = {};
    const textFields = [
      'salutationName','firstName','lastName','middleName',
      'emailAddress','accountName',
      'addressStreet','addressCity','addressState','addressCountry','addressPostalCode',
    ];
    for (const f of textFields) { const v = g(f); if (v) payload[f] = v; }
    const bt = g('cBusinessType');
    const fc = g('cFabricCategory');
    const am = g('opportunityAmount');
    if (bt) payload.cBusinessType   = [bt];
    if (fc) payload.cFabricCategory = [fc];
    if (am) payload.opportunityAmount = parseFloat(am);
    const cur = g('opportunityAmountCurrency');
    if (cur) payload.opportunityAmountCurrency = cur;
    // Phone goes into description to avoid CRM phone field validation
    const parts = [];
    const rawPhone = g('phoneNumber');
    if (rawPhone) parts.push(`Phone: ${rawPhone}`);
    const desc = g('description');
    if (desc) parts.push(desc);
    if (parts.length) payload.description = parts.join('\n');
    return payload;
  }

  function goTo(n) {
    document.getElementById(`${FORM_ID}-step-${current}`).classList.add('hidden');
    current = n;
    document.getElementById(`${FORM_ID}-step-${current}`).classList.remove('hidden');
    stepLabel.textContent = stepLabels[current] ?? `Step ${current + 1} of ${STEP_COUNT}`;

    for (let i = 0; i < STEP_COUNT; i++) {
      const dot = document.getElementById(`${FORM_ID}-dot-${i}`);
      if (i <= current) {
        dot.classList.remove('border-2', 'border-[#d1d5db]', 'text-[#9ca3af]');
        dot.classList.add('bg-[#041632]', 'text-white');
      } else {
        dot.classList.add('border-2', 'border-[#d1d5db]', 'text-[#9ca3af]');
        dot.classList.remove('bg-[#041632]', 'text-white');
      }
    }
    for (let i = 0; i < STEP_COUNT - 1; i++) {
      const line = document.getElementById(`${FORM_ID}-line-${i}`);
      line.classList.toggle('bg-[#041632]', i < current);
      line.classList.toggle('bg-[#d1d5db]', i >= current);
    }
  }

  function validateStep0() {
    if (!g('firstName') || !g('lastName')) { alert('Please enter your first and last name.'); return false; }
    if (!g('emailAddress') && !g('phoneNumber')) { alert('Please provide at least an email or phone number.'); return false; }
    return true;
  }

  document.getElementById(`${FORM_ID}-next-0`).addEventListener('click', () => { if (validateStep0()) goTo(1); });
  document.getElementById(`${FORM_ID}-prev-1`).addEventListener('click', () => goTo(0));
  document.getElementById(`${FORM_ID}-next-1`).addEventListener('click', () => goTo(2));
  document.getElementById(`${FORM_ID}-prev-2`).addEventListener('click', () => goTo(1));

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (form.querySelector('[name="_hp"]').value) return;

    const submitBtn  = document.getElementById(`${FORM_ID}-submit`);
    const submitText = document.getElementById(`${FORM_ID}-submit-text`);
    const spinner    = document.getElementById(`${FORM_ID}-submit-spinner`);
    const errorEl    = document.getElementById(`${FORM_ID}-error`);
    const successEl  = document.getElementById(`${FORM_ID}-success`);

    submitBtn.disabled = true;
    submitText.textContent = 'Sending...';
    spinner.classList.remove('hidden');
    errorEl.classList.add('hidden');

    try {
      const res = await fetch(LEAD_CAPTURE_URL, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(collectPayload()),
      });
      if (!res.ok) throw new Error(`${res.status}`);

      form.reset();
      document.getElementById(`${FORM_ID}-step-${current}`).classList.add('hidden');
      document.getElementById(`${FORM_ID}-stepper`).classList.add('hidden');
      stepLabel.classList.add('hidden');
      successEl.classList.remove('hidden');
    } catch {
      errorEl.textContent = 'Something went wrong. Please try again or email us directly.';
      errorEl.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitText.textContent = 'Submit Request';
      spinner.classList.add('hidden');
    }
  });
</script>
