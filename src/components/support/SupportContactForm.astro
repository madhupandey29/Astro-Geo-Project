---
---
<section class="py-20 md:py-28 px-8 bg-[#f3f4f5]">
  <div class="max-w-2xl mx-auto">
    <div class="text-center mb-10">
      <span class="inline-block px-4 py-1 mb-6 border border-[#775a19] text-[#775a19] font-sans text-xs tracking-[0.2em] uppercase">
        Direct Inquiry
      </span>
      <h2 class="font-serif text-3xl md:text-4xl text-[#041632] mb-3 leading-tight">Send us a Message</h2>
      <p class="text-[#5a6a85] text-sm">Fill out the form below and we'll get back to you shortly.</p>
    </div>

    <div class="bg-white rounded-lg shadow-sm p-8 md:p-12">
      <!-- Stepper -->
      <div class="flex items-center justify-center gap-0 mb-2">
        <div class="h-px w-16 bg-[#d1d5db]"></div>
        <div id="step-dot-1" class="w-9 h-9 rounded-full flex items-center justify-center text-sm font-sans font-semibold bg-[#041632] text-white z-10">1</div>
        <div id="step-line-1" class="h-px w-16 bg-[#d1d5db] transition-colors duration-300"></div>
        <div id="step-dot-2" class="w-9 h-9 rounded-full flex items-center justify-center text-sm font-sans font-semibold border-2 border-[#d1d5db] text-[#9ca3af] z-10 transition-all duration-300">2</div>
        <div id="step-line-2" class="h-px w-16 bg-[#d1d5db] transition-colors duration-300"></div>
        <div id="step-dot-3" class="w-9 h-9 rounded-full flex items-center justify-center text-sm font-sans font-semibold border-2 border-[#d1d5db] text-[#9ca3af] z-10 transition-all duration-300">3</div>
        <div class="h-px w-16 bg-[#d1d5db]"></div>
      </div>
      <p id="step-label" class="text-center font-sans text-xs tracking-widest uppercase text-[#5a6a85] mb-8">Step 1 of 3</p>

      <form id="msf" novalidate>
        <!-- Honeypot -->
        <input type="text" name="_hp" class="hidden" tabindex="-1" autocomplete="off" />

        <!-- STEP 1: Personal Info -->
        <div id="step-1" class="space-y-5">
          <div>
            <label for="salutationName" class="field-label">Salutation</label>
            <select id="salutationName" name="salutationName" class="field-input">
              <option value="">Select salutation</option>
              <option value="Mr.">Mr.</option>
              <option value="Ms.">Ms.</option>
              <option value="Mrs.">Mrs.</option>
              <option value="Dr.">Dr.</option>
              <option value="Prof.">Prof.</option>
            </select>
          </div>
          <div>
            <label for="firstName" class="field-label">First Name <span class="text-[#775a19]">*</span></label>
            <input id="firstName" type="text" name="firstName" required class="field-input" placeholder="Your first name" />
          </div>
          <div>
            <label for="lastName" class="field-label">Last Name <span class="text-[#775a19]">*</span></label>
            <input id="lastName" type="text" name="lastName" required class="field-input" placeholder="Your last name" />
          </div>
          <div>
            <label for="middleName" class="field-label">Middle Name</label>
            <input id="middleName" type="text" name="middleName" class="field-input" placeholder="Your middle name (optional)" />
          </div>
          <div>
            <label for="emailAddress" class="field-label">Email Address <span class="text-[#775a19]">*</span></label>
            <input id="emailAddress" type="email" name="emailAddress" class="field-input" placeholder="your@company.com" />
          </div>
          <div>
            <label for="phoneNumber" class="field-label">Phone Number <span class="text-[#775a19]">*</span></label>
            <input id="phoneNumber" type="tel" name="phoneNumber" class="field-input" placeholder="+91 00000 00000" />
            <p class="text-xs text-[#5a6a85] mt-1">* Please provide either an email address or phone number</p>
          </div>
          <div class="flex justify-end pt-2">
            <button type="button" id="next-1" class="btn-primary">Next Step</button>
          </div>
        </div>

        <!-- STEP 2: Company & Address -->
        <div id="step-2" class="space-y-5 hidden">
          <div>
            <label for="accountName" class="field-label">Company Name</label>
            <input id="accountName" type="text" name="accountName" class="field-input" placeholder="Your company name" />
          </div>
          <div>
            <label for="addressStreet" class="field-label">Street Address</label>
            <input id="addressStreet" type="text" name="addressStreet" class="field-input" placeholder="Street address" />
          </div>
          <div>
            <label for="addressCity" class="field-label">City</label>
            <input id="addressCity" type="text" name="addressCity" class="field-input" placeholder="City" />
          </div>
          <div>
            <label for="addressState" class="field-label">State / Province</label>
            <input id="addressState" type="text" name="addressState" class="field-input" placeholder="State or Province" />
          </div>
          <div>
            <label for="addressCountry" class="field-label">Country</label>
            <input id="addressCountry" type="text" name="addressCountry" class="field-input" placeholder="Country" />
          </div>
          <div>
            <label for="addressPostalCode" class="field-label">Postal Code</label>
            <input id="addressPostalCode" type="text" name="addressPostalCode" class="field-input" placeholder="Postal/ZIP code" />
          </div>
          <div class="flex justify-between pt-2">
            <button type="button" id="prev-2" class="btn-secondary">Previous</button>
            <button type="button" id="next-2" class="btn-primary">Next Step</button>
          </div>
        </div>

        <!-- STEP 3: Business Details -->
        <div id="step-3" class="space-y-5 hidden">
          <div>
            <label for="cBusinessType" class="field-label">Business Type</label>
            <select id="cBusinessType" name="cBusinessType" class="field-input">
              <option value="">Select business type</option>
              <option value="fabric-importer">Fabric Importer</option>
              <option value="fabric-exporter">Fabric Exporter</option>
              <option value="garment-manufacturer">Garment Manufacturer</option>
              <option value="retailer">Retailer</option>
              <option value="wholesaler">Wholesaler</option>
              <option value="buying-agent">Buying Agent</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div>
            <label for="cFabricCategory" class="field-label">Fabric Category</label>
            <select id="cFabricCategory" name="cFabricCategory" class="field-input">
              <option value="">Select fabric category</option>
              <option value="cotton">Cotton</option>
              <option value="denim">Denim</option>
              <option value="polyester">Polyester</option>
              <option value="knit">Knit</option>
              <option value="woven">Woven</option>
              <option value="blended">Blended</option>
              <option value="other">Other</option>
            </select>
          </div>
          <div>
            <label for="opportunityAmount" class="field-label">Opportunity Amount</label>
            <div class="flex gap-3">
              <input id="opportunityAmount" type="number" name="opportunityAmount" class="field-input flex-1" placeholder="0.00" min="0" step="0.01" />
              <label for="opportunityAmountCurrency" class="sr-only">Currency</label>
              <select id="opportunityAmountCurrency" name="opportunityAmountCurrency" class="field-input w-28">
                <option value="USD">USD</option>
                <option value="INR">INR</option>
                <option value="EUR">EUR</option>
                <option value="GBP">GBP</option>
              </select>
            </div>
          </div>
          <div>
            <label for="description" class="field-label">Description</label>
            <textarea id="description" name="description" rows="4" class="field-input resize-none" placeholder="Please describe your requirements, specifications, or any additional information"></textarea>
          </div>

          <div id="form-success" class="hidden px-4 py-3 bg-green-50 border border-green-200 text-green-800 text-sm rounded">
            Thank you! Your inquiry has been received. We'll be in touch shortly.
          </div>
          <div id="form-error" class="hidden px-4 py-3 bg-red-50 border border-red-200 text-red-800 text-sm rounded">
            Something went wrong. Please try again or email us directly.
          </div>

          <div class="flex justify-between pt-2">
            <button type="button" id="prev-3" class="btn-secondary">Previous</button>
            <button type="submit" id="form-submit" class="btn-primary">Submit Request</button>
          </div>
        </div>
      </form>
    </div>
  </div>
</section>

<style>
  .field-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #041632;
    margin-bottom: 0.5rem;
  }
  .field-input {
    width: 100%;
    border: 1px solid #d1d5db;
    border-radius: 0.25rem;
    padding: 0.75rem 1rem;
    font-size: 0.875rem;
    color: #041632;
    background: white;
    outline: none;
    transition: border-color 0.2s;
  }
  .field-input:focus {
    border-color: #041632;
  }
  .btn-primary {
    background: #041632;
    color: white;
    padding: 0.75rem 2rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
  }
  .btn-primary:hover {
    background: #775a19;
  }
  .btn-primary:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .btn-secondary {
    background: white;
    color: #041632;
    padding: 0.75rem 2rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: 1px solid #d1d5db;
    cursor: pointer;
    transition: border-color 0.2s;
  }
  .btn-secondary:hover {
    border-color: #041632;
  }
</style>

<script>
  const LEAD_CAPTURE_URL = 'https://espo.egport.com/api/v1/LeadCapture/a4624c9bb58b8b755e3d94f1a25fc9be';
  const ESPO_API_BASE    = 'https://espo.egport.com/api/v1';
  const ESPO_API_KEY     = 'a4624c9bb58b8b755e3d94f1a25fc9be';

  const form      = document.getElementById('msf') as HTMLFormElement;
  const stepEls   = [document.getElementById('step-1')!, document.getElementById('step-2')!, document.getElementById('step-3')!];
  const dots      = [document.getElementById('step-dot-1')!, document.getElementById('step-dot-2')!, document.getElementById('step-dot-3')!];
  const lines     = [document.getElementById('step-line-1')!, document.getElementById('step-line-2')!];
  const stepLabel = document.getElementById('step-label')!;

  let current = 0;
  let leadId: string | null = null;
  let isSaving = false;

  // ── helpers ───────────────────────────────────────────────────────────────────

  const g = (name: string): string =>
    (form.querySelector(`[name="${name}"]`) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement)?.value?.trim() ?? '';

  function collectAllFilledFields(): Record<string, unknown> {
    const payload: Record<string, unknown> = {};
    const textFields = [
      'salutationName','firstName','lastName','middleName',
      'emailAddress','phoneNumber','accountName',
      'addressStreet','addressCity','addressState','addressCountry','addressPostalCode',
      'description',
    ];
    for (const f of textFields) {
      const v = g(f);
      if (v) payload[f] = v;
    }
    const businessType   = g('cBusinessType');
    const fabricCategory = g('cFabricCategory');
    const amount         = g('opportunityAmount');
    if (businessType)   payload.cBusinessType   = [businessType];
    if (fabricCategory) payload.cFabricCategory = [fabricCategory];
    if (amount)         payload.opportunityAmount = parseFloat(amount);
    const currency = g('opportunityAmountCurrency');
    if (currency)       payload.opportunityAmountCurrency = currency;
    return payload;
  }

  // ── upsert to EspoCRM ─────────────────────────────────────────────────────────
  // First blur with any data → POST LeadCapture (creates record, stores id)
  // Every subsequent blur   → PATCH /Lead/{id} (updates same record, no duplicate)

  async function syncToEspo() {
    if (isSaving) return;
    const payload = collectAllFilledFields();
    // Need at least one meaningful field before creating a record
    if (!payload.firstName && !payload.emailAddress && !payload.phoneNumber) return;

    isSaving = true;
    try {
      if (!leadId) {
        const res = await fetch(LEAD_CAPTURE_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (res.ok) {
          const json = await res.json().catch(() => ({}));
          if (json?.id) leadId = json.id;
        }
      } else {
        await fetch(`${ESPO_API_BASE}/Lead/${leadId}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json', 'X-Api-Key': ESPO_API_KEY },
          body: JSON.stringify(payload),
        });
      }
    } catch {
      // Silent — never interrupt the user
    } finally {
      isSaving = false;
    }
  }

  // Attach blur listener to every field in the form
  form.querySelectorAll<HTMLElement>('input, select, textarea').forEach((el) => {
    el.addEventListener('blur', () => {
      if ((el as HTMLInputElement).name === '_hp') return; // skip honeypot
      syncToEspo();
    });
  });

  // ── stepper UI ────────────────────────────────────────────────────────────────

  function goTo(n: number) {
    stepEls[current].classList.add('hidden');
    current = n;
    stepEls[current].classList.remove('hidden');
    stepLabel.textContent = `Step ${current + 1} of 3`;
    dots.forEach((dot, i) => {
      if (i <= current) {
        dot.classList.remove('border-2', 'border-[#d1d5db]', 'text-[#9ca3af]');
        dot.classList.add('bg-[#041632]', 'text-white');
      } else {
        dot.classList.add('border-2', 'border-[#d1d5db]', 'text-[#9ca3af]');
        dot.classList.remove('bg-[#041632]', 'text-white');
      }
    });
    lines.forEach((line, i) => {
      line.classList.toggle('bg-[#041632]', i < current);
      line.classList.toggle('bg-[#d1d5db]', i >= current);
    });
  }

  function validateStep1(): boolean {
    if (!g('firstName') || !g('lastName')) { alert('Please enter your first and last name.'); return false; }
    if (!g('emailAddress') && !g('phoneNumber')) { alert('Please provide at least an email or phone number.'); return false; }
    return true;
  }

  document.getElementById('next-1')!.addEventListener('click', () => { if (validateStep1()) goTo(1); });
  document.getElementById('prev-2')!.addEventListener('click', () => goTo(0));
  document.getElementById('next-2')!.addEventListener('click', () => goTo(2));
  document.getElementById('prev-3')!.addEventListener('click', () => goTo(1));

  // ── final submit ──────────────────────────────────────────────────────────────

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if ((form.querySelector('[name="_hp"]') as HTMLInputElement).value) return;

    const submitBtn  = document.getElementById('form-submit') as HTMLButtonElement;
    const successMsg = document.getElementById('form-success')!;
    const errorMsg   = document.getElementById('form-error')!;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending...';
    successMsg.classList.add('hidden');
    errorMsg.classList.add('hidden');

    const payload = collectAllFilledFields();

    try {
      if (leadId) {
        // Record already exists — just update it with final data
        const res = await fetch(`${ESPO_API_BASE}/Lead/${leadId}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json', 'X-Api-Key': ESPO_API_KEY },
          body: JSON.stringify(payload),
        });
        if (!res.ok) throw new Error(`${res.status}`);
      } else {
        // No partial save happened yet — create fresh
        const res = await fetch(LEAD_CAPTURE_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (!res.ok) throw new Error(`${res.status}`);
      }

      form.reset();
      leadId = null;
      goTo(0);
      successMsg.classList.remove('hidden');
    } catch {
      errorMsg.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit Request';
    }
  });
</script>
