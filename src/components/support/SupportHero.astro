---
import Breadcrumbs from "../common/Breadcrumbs.astro";

interface Props {
  image?: string | null;
  breadcrumbs?: { name: string; href?: string }[];
}
const { image, breadcrumbs } = Astro.props;
const FALLBACK_IMAGE = "https://images.unsplash.com/photo-1521737604893-d14cc237f11d?w=800&q=60&fm=webp";
const heroImage = image ?? FALLBACK_IMAGE;
---
<header class="support-hero relative flex flex-col bg-[#041632]" style="padding-top:2px">
  <style>
    .support-hero {
      min-height: calc(100dvh - 94px);
    }
    @media (min-width: 768px) {
      .support-hero { min-height: calc(100dvh - 102px); }
    }
    .support-gold-text {
      background: linear-gradient(to right, #fed488, #ffdea5);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      color: transparent;
    }
  </style>

  <!-- Background -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <img
      src={heroImage}
      alt="Support team at work"
      title="Support team at work"
      width="800"
      height="525"
      class="w-full h-full object-cover opacity-30"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-[#041632] via-[#041632]/80 to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-[#041632]/60 via-transparent to-transparent"></div>
  </div>

  <!-- Main content -->
  <div class="relative z-10 flex-1 max-w-7xl mx-auto px-6 md:px-8 w-full py-6 md:py-10 flex flex-col justify-between">
    <div class="max-w-2xl">
      {breadcrumbs && breadcrumbs.length > 1 && (
        <div class="mb-4">
          <Breadcrumbs items={breadcrumbs} variant="dark" />
        </div>
      )}
      <span class="inline-block px-4 py-1 mb-4 border border-[#775a19] text-[#ffdea5] font-sans text-xs tracking-[0.2em] uppercase">
        Global Operations Support
      </span>
      <h1 class="font-serif text-5xl md:text-7xl leading-tight mb-6">
        <span class="text-white">Support &amp; Contact</span><br/>
        <span class="italic support-gold-text">Us Anytime.</span>
      </h1>
      <p class="text-[#8393b5] text-lg md:text-xl leading-relaxed font-light max-w-xl mb-8">
        Direct access to technical experts and supply chain coordinators across the globe. We ensure your production line never stops — 24 hours a day, 7 days a week.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="#channels"
          class="inline-flex items-center justify-center gap-2 bg-[#775a19] text-white px-8 py-4 font-sans uppercase tracking-widest text-sm hover:bg-[#ffdea5] hover:text-[#041632] transition-all group"
        >
          Get Support Now
          <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">arrow_forward</span>
        </a>
        <a
          href="/support#contact"
          class="inline-flex items-center justify-center gap-2 bg-white/5 border border-white/20 text-white px-8 py-4 font-sans uppercase tracking-widest text-sm hover:bg-white/10 transition-all"
        >
          Send a Message
        </a>
      </div>
    </div>

    <!-- Stats bar -->
    <div class="mt-10 pt-6 border-t border-white/10 grid grid-cols-2 md:grid-cols-4 gap-6">
      <div class="flex flex-col items-center text-center md:items-start md:text-left">
        <p class="font-serif text-2xl md:text-3xl text-white font-bold">24/7</p>
        <p class="font-sans text-[10px] text-[#8393b5] uppercase tracking-widest mt-1">Expert Access</p>
      </div>
      <div class="flex flex-col items-center text-center md:items-start md:text-left">
        <p class="font-serif text-2xl md:text-3xl text-white font-bold">1 hr</p>
        <p class="font-sans text-[10px] text-[#8393b5] uppercase tracking-widest mt-1">Acknowledgement</p>
      </div>
      <div class="flex flex-col items-center text-center md:items-start md:text-left">
        <p class="font-serif text-2xl md:text-3xl text-white font-bold">98.4%</p>
        <p class="font-sans text-[10px] text-[#8393b5] uppercase tracking-widest mt-1">On-Time Resolution</p>
      </div>
      <div class="flex flex-col items-center text-center md:items-start md:text-left">
        <p class="font-serif text-2xl md:text-3xl text-[#ffdea5] font-bold">24 hrs</p>
        <p class="font-sans text-[10px] text-[#8393b5] uppercase tracking-widest mt-1">Full Resolution</p>
      </div>
    </div>
  </div>
</header>
