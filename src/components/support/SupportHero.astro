---
import ResponsiveImage from "../common/ResponsiveImage.astro";

interface Props {
  image?: string | null;
}
const { image } = Astro.props;
const FALLBACK_IMAGE = "https://images.unsplash.com/photo-1521737604893-d14cc237f11d?w=800&q=60&fm=webp";
const heroImage = image ?? FALLBACK_IMAGE;
---
<style>
  .gold-text {
    background: linear-gradient(to right, #775a19, #fed488);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: transparent;
  }
</style>
<header class="relative flex flex-col overflow-hidden bg-[#041632] pt-16">
  <!-- Background image -->
  <div class="absolute inset-0 opacity-30 pointer-events-none">
    <ResponsiveImage
      src={heroImage}
      alt="Support team at work"
      title="Support team at work"
      width={800}
      height={525}
      widths={[480, 640, 800, 1024, 1280]}
      sizes="100vw"
      crop="fill"
      class="w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-[#041632] via-[#041632]/80 to-transparent"></div>
  </div>

  <!-- Main content -->
  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-8 w-full py-16 md:py-24">
    <div class="max-w-2xl">
      <span class="inline-block px-4 py-1 mb-6 border border-[#775a19] text-[#ffdea5] font-sans text-xs tracking-[0.2em] uppercase">
        Global Operations Support
      </span>
      <h1 class="font-serif text-4xl sm:text-5xl md:text-7xl leading-tight mb-6 !text-white">
        <span class="text-white">Support &amp; Contact</span><br/>
        <span class="italic gold-text">Us Anytime</span>
      </h1>
      <p class="text-[#8393b5] text-base md:text-xl leading-relaxed font-light mb-10 max-w-lg">
        Direct access to technical experts and supply chain coordinators. We ensure your production line never stops.
      </p>
      <a
        href="#channels"
        class="inline-flex items-center gap-2 bg-[#775a19] text-white px-8 py-4 font-sans uppercase tracking-widest text-sm hover:bg-[#ffdea5] hover:text-[#041632] transition-all group"
      >
        Get Support Now
        <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">arrow_forward</span>
      </a>
    </div>
  </div>

  <!-- Stats strip — always below content, never overlapping -->
  <div class="relative z-10 bg-[#1b2b48]/90 border-t border-white/10 mt-auto">
    <div class="max-w-7xl mx-auto px-6 md:px-8 py-5 grid grid-cols-2 md:grid-cols-4 gap-6">
      <div>
        <p class="font-serif text-2xl md:text-3xl text-white font-bold">24/7</p>
        <p class="font-sans text-[10px] text-[#8393b5] uppercase tracking-widest mt-1">Expert Access</p>
      </div>
      <div>
        <p class="font-serif text-2xl md:text-3xl text-white font-bold">1 hr</p>
        <p class="font-sans text-[10px] text-[#8393b5] uppercase tracking-widest mt-1">Acknowledgement</p>
      </div>
      <div>
        <p class="font-serif text-2xl md:text-3xl text-white font-bold">98.4%</p>
        <p class="font-sans text-[10px] text-[#8393b5] uppercase tracking-widest mt-1">On-Time Resolution</p>
      </div>
      <div>
        <p class="font-serif text-2xl md:text-3xl text-[#ffdea5] font-bold">24 hrs</p>
        <p class="font-sans text-[10px] text-[#8393b5] uppercase tracking-widest mt-1">Full Resolution</p>
      </div>
    </div>
  </div>
</header>
