---
import { getCompanyInfo, buildWaLink, buildPhoneHref } from "../../lib/api";

const company = await getCompanyInfo("AGE");
const whatsappHref = buildWaLink(company?.whatsappNumber);
const supportEmail = company?.supportEmail ?? null;
---
<section class="py-20 md:py-28 px-8 bg-[#f3f4f5]">
  <div class="max-w-7xl mx-auto bg-[#041632] rounded-lg p-12 md:p-20 text-center relative overflow-hidden">
    <div class="absolute inset-0 opacity-10 pointer-events-none">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_#775a19,_transparent_70%)]"></div>
    </div>
    <div class="relative z-10">
      <span class="inline-block px-4 py-1 mb-6 border border-[#775a19] text-[#ffdea5] font-sans text-xs tracking-[0.2em] uppercase">
        Priority Escalation
      </span>
      <h2 class="font-serif text-3xl md:text-5xl !text-white mb-6 leading-tight">
        Need Immediate<br/>
        <span class="italic" style="background: linear-gradient(to right, #775a19, #fed488); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Technical Intervention?</span>
      </h2>
      <p class="text-[#8393b5] text-base max-w-xl mx-auto mb-10">
        Integrated digital support desk with manufacturing floor updates. Our team is standing by.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        {whatsappHref && (
          <a
            href={whatsappHref}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 bg-[#775a19] text-white px-8 py-4 font-sans uppercase tracking-widest text-sm hover:bg-[#ffdea5] hover:text-[#041632] transition-all"
          >
            WhatsApp Now
            <span class="material-symbols-outlined text-sm">chat_bubble</span>
          </a>
        )}
        {supportEmail && (
          <a
            href={`mailto:${supportEmail}`}
            class="inline-flex items-center justify-center gap-2 border border-white/30 text-white px-8 py-4 font-sans uppercase tracking-widest text-sm hover:border-[#775a19] hover:text-[#ffdea5] transition-all"
          >
            Send Email
            <span class="material-symbols-outlined text-sm">mail</span>
          </a>
        )}
      </div>
    </div>
  </div>
</section>
