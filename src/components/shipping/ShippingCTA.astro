---
import { getCompanyInfo, buildPhoneHref } from "../../lib/api";

const companyInfo = await getCompanyInfo();
const phoneHref = buildPhoneHref(companyInfo?.phone1 ?? companyInfo?.phone2);
---
<section class="px-6 py-16 bg-white">
  <div class="max-w-7xl mx-auto">
    <div class="bg-[#041632] p-8 md:p-16 text-center relative overflow-hidden">
      <div class="pointer-events-none absolute inset-0 bg-gradient-to-tr from-[#041632] to-[#1b2b48] opacity-50"></div>
      <div class="relative z-10">
        <h2 class="font-headline text-3xl text-white mb-4 italic">Request a Logistics Quote</h2>
        <p class="text-[#8393b5] mb-8 text-sm">
          Speak with our global supply chain experts for a tailored shipping plan.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a
            href="/support"
            class="inline-block bg-[#775a19] text-white px-8 py-4 font-bold font-label uppercase text-sm tracking-widest hover:bg-[#fed488] hover:text-[#041632] transition-colors"
            onclick="window.gtag?.('event','cta_click',{event_label:'Consult with Experts',section:'shipping_cta',page_path:window.location.pathname})"
          >
            Consult with Experts
          </a>
          {phoneHref && (
            <a
              href={phoneHref}
              class="inline-flex items-center gap-2 border border-white text-white px-8 py-4 font-bold font-label uppercase text-sm tracking-widest hover:bg-white hover:text-[#041632] transition-colors"
              onclick="window.gtag?.('event','cta_click',{event_label:'Call Now',section:'shipping_cta',page_path:window.location.pathname})"
            >
              <span class="material-symbols-outlined text-base">call</span>
              Call Now
            </a>
          )}
        </div>
      </div>
    </div>
  </div>
</section>
