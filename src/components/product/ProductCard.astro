---
import CloudinaryImage from "../common/CloudinaryImage.astro";

interface Product {
  id: string;
  name: string;
  category: string;
  weight: string;
  width: string;
  color: string;
  image: string;
  imageSrcset?: string;
  href: string | null;
  filterCategory?: string;
  filterColor?: string;
  filterStructure?: string;
  filterContent?: string;
  filterGsm?: string;
  filterDesign?: string;
  filterFinish?: string;
}

interface Props {
  product: Product;
}

const { product } = Astro.props;
---

<article
  class="product-card group cursor-pointer overflow-hidden rounded bg-white shadow-sm transition-all hover:shadow-xl"
  data-category={product.filterCategory ?? product.category}
  data-color={product.filterColor ?? ""}
  data-structure={product.filterStructure ?? ""}
  data-content={product.filterContent ?? ""}
  data-design={product.filterDesign ?? ""}
  data-finish={product.filterFinish ?? ""}
  data-gsm={product.filterGsm ?? "0"}
>
  <a href={product.href ?? undefined} class={`block${!product.href ? " pointer-events-none" : ""}`}>
    <div class="relative h-64 overflow-hidden">
      <CloudinaryImage
        src={product.image}
        alt={product.name}
        title={product.name}
        width={400}
        height={267}
        widths={[320, 400, 560, 720, 880]}
        sizes="(max-width: 768px) 100vw, (max-width: 1280px) 50vw, 33vw"
        crop="fill"
        loading="lazy"
        class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
      />
      <span class="absolute right-4 top-4 bg-[#041632] px-2 py-1 text-[10px] font-mono uppercase tracking-widest text-white">
        ID: {product.id}
      </span>
    </div>

    <div class="p-6">
      <div class="mb-2 flex items-start justify-between">
        <h3 class="font-headline italic text-base text-[#041632] leading-snug">{product.name}</h3>
        <span
          class="mt-1 h-4 w-4 rounded-full border border-slate-300"
          style={`background:${product.color}`}
        ></span>
      </div>

      <p class="mb-4 text-sm font-label font-bold uppercase tracking-widest text-[#775a19]">
        {product.category}
      </p>

      <div class="grid grid-cols-2 gap-4 border-t border-slate-200 pt-4">
        <div>
          <p class="text-[10px] font-label uppercase tracking-wide text-slate-500">Weight</p>
          <p class="text-sm font-bold text-[#041632]">{product.weight}</p>
        </div>
        <div>
          <p class="text-[10px] font-label uppercase tracking-wide text-slate-500">Width</p>
          <p class="text-sm font-bold text-[#041632]">{product.width}</p>
        </div>
      </div>

      {product.href && (
        <div class="mt-6 w-full bg-[#041632] py-3 text-center text-xs font-label uppercase tracking-widest text-white transition hover:bg-[#775a19]">
          View Specifications
        </div>
      )}
      {!product.href && (
        <div class="mt-6 w-full bg-slate-200 py-3 text-center text-xs font-label uppercase tracking-widest text-slate-400 cursor-not-allowed">
          Slug Pending
        </div>
      )}
    </div>
  </a>
</article>