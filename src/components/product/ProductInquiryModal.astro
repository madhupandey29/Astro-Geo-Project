---
import MultiStepContactForm from "../common/MultiStepContactForm.astro";
import { getCompanyInfo } from "../../lib/api";
const LEAD_CAPTURE_URL = import.meta.env.PUBLIC_ESPO_BASE + "/LeadCapture/" + import.meta.env.PUBLIC_LEAD_CAPTURE_KEY;
const company = await getCompanyInfo("AGE");
const companyName = company?.legalName ?? "";
---

<div
  id="inquire-modal"
  class="fixed inset-0 z-[9999] flex items-center justify-center p-4 hidden"
  role="dialog"
  aria-modal="true"
  aria-labelledby="inquire-modal-title"
>
  <!-- Backdrop -->
  <div id="inquire-backdrop" class="absolute inset-0 bg-[#020d1f]/80 backdrop-blur-md"></div>

  <!-- Modal shell — split layout -->
  <div class="iqm-panel relative z-10 w-full max-w-3xl flex shadow-2xl overflow-hidden max-h-[92vh]">

    <!-- LEFT: Brand sidebar -->
    <div class="hidden md:flex flex-col justify-between w-64 shrink-0 bg-[#041632] px-7 py-8 text-white">
      <div>
        <div class="mb-8">
          <div class="flex items-center gap-3">
            <img
              src="/images/icons/my_logo.webp"
              srcset="/images/icons/my_logo.webp 1x, /images/icons/my_logo@2x.webp 2x"
              alt={companyName}
              width="40"
              height="40"
              class="h-10 w-10 object-contain flex-shrink-0"
            />
            <div class="flex flex-col">
              <span class="font-serif text-white text-[17px] italic leading-tight">{companyName}</span>
              <span class="font-serif text-[#ffdea5] text-[16px] italic tracking-wide"></span>
            </div>
          </div>
          <div class="mt-5 h-px bg-white/10"></div>
        </div>
        <p class="font-sans text-[10px] tracking-[0.3em] uppercase text-[#ffdea5] mb-2">Bulk Quote</p>
        <h2 id="inquire-modal-title" class="font-serif text-2xl italic leading-snug mb-4">
          Request a<br/>Custom Quote
        </h2>
        <p class="text-white/60 text-xs leading-relaxed">
          Fill in your details and we'll prepare a personalised bulk pricing sheet within 24 hours.
        </p>
        <div id="iqm-product-chip" class="hidden mt-6 border border-white/20 p-3">
          <p class="text-[10px] uppercase tracking-widest text-[#ffdea5] mb-1">Selected Product</p>
          <p id="inquire-product-name" class="text-xs text-white/80 leading-snug"></p>
        </div>
      </div>
      <!-- Sidebar step list -->
      <div class="space-y-3 mt-8">
        {["Contact Info", "Company", "Requirements"].map((label, i) => (
          <div class="flex items-center gap-3">
            <div class={`iqm-sidebar-dot w-6 h-6 rounded-full flex items-center justify-center text-[10px] font-bold shrink-0 transition-all duration-300 ${i === 0 ? "bg-[#775a19] text-white" : "border border-white/30 text-white/40"}`}>{i + 1}</div>
            <span class={`iqm-sidebar-label text-xs transition-colors duration-300 ${i === 0 ? "text-white font-semibold" : "text-white/40"}`}>{label}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- RIGHT: Form panel -->
    <div class="flex-1 flex flex-col bg-white overflow-y-auto">

      <!-- Top bar -->
      <div class="flex items-center justify-between px-6 py-4 border-b border-[#f0f0f0]">
        <div class="md:hidden">
          <p class="text-[10px] uppercase tracking-widest text-[#775a19] font-bold">Bulk Quote</p>
          <p id="iqf-step-label-mobile" class="text-xs text-[#44474d] font-semibold">Step 1 of 3 — Contact Info</p>
        </div>
        <div class="hidden md:flex items-center gap-2 flex-1">
          <div class="flex-1 h-1 bg-[#f0f0f0] rounded-full overflow-hidden">
            <div id="iqf-progress-bar" class="h-full bg-[#775a19] rounded-full transition-all duration-500" style="width:33%"></div>
          </div>
          <span id="iqf-progress-text" class="text-[10px] text-[#9ca3af] font-sans whitespace-nowrap">Step 1 of 3</span>
        </div>
        <button id="inquire-modal-close" class="ml-4 shrink-0 w-8 h-8 flex items-center justify-center rounded-full hover:bg-[#f3f4f5] transition-colors" aria-label="Close">
          <span class="material-symbols-outlined text-lg text-[#44474d]">close</span>
        </button>
      </div>

      <!-- MultiStepContactForm in modal variant — provides stepper + form shell -->
      <div class="flex-1 px-6 py-6">
        <MultiStepContactForm
          formId="iqf"
          variant="modal"
          steps={[{ label: "Contact Info" }, { label: "Company" }, { label: "Requirements" }]}
          successTitle="Inquiry Sent!"
          successMessage="Thank you. Our team will prepare your bulk quote and reach out within 24 hours."
        >

          <!-- STEP 1: Contact -->
          <div id="iqf-step-0" class="space-y-5">
            <div>
              <h3 class="font-serif text-lg text-[#041632] italic mb-1">Your Contact Details</h3>
              <p class="text-xs text-[#9ca3af]">We'll use this to send your quote.</p>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div class="iqm-field">
                <input id="iqf-firstName" type="text" name="firstName" required placeholder=" " class="iqm-input peer" />
                <label for="iqf-firstName" class="iqm-label">First Name <span class="text-[#775a19]">*</span></label>
              </div>
              <div class="iqm-field">
                <input id="iqf-lastName" type="text" name="lastName" required placeholder=" " class="iqm-input peer" />
                <label for="iqf-lastName" class="iqm-label">Last Name <span class="text-[#775a19]">*</span></label>
              </div>
            </div>
            <div class="iqm-field">
              <input id="iqf-email" type="email" name="emailAddress" placeholder=" " class="iqm-input peer" />
              <label for="iqf-email" class="iqm-label">Email Address <span class="text-[#775a19]">*</span></label>
            </div>
            <div class="iqm-field">
              <input id="iqf-phone" type="tel" name="phoneNumber" placeholder=" " class="iqm-input peer" />
              <label for="iqf-phone" class="iqm-label">Phone Number (e.g. +91 98765 43210)</label>
              <p class="text-[11px] text-[#9ca3af] mt-1.5 ml-1">Provide at least an email or phone number.</p>
            </div>
            <div class="msf-nav-row end pt-2">
              <button type="button" id="iqf-next-0" class="msf-btn-primary">
                Continue
                <span class="material-symbols-outlined text-base">arrow_forward</span>
              </button>
            </div>
          </div>

          <!-- STEP 2: Company -->
          <div id="iqf-step-1" class="space-y-5 hidden">
            <div>
              <h3 class="font-serif text-lg text-[#041632] italic mb-1">Company & Location</h3>
              <p class="text-xs text-[#9ca3af]">Helps us tailor pricing and logistics.</p>
            </div>
            <div class="iqm-field">
              <input id="iqf-company" type="text" name="accountName" placeholder=" " class="iqm-input peer" />
              <label for="iqf-company" class="iqm-label">Company Name</label>
            </div>
            <div class="iqm-field">
              <input id="iqf-city" type="text" name="addressCity" placeholder=" " class="iqm-input peer" />
              <label for="iqf-city" class="iqm-label">City</label>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div class="iqm-field">
                <input id="iqf-state" type="text" name="addressState" placeholder=" " class="iqm-input peer" />
                <label for="iqf-state" class="iqm-label">State</label>
              </div>
              <div class="iqm-field">
                <input id="iqf-country" type="text" name="addressCountry" placeholder=" " class="iqm-input peer" />
                <label for="iqf-country" class="iqm-label">Country</label>
              </div>
            </div>
            <div class="msf-nav-row pt-2">
              <button type="button" id="iqf-prev-1" class="msf-btn-secondary">Back</button>
              <button type="button" id="iqf-next-1" class="msf-btn-primary">
                Continue
                <span class="material-symbols-outlined text-base">arrow_forward</span>
              </button>
            </div>
          </div>

          <!-- STEP 3: Requirements -->
          <div id="iqf-step-2" class="space-y-5 hidden">
            <div>
              <h3 class="font-serif text-lg text-[#041632] italic mb-1">Order Requirements</h3>
              <p class="text-xs text-[#9ca3af]">Tell us what you need and we'll do the rest.</p>
            </div>
            <div>
              <label for="iqf-bizType" class="msf-label">Business Type</label>
              <select id="iqf-bizType" name="cBusinessType" class="msf-input">
                <option value="">Select…</option>
                <option value="fabric-importer">Fabric Importer</option>
                <option value="fabric-exporter">Fabric Exporter</option>
                <option value="garment-manufacturer">Garment Manufacturer</option>
                <option value="retailer">Retailer</option>
                <option value="wholesaler">Wholesaler</option>
                <option value="buying-agent">Buying Agent</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div>
              <label class="msf-label">Estimated Order Value</label>
              <div class="flex flex-col sm:flex-row gap-2">
                <input id="iqf-amount" type="number" name="opportunityAmount" class="msf-input flex-1" placeholder="0.00" min="0" step="0.01" />
                <select id="iqf-currency" name="opportunityAmountCurrency" class="msf-input flex-1">
                  <option value="USD">USD</option>
                  <option value="INR">INR</option>
                  <option value="EUR">EUR</option>
                  <option value="GBP">GBP</option>
                </select>
              </div>
            </div>
            <div>
              <label for="iqf-description" class="msf-label">Requirements</label>
              <textarea id="iqf-description" name="description" rows="4" class="msf-input resize-none" placeholder="Quantity, colour, finish, delivery timeline…"></textarea>
            </div>
            <div class="msf-nav-row pt-2">
              <button type="button" id="iqf-prev-2" class="msf-btn-secondary">Back</button>
              <button type="submit" id="iqf-submit" class="msf-btn-primary">
                <span id="iqf-submit-text">Send Inquiry</span>
                <span id="iqf-submit-spinner" class="material-symbols-outlined animate-spin text-base" style="display:none">progress_activity</span>
              </button>
            </div>
          </div>

        </MultiStepContactForm>
      </div>
    </div>
  </div>
</div>

<style>
  @keyframes iqm-in {
    from { opacity: 0; transform: translateY(24px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }
  .iqm-panel { animation: iqm-in 0.28s cubic-bezier(0.22,1,0.36,1) both; }

  /* Floating label inputs */
  .iqm-field { position: relative; }
  .iqm-input {
    width: 100%;
    border: 1.5px solid #e5e7eb;
    background: #fafafa;
    padding: 1.25rem 0.875rem 0.5rem;
    font-size: 0.875rem;
    color: #041632;
    outline: none;
    transition: border-color 0.2s, background 0.2s;
    border-radius: 6px;
  }
  .iqm-input:focus { border-color: #775a19; background: #fff; }
  .iqm-label {
    position: absolute;
    left: 0.875rem;
    top: 50%;
    transform: translateY(-50%);
    font-size: 0.8rem;
    color: #9ca3af;
    pointer-events: none;
    transition: all 0.18s ease;
    font-family: var(--font-sans, sans-serif);
  }
  .iqm-input:focus ~ .iqm-label,
  .iqm-input:not(:placeholder-shown) ~ .iqm-label {
    top: 0.55rem;
    transform: none;
    font-size: 0.65rem;
    color: #775a19;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
</style>

<!-- Expose LEAD_CAPTURE_URL to window so the TS script below can read it -->
<script define:vars={{ LEAD_CAPTURE_URL }}>
  window.__IQM_LEAD_URL__ = LEAD_CAPTURE_URL;
</script>

<script>
  if (!(window as any).__IQM_INIT__) {
    (window as any).__IQM_INIT__ = true;

  const LEAD_CAPTURE_URL = (window as any).__IQM_LEAD_URL__ as string;
  const FORM_ID    = 'iqf';
  const STEP_COUNT = 3;
  const stepMeta   = [
    { label: 'Contact Info', progress: 33  },
    { label: 'Company',      progress: 66  },
    { label: 'Requirements', progress: 100 },
  ];

  const modal         = document.getElementById('inquire-modal') as HTMLElement;
  const backdrop      = document.getElementById('inquire-backdrop') as HTMLElement;
  const closeBtn      = document.getElementById('inquire-modal-close') as HTMLElement;
  const openBtn       = document.getElementById('inquire-modal-open') as HTMLElement;
  const productNameEl = document.getElementById('inquire-product-name') as HTMLElement;
  const productChip   = document.getElementById('iqm-product-chip') as HTMLElement;
  const form          = document.getElementById(FORM_ID) as HTMLFormElement;
  const progressBar   = document.getElementById('iqf-progress-bar') as HTMLElement;
  const progressText  = document.getElementById('iqf-progress-text') as HTMLElement;
  const mobileLbl     = document.getElementById('iqf-step-label-mobile') as HTMLElement;
  const stepLabel     = document.getElementById(`${FORM_ID}-step-label`) as HTMLElement;
  const sidebarDots   = document.querySelectorAll<HTMLElement>('.iqm-sidebar-dot');
  const sidebarLabels = document.querySelectorAll<HTMLElement>('.iqm-sidebar-label');

  let current = 0;
  let isSubmitting = false;

  // ── open / close ──────────────────────────────────────────────────────────────
  const _gaPage = () => (window as any).location.pathname;
  const _gaForm = 'Product Inquiry Modal';
  const _gaProduct = () => (openBtn as HTMLButtonElement | null)?.dataset?.product ?? '';

  function openModal(productName = '') {
    productNameEl.textContent = productName;
    productChip.classList.toggle('hidden', !productName);
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    const slug = productName.toLowerCase().replace(/\s+/g,'_').replace(/[^a-z0-9_]/g,'').slice(0,30);
    (window as any).gtag?.('event', `inquiry_modal_opened__${slug || 'product'}__${_gaPage().replace(/\//g,'_').replace(/^_/,'')}`, { product: productName, page_path: _gaPage() });
  }
  function closeModal() {
    modal.classList.add('hidden');
    document.body.style.overflow = '';
    (window as any).gtag?.('event', `inquiry_modal_closed__step${current + 1}__${_gaPage().replace(/\//g,'_').replace(/^_/,'')}`, { step_reached: current + 1, page_path: _gaPage() });
  }

  // Original product open button
  openBtn?.addEventListener('click', () => openModal((openBtn as HTMLButtonElement).dataset.product ?? ''));
  closeBtn?.addEventListener('click', closeModal);
  backdrop?.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

  // Global event so any element (e.g. header Free Sample btn) can open the modal
  window.addEventListener('iqm:open', (e) => {
    openModal((e as CustomEvent).detail?.product ?? '');
  });

  // ── helpers ───────────────────────────────────────────────────────────────────
  const g = (name: string): string =>
    (form.querySelector(`[name="${name}"]`) as HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement)?.value?.trim() ?? '';

  function collectPayload(): Record<string, unknown> {
    const payload: Record<string, unknown> = {};
    ['firstName','lastName','emailAddress','accountName',
     'addressCity','addressState','addressCountry'].forEach(f => {
      const v = g(f); if (v) payload[f] = v;
    });
    const bt = g('cBusinessType'), am = g('opportunityAmount'), cur = g('opportunityAmountCurrency');
    if (bt)  payload.cBusinessType = [bt];
    if (am)  payload.opportunityAmount = parseFloat(am);
    if (cur) payload.opportunityAmountCurrency = cur;
    // Build description — include phone and product name here to avoid CRM field validation
    const parts: string[] = [];
    const pn = (openBtn as HTMLButtonElement | null)?.dataset?.product ?? '';
    if (pn) parts.push(`Product: ${pn}`);
    const rawPhone = g('phoneNumber');
    if (rawPhone) parts.push(`Phone: ${rawPhone}`);
    const desc = g('description');
    if (desc) parts.push(desc);
    if (parts.length) payload.description = parts.join('\n');
    return payload;
  }

  // ── stepper ───────────────────────────────────────────────────────────────────
  function goTo(n: number) {
    (document.getElementById(`${FORM_ID}-step-${current}`) as HTMLElement).classList.add('hidden');
    current = n;
    (document.getElementById(`${FORM_ID}-step-${current}`) as HTMLElement).classList.remove('hidden');

    const meta = stepMeta[current];
    progressBar.style.width = `${meta.progress}%`;
    progressText.textContent = `Step ${current + 1} of ${STEP_COUNT}`;
    mobileLbl.textContent = `Step ${current + 1} of ${STEP_COUNT} — ${meta.label}`;
    stepLabel.textContent = meta.label;

    for (let i = 0; i < STEP_COUNT; i++) {
      const dot = document.getElementById(`${FORM_ID}-dot-${i}`) as HTMLElement;
      if (i <= current) {
        dot.classList.remove('border-2','border-[#d1d5db]','text-[#9ca3af]');
        dot.classList.add('bg-[#041632]','text-white');
      } else {
        dot.classList.add('border-2','border-[#d1d5db]','text-[#9ca3af]');
        dot.classList.remove('bg-[#041632]','text-white');
      }
    }
    for (let i = 0; i < STEP_COUNT - 1; i++) {
      const line = document.getElementById(`${FORM_ID}-line-${i}`) as HTMLElement;
      line.classList.toggle('bg-[#041632]', i < current);
      line.classList.toggle('bg-[#d1d5db]', i >= current);
    }

    sidebarDots.forEach((dot, i) => {
      dot.classList.toggle('bg-[#775a19]', i <= current);
      dot.classList.toggle('text-white', i <= current);
      dot.classList.toggle('border', i > current);
      dot.classList.toggle('border-white/30', i > current);
      dot.classList.toggle('text-white/40', i > current);
    });
    sidebarLabels.forEach((lbl, i) => {
      lbl.classList.toggle('text-white', i <= current);
      lbl.classList.toggle('font-semibold', i === current);
      lbl.classList.toggle('text-white/40', i > current);
    });
  }

  function validateStep0(): boolean {
    if (!g('firstName') || !g('lastName')) { alert('Please enter your first and last name.'); return false; }
    if (!g('emailAddress') && !g('phoneNumber')) { alert('Please provide at least an email or phone number.'); return false; }
    return true;
  }

  (document.getElementById(`${FORM_ID}-next-0`) as HTMLElement).addEventListener('click', () => {
    if (validateStep0()) { goTo(1); (window as any).gtag?.('event', `inquiry_modal_step2_company__${_gaPage().replace(/\//g,'_').replace(/^_/,'')}`, { product: _gaProduct(), page_path: _gaPage() }); }
  });
  (document.getElementById(`${FORM_ID}-prev-1`) as HTMLElement).addEventListener('click', () => goTo(0));
  (document.getElementById(`${FORM_ID}-next-1`) as HTMLElement).addEventListener('click', () => {
    goTo(2); (window as any).gtag?.('event', `inquiry_modal_step3_requirements__${_gaPage().replace(/\//g,'_').replace(/^_/,'')}`, { product: _gaProduct(), page_path: _gaPage() });
  });
  (document.getElementById(`${FORM_ID}-prev-2`) as HTMLElement).addEventListener('click', () => goTo(1));

  // ── submit ────────────────────────────────────────────────────────────────────
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if ((form.querySelector('[name="_hp"]') as HTMLInputElement).value) return;

    const submitBtn  = document.getElementById(`${FORM_ID}-submit`) as HTMLButtonElement;
    const submitText = document.getElementById(`${FORM_ID}-submit-text`) as HTMLElement;
    const spinner    = document.getElementById(`${FORM_ID}-submit-spinner`) as HTMLElement;
    const errorEl    = document.getElementById(`${FORM_ID}-error`) as HTMLElement;
    const successEl  = document.getElementById(`${FORM_ID}-success`) as HTMLElement;

    isSubmitting = true;
    submitBtn.disabled = true;
    submitText.textContent = 'Sending…';
    spinner.style.display = '';
    errorEl.classList.add('hidden');
    (window as any).gtag?.('event', `inquiry_modal_submitted__${_gaPage().replace(/\//g,'_').replace(/^_/,'')}`, { product: _gaProduct(), page_path: _gaPage() });

    const resetBtn = () => {
      submitBtn.disabled = false;
      submitText.textContent = 'Send Inquiry';
      spinner.style.display = 'none';
      isSubmitting = false;
    };

    try {
      const payload = collectPayload();
      const ctrl = new AbortController();
      const timer = setTimeout(() => ctrl.abort(), 8000);
      let res: Response;
      try {
        res = await fetch(LEAD_CAPTURE_URL, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
          signal: ctrl.signal,
        });
      } finally {
        clearTimeout(timer);
      }

      if (!res!.ok) {
        let detail = '';
        try { detail = await res!.text(); } catch { /* ignore */ }
        console.error('[IQM] API error', res!.status, detail);
        throw new Error(`API error ${res!.status}${detail ? ': ' + detail : ''}`);
      }

      form.reset();
      (document.getElementById(`${FORM_ID}-step-${current}`) as HTMLElement).classList.add('hidden');
      spinner.style.display = 'none';
      submitBtn.disabled = false;
      isSubmitting = false;
      successEl.classList.remove('hidden');
      progressBar.style.width = '100%';
      (window as any).gtag?.('event', `inquiry_modal_success__${_gaPage().replace(/\//g,'_').replace(/^_/,'')}`, { product: _gaProduct(), page_path: _gaPage() });
    } catch (err: unknown) {
      let msg = 'Something went wrong. Please try again.';
      if (err instanceof Error) {
        if (err.name === 'AbortError') msg = 'Request timed out. Please try again.';
        else if (err.message) msg = err.message;
      }
      console.error('[IQM] Submit error:', err);
      errorEl.textContent = msg;
      errorEl.classList.remove('hidden');
      (window as any).gtag?.('event', `inquiry_modal_error__${_gaPage().replace(/\//g,'_').replace(/^_/,'')}`, { error_message: msg, page_path: _gaPage() });
      resetBtn();
    }
  });

  } // end __IQM_INIT__ guard
</script>
