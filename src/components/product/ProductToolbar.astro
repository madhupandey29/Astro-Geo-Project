---
interface Props {
  total: number;
  showingStart: number;
  showingEnd: number;
}

const { total, showingStart, showingEnd } = Astro.props;
---

<div class="mb-8 flex flex-col gap-4 rounded bg-white p-4 shadow-sm sm:flex-row sm:items-center sm:justify-between">
  <span class="text-sm font-label text-slate-600">
    Showing {showingStart}-{showingEnd} of {total} textiles
  </span>

  <div class="flex w-full items-center justify-between gap-4 sm:w-auto">
    <span class="text-xs font-label uppercase tracking-widest text-slate-500" id="sort-label">Sort By:</span>
    <select aria-labelledby="sort-label" class="border-none bg-transparent text-sm font-bold text-[#041632] focus:ring-0 cursor-pointer">
      <option>Latest Arrivals</option>
      <option>GSM: High to Low</option>
      <option>GSM: Low to High</option>
    </select>
  </div>
</div>