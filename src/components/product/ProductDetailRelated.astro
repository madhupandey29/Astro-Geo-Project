---
import type { Product } from "../../data/products";
import { buildWaLink, buildPhoneHref } from "../../lib/api";
import { buildCloudinarySrcset } from "../../data/products";

interface Props {
  product: Product;
  collectionProducts?: Product[];
  whatsapp?: string | null;
  phone?: string | null;
}
const { product, collectionProducts = [], whatsapp, phone } = Astro.props;

const whatsappHref = buildWaLink(whatsapp);
const phoneHref = buildPhoneHref(phone);
const hasMore = collectionProducts.length > 4;
---

<section class="max-w-7xl mx-auto px-4 lg:px-8 py-16 lg:py-20">
  <div class="flex justify-between items-end mb-10">
    <h2 class="font-serif text-2xl lg:text-3xl font-bold">Related Fabric Options</h2>
    <a href="/fabric" class="text-[#775a19] font-bold text-sm lg:text-base underline">View Collection</a>
  </div>

  {collectionProducts.length > 0 ? (
    <div class="relative">
      <div
        id="related-scroll"
        class="flex gap-4 lg:gap-6 overflow-x-auto snap-x snap-mandatory scroll-smooth pb-4 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden"
      >
        {collectionProducts.map((rel) => rel.slug && (
          <a
            href={`/fabric/${rel.slug}`}
            class="group block flex-none snap-start"
            style="width: calc(50% - 8px); min-width: 150px; max-width: 260px;"
          >
            <div class="aspect-[3/2] bg-[#e7e8e9] mb-3 overflow-hidden group-hover:opacity-80 transition-opacity">
              {rel.image1 ? (
                <picture>
                  <source
                    type="image/avif"
                    srcset={rel.image1Srcset
                      ? rel.image1Srcset.replace(/f_auto/g, "f_avif")
                      : buildCloudinarySrcset(rel.image1, [200, 400, 600], 3, 2, "fill").replace(/f_auto/g, "f_avif")}
                    sizes="(max-width: 768px) 50vw, 25vw"
                  />
                  <source
                    type="image/webp"
                    srcset={rel.image1Srcset
                      ? rel.image1Srcset.replace(/f_auto/g, "f_webp")
                      : buildCloudinarySrcset(rel.image1, [200, 400, 600], 3, 2, "fill").replace(/f_auto/g, "f_webp")}
                    sizes="(max-width: 768px) 50vw, 25vw"
                  />
                  <img
                    src={rel.image || rel.image1}
                    srcset={rel.image1Srcset || buildCloudinarySrcset(rel.image1, [200, 400, 600], 3, 2, "fill") || undefined}
                    sizes="(max-width: 768px) 50vw, 25vw"
                    alt={rel.imageAlt ?? rel.name}
                    title={rel.imageAlt ?? rel.name}
                    width="400"
                    height="267"
                    class="w-full h-full object-cover"
                    loading="lazy"
                    decoding="async"
                  />
                </picture>
              ) : (
                <div class="w-full h-full flex items-center justify-center">
                  <span class="material-symbols-outlined text-4xl text-[#c5c6ce]">image</span>
                </div>
              )}
            </div>
            <h3 class="font-bold text-xs lg:text-sm leading-snug">{rel.name}</h3>
            <p class="text-[10px] lg:text-xs text-[#44474d] font-sans mt-1">{rel.specs.weight} • {rel.specs.weave}</p>
          </a>
        ))}
      </div>

      {hasMore && (
        <div class="absolute right-0 top-0 w-10 lg:w-14 pointer-events-none" style="height: calc((100% - 1rem) * 3/5);">
          <button
            id="scroll-right-btn"
            class="pointer-events-auto absolute right-0 top-1/2 -translate-y-1/2 w-7 h-7 lg:w-11 lg:h-11 bg-[#041632] text-white flex items-center justify-center hover:bg-[#374765] transition-colors"
            aria-label="Scroll right"
          >
            <span class="material-symbols-outlined text-sm lg:text-xl">chevron_right</span>
          </button>
        </div>
      )}
    </div>
  ) : (
    <p class="text-[#44474d] font-sans text-sm">No related products found in this collection.</p>
  )}
</section>

<section class="max-w-5xl mx-auto px-4 lg:px-8 py-10 mb-10 lg:mb-20">
  <div class="bg-[#775a19] p-8 lg:p-12 text-center text-white relative overflow-hidden">
    <div class="absolute top-0 right-0 p-8 opacity-10 hidden lg:block">
      <span class="material-symbols-outlined text-9xl">inbox</span>
    </div>
    <h2 class="font-serif text-3xl lg:text-4xl font-bold mb-4">Request a Quote for Bulk Supply</h2>
    <p class="mb-8 text-white text-sm lg:text-base">
      Experience the premium feel and technical excellence of {product.name.split(" ").slice(0, 2).join(" ")} in your next collection.
    </p>
    <div class="flex flex-col md:flex-row justify-center space-y-4 md:space-y-0 md:space-x-4">
      {whatsappHref && (
        <a href={whatsappHref} target="_blank" rel="noopener noreferrer" class="bg-[#041632] px-10 py-4 font-bold hover:bg-[#374765] transition-colors w-full md:w-auto text-center">
          Start Bulk Inquiry
        </a>
      )}
      {phoneHref && (
        <a href={phoneHref} class="bg-white text-[#775a19] px-10 py-4 font-bold hover:bg-[#f3f4f5] transition-colors w-full md:w-auto text-center">
          Download Data Sheet
        </a>
      )}
    </div>
  </div>
</section>

<script>
  const btn = document.getElementById('scroll-right-btn');
  const track = document.getElementById('related-scroll');
  if (btn && track) {
    btn.addEventListener('click', () => {
      track.scrollBy({ left: track.clientWidth * 0.8, behavior: 'smooth' });
    });
  }
</script>
