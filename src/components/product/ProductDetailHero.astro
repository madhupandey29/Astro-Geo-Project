---
import type { Product } from "../../data/products";
import { getCloudinaryUrl } from "../../data/products";
import ProductShareButton from "./ProductShareButton.astro";
interface Props { product: Product }
const { product } = Astro.props;

// Extract YouTube video ID for thumbnail
function getYouTubeId(url: string): string | null {
  const match = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([a-zA-Z0-9_-]{11})/);
  return match ? match[1] : null;
}

type Slot =
  | { type: "image"; src: string; srcset: string; alt: string }
  | { type: "youtube"; embedSrc: string; thumbSrc: string; alt: string }
  | { type: "video"; src: string; alt: string }
  | { type: "empty" };

function makeVideoSlot(url: string, alt: string): Slot {
  const videoId = getYouTubeId(url);
  if (videoId) return {
    type: "youtube",
    embedSrc: `https://www.youtube.com/embed/${videoId}?autoplay=0&rel=0`,
    thumbSrc: `https://img.youtube.com/vi/${videoId}/mqdefault.jpg`,
    alt,
  };
  return { type: "video", src: url, alt };
}

const slots: Slot[] = [
  product.image1
    ? { type: "image", src: product.image1, srcset: product.image1Srcset, alt: product.imageAlt ?? product.name }
    : { type: "empty" },
  product.image2
    ? { type: "image", src: product.image2, srcset: "", alt: product.imageAlt2 ?? product.name }
    : { type: "empty" },
  product.image3
    ? { type: "image", src: product.image3, srcset: "", alt: product.imageAlt3 ?? product.name }
    : { type: "empty" },
  product.collectionImage
    ? { type: "image", src: product.collectionImage, srcset: product.collectionImageSrcset, alt: product.collectionImageAlt ?? product.collectionName }
    : { type: "empty" },
  product.collectionVideoURL
    ? makeVideoSlot(product.collectionVideoURL, "Collection Video")
    : { type: "empty" },
];

// Main slides = only non-empty slots
const slides = slots.filter((s): s is Exclude<Slot, { type: "empty" }> => s.type !== "empty");
---

<section class="max-w-7xl mx-auto px-4 lg:px-8 grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 mt-4">
  <!-- Gallery -->
  <div class="lg:col-span-7">
    <div class="relative group">
      <!-- Main slider — only non-empty slots -->
      <div class="zigzag-frame">
      <div id="gallery-track" class="flex overflow-x-auto snap-x snap-mandatory hide-scrollbar bg-[#f3f4f5]">
        {slides.map((slide, i) => (
          <div class="snap-center shrink-0 w-full" data-index={i}>
            {slide.type === "image" ? (
              <picture>
                {slide.srcset ? (
                  <>
                    <source
                      type="image/avif"
                      srcset={slide.srcset.replace(/f_auto/g, "f_avif")}
                      sizes="(max-width: 640px) 100vw, (max-width: 1024px) 100vw, 58vw"
                    />
                    <source
                      type="image/webp"
                      srcset={slide.srcset.replace(/f_auto/g, "f_webp")}
                      sizes="(max-width: 640px) 100vw, (max-width: 1024px) 100vw, 58vw"
                    />
                  </>
                ) : null}
                <img
                  src={getCloudinaryUrl(slide.src, slide.srcset ? "f_auto,q_auto,w_700,c_limit" : "f_auto,q_auto,w_665,c_limit")}
                  srcset={slide.srcset || undefined}
                  sizes="(max-width: 640px) 100vw, (max-width: 1024px) 100vw, 58vw"
                  alt={slide.alt}
                  title={slide.alt}
                  width="700"
                  height="467"
                  class="w-full h-[350px] lg:h-[600px] object-cover"
                  loading={i === 0 ? "eager" : "lazy"}
                  decoding={i === 0 ? "sync" : "async"}
                  fetchpriority={i === 0 ? "high" : undefined}
                />
              </picture>
            ) : slide.type === "youtube" ? (
              <iframe
                src={slide.embedSrc}
                class="w-full h-[350px] lg:h-[600px]"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
                title={slide.alt}
              />
            ) : (
              <video
                src={slide.src}
                class="w-full h-[350px] lg:h-[600px] object-cover"
                controls
                muted
                playsinline
                preload="metadata"
              />
            )}
          </div>
        ))}
      </div>
      </div><!-- /zigzag-frame -->

      <!-- Mobile dots -->
      {slides.length > 1 && (
        <div id="gallery-dots" class="flex lg:hidden justify-center space-x-2 mt-4">
          {slides.map((_, i) => (
            <button
              class={`w-6 h-6 flex items-center justify-center gallery-dot`}
              data-dot={i}
              aria-label={`Go to slide ${i + 1}`}
            >
              <span class={`w-2 h-2 rounded-full transition-colors block ${i === 0 ? "bg-[#041632]" : "bg-[#e1e3e4]"}`}></span>
            </button>
          ))}
        </div>
      )}
    </div>

    <!-- Thumbnails (desktop) — only non-empty slots -->
    {slides.length > 1 && (
    <div id="gallery-thumbs" class="hidden lg:flex flex-wrap gap-3 mt-4">
      {slides.map((slide, slideIndex) => (
          <button
            class={`h-20 w-20 flex-shrink-0 overflow-hidden border-2 transition-colors gallery-thumb ${slideIndex === 0 ? "border-[#041632]" : "border-transparent"} cursor-pointer`}
            data-thumb={slideIndex}
            aria-label={`View slide ${slideIndex + 1}`}
          >
            {slide.type === "image" ? (
              <img src={getCloudinaryUrl(slide.src, "f_auto,q_auto,w_160,h_160,c_fill,g_auto")} alt={slide.alt} title={slide.alt} width="80" height="80" class="w-full h-full object-cover" loading="lazy" />
            ) : slide.type === "youtube" ? (
              <div class="relative w-full h-full">
                <img src={slide.thumbSrc} alt={slide.alt} title={slide.alt} width="80" height="80" class="w-full h-full object-cover" loading="lazy" />
                <div class="absolute inset-0 flex items-center justify-center bg-black/20">
                  <span class="material-symbols-outlined text-white text-2xl" style="font-variation-settings: 'FILL' 1;">play_circle</span>
                </div>
              </div>
            ) : (
              <div class="w-full h-full bg-[#e7e8e9] flex items-center justify-center">
                <span class="material-symbols-outlined text-2xl text-[#44474d]">play_circle</span>
              </div>
            )}
          </button>
      ))}
    </div>
    )}
  </div>

  <!-- Lead Panel -->
  <div class="lg:col-span-5 flex flex-col space-y-6 lg:space-y-8">
    <div>
      <span class="font-sans text-xs uppercase tracking-widest text-[#775a19] font-bold">{product.seriesLabel}</span>
      <div class="flex flex-wrap items-center gap-4 mb-3">
        <div class="flex items-center space-x-1 py-1 px-2 bg-[#e7e8e9] rounded-sm">
          <span class="material-symbols-outlined text-sm text-[#FFD700]" style="font-variation-settings: 'FILL' 1;">star</span>
          <span class="text-xs font-bold text-[#191c1d]">
            {product.rating} <span class="font-normal text-[#44474d]">({product.ratingCount} ratings)</span>
          </span>
        </div>
        <div class="text-xs font-sans text-[#44474d] flex items-center">
          <span class="uppercase tracking-wider font-semibold">Category:</span>
          <a href={`/category/${product.categorySlug}`} class="ml-1 hover:text-[#775a19] cursor-pointer transition-colors">{product.category}</a>
        </div>
      </div>
      <h1 class="font-serif text-3xl lg:text-5xl font-extrabold mt-2 text-[#041632] leading-tight">{product.name}</h1>
      <p class="mt-4 text-[#44474d] text-sm lg:text-base leading-relaxed border-l-4 border-[#775a19] pl-4">{product.shortDesc}</p>
    </div>

    <div class="bg-[#f3f4f5] p-6 lg:p-8 space-y-6">
      <div class="flex items-center justify-between border-b border-[#c5c6ce]/20 pb-4">
        <span class="text-sm font-sans uppercase">Supply Status</span>
        <span class="flex items-center text-[#775a19] font-bold text-sm">
          <span class="bg-[#775a19]/10 text-[#775a19] px-3 py-1 rounded-full flex items-center">
            <span class="material-symbols-outlined text-sm mr-1.5" style="font-variation-settings: 'FILL' 1;">verified_user</span>
            {product.supplyStatus}
          </span>
        </span>
      </div>
      <div class="space-y-4">
        <a href={product.whatsapp} target="_blank" rel="noopener noreferrer" class="w-full bg-[#041632] text-white py-4 px-6 font-bold flex items-center justify-center space-x-3 hover:bg-[#775a19] transition-colors">
          <span class="material-symbols-outlined">mail</span>
          <span>INQUIRE FOR BULK QUOTE</span>
        </a>
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
          <a href={product.whatsapp} class="flex items-center justify-center gap-2 border border-[#c5c6ce] py-3 px-2 hover:bg-[#e7e8e9] transition-colors min-w-0">
            <span class="material-symbols-outlined text-green-600 shrink-0" style="font-variation-settings: 'FILL' 1;">chat</span>
            <span class="text-sm font-bold truncate">WhatsApp</span>
          </a>
          <a href={product.phone} class="flex items-center justify-center gap-2 border border-[#c5c6ce] py-3 px-2 hover:bg-[#e7e8e9] transition-colors min-w-0">
            <span class="material-symbols-outlined shrink-0">call</span>
            <span class="text-sm font-bold truncate">Call Us</span>
          </a>
          <div class="col-span-2 sm:col-span-1">
            <ProductShareButton product={product} />
          </div>
        </div>
      </div>
    </div>

    <!-- Quick Specs Strip -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-[#c5c6ce]/20 border border-[#c5c6ce]/20 overflow-hidden">
      <div class="bg-white p-4 text-center">
        <p class="text-[10px] uppercase font-sans text-[#44474d]">Material</p>
        <p class="font-bold text-sm">{product.specs.material}</p>
      </div>
      <div class="bg-white p-4 text-center">
        <p class="text-[10px] uppercase font-sans text-[#44474d]">Weight</p>
        <p class="font-bold text-sm">{product.specs.weight}</p>
      </div>
      <div class="bg-white p-4 text-center">
        <p class="text-[10px] uppercase font-sans text-[#44474d]">Width</p>
        <p class="font-bold text-sm">{product.specs.width}</p>
      </div>
      <div class="bg-white p-4 text-center">
        <p class="text-[10px] uppercase font-sans text-[#44474d]">Weave</p>
        <p class="font-bold text-sm">{product.specs.weave}</p>
      </div>
    </div>
  </div>
</section>

<script>
  const track = document.getElementById("gallery-track") as HTMLElement;
  const dots = document.querySelectorAll<HTMLButtonElement>(".gallery-dot");
  const thumbs = document.querySelectorAll<HTMLButtonElement>(".gallery-thumb");

  function goTo(index: number) {
    const slideWidth = track.offsetWidth;
    track.scrollTo({ left: slideWidth * index, behavior: "smooth" });
    dots.forEach((d, i) => {
      const inner = d.querySelector("span");
      if (inner) {
        inner.classList.toggle("bg-[#041632]", i === index);
        inner.classList.toggle("bg-[#e1e3e4]", i !== index);
      }
    });
    thumbs.forEach((t, i) => {
      t.classList.toggle("border-[#041632]", i === index);
      t.classList.toggle("border-transparent", i !== index);
    });
  }

  dots.forEach((dot) => {
    dot.addEventListener("click", () => goTo(Number(dot.dataset.dot)));
  });

  thumbs.forEach((thumb) => {
    thumb.addEventListener("click", () => {
      const idx = Number(thumb.dataset.thumb);
      if (idx >= 0) goTo(idx);
    });
  });

  // Sync dots/thumbs on scroll
  track?.addEventListener("scroll", () => {
    const index = Math.round(track.scrollLeft / track.offsetWidth);
    dots.forEach((d, i) => {
      const inner = d.querySelector("span");
      if (inner) {
        inner.classList.toggle("bg-[#041632]", i === index);
        inner.classList.toggle("bg-[#e1e3e4]", i !== index);
      }
    });
    thumbs.forEach((t, i) => {
      t.classList.toggle("border-[#041632]", i === index);
      t.classList.toggle("border-transparent", i !== index);
    });
  });
</script>

