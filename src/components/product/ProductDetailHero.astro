      80% 100%,     78% calc(100% - 12px),
      76% 100%,     74% calc(100% - 12px),
      72% 100%,     70% calc(100% - 12px),
      68% 100%,     66% calc(100% - 12px),
      64% 100%,     62% calc(100% - 12px),
      60% 100%,     58% calc(100% - 12px),
      56% 100%,     54% calc(100% - 12px),
      52% 100%,     50% calc(100% - 12px),
      48% 100%,     46% calc(100% - 12px),
      44% 100%,     42% calc(100% - 12px),
      40% 100%,     38% calc(100% - 12px),
      36% 100%,     34% calc(100% - 12px),
