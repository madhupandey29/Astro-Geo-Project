      100% 4%,      calc(100% - 12px) 6%,
      100% 8%,      calc(100% - 12px) 10%,
      100% 12%,     calc(100% - 12px) 14%,
      100% 16%,     calc(100% - 12px) 18%,
      100% 20%,     calc(100% - 12px) 22%,
      100% 24%,     calc(100% - 12px) 26%,
      100% 28%,     calc(100% - 12px) 30%,
      100% 32%,     calc(100% - 12px) 34%,
      100% 36%,     calc(100% - 12px) 38%,
      100% 40%,     calc(100% - 12px) 42%,
      100% 44%,     calc(100% - 12px) 46%,
      100% 48%,     calc(100% - 12px) 50%,
      100% 52%,     calc(100% - 12px) 54%,
      100% 56%,     calc(100% - 12px) 58%,
      100% 60%,     calc(100% - 12px) 62%,
      100% 64%,     calc(100% - 12px) 66%,
      100% 68%,     calc(100% - 12px) 70%,
      100% 72%,     calc(100% - 12px) 74%,
      100% 76%,     calc(100% - 12px) 78%,
