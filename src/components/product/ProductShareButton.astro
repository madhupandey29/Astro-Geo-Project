---
import type { Product } from "../../data/products";
interface Props { product: Product }
const { product } = Astro.props;

const gsmRounded = Math.round(product.gsm);
const widthClean = `${Math.round(product.cm)} cm / ${Math.round(product.inch)} inch`;
const shareText = `${product.name}\nGSM: ${gsmRounded} | Material: ${product.specs.material} | Width: ${widthClean} | Weave: ${product.specs.weave}\nEnquire at Amrita Global Enterprises:`;

const keySpecs = [
  { label: "Material", value: product.specs.material },
  { label: "Weight",   value: product.specs.weight },
  { label: "Width",    value: widthClean },
  { label: "Weave",    value: product.specs.weave },
];
---

<!-- Share Button -->
<button
  id="share-btn"
  class="flex items-center justify-center gap-2 border border-[#c5c6ce] py-3 px-4 hover:bg-[#e7e8e9] transition-colors w-full"
  aria-label="Share this product"
>
  <span class="material-symbols-outlined text-[#041632] text-[20px]">share</span>
  <span class="text-sm font-bold">Share</span>
</button>

<!-- Modal Overlay -->
<div
  id="share-modal"
  class="fixed inset-0 z-50 flex items-end sm:items-center justify-center bg-black/70 backdrop-blur-sm hidden"
  role="dialog"
  aria-modal="true"
  aria-labelledby="share-modal-title"
>
  <div id="share-panel" class="relative w-full sm:max-w-md bg-white sm:rounded-2xl overflow-hidden shadow-2xl flex flex-col max-h-[95dvh] sm:max-h-[90vh] translate-y-4 opacity-0 transition-all duration-300">

    <!-- Drag handle (mobile) -->
    <div class="sm:hidden flex justify-center pt-3 pb-1 flex-shrink-0">
      <div class="w-10 h-1 rounded-full bg-[#c5c6ce]"></div>
    </div>

    <!-- Close -->
    <button
      id="share-modal-close"
      class="absolute top-4 right-4 z-10 w-8 h-8 flex items-center justify-center rounded-full bg-black/10 hover:bg-black/20 transition-colors"
      aria-label="Close"
    >
      <span class="material-symbols-outlined text-white text-[18px]">close</span>
    </button>

    <!-- Scrollable content -->
    <div class="overflow-y-auto flex-1 overscroll-contain">

      <!-- Hero image -->
      <div class="relative h-48 bg-[#0d1f38] overflow-hidden">
        {product.image1 ? (
          <img
            src={product.image1}
            alt={product.imageAlt ?? product.name}
            width="480"
            height="192"
            class="w-full h-full object-cover opacity-90"
            loading="eager"
          />
        ) : (
          <div class="w-full h-full bg-gradient-to-br from-[#041632] to-[#0d2d52]"></div>
        )}
        <div class="absolute inset-0 bg-gradient-to-t from-[#041632]/90 via-[#041632]/30 to-transparent"></div>
        <div class="absolute top-4 left-4 flex items-center gap-2">
          <div class="w-1 h-4 bg-[#c9a84c]"></div>
          <span class="text-[10px] font-bold uppercase tracking-widest text-white/80 font-sans">Amrita Global Enterprises</span>
        </div>
        <div class="absolute bottom-0 left-0 right-0 px-5 pb-4">
          <p class="text-[10px] uppercase tracking-widest text-[#c9a84c] font-bold font-sans mb-1">{product.seriesLabel}</p>
          <h2 id="share-modal-title" class="font-serif text-lg font-extrabold text-white leading-snug">{product.name}</h2>
        </div>
      </div>

      <!-- Gold rule -->
      <div class="h-[3px] bg-gradient-to-r from-[#775a19] via-[#c9a84c] to-[#775a19]"></div>

      <!-- Short desc -->
      <div class="px-5 pt-4 pb-3">
        <p class="text-xs text-[#44474d] leading-relaxed line-clamp-2">{product.shortDesc}</p>
      </div>

      <!-- Key specs 2x2 grid -->
      <div class="px-5 pb-5 grid grid-cols-2 gap-2">
        {keySpecs.map(s => (
          <div class="bg-[#f3f4f5] rounded-lg px-3 py-2.5">
            <p class="text-[9px] uppercase tracking-widest text-[#775a19] font-bold font-sans mb-0.5">{s.label}</p>
            <p class="text-xs font-bold text-[#041632] leading-tight">{s.value}</p>
          </div>
        ))}
      </div>

    </div>

    <!-- Share actions -->
    <div class="px-5 pb-6 pt-4 bg-white border-t border-[#e7e8e9] flex-shrink-0 space-y-3">
      <p class="text-[10px] uppercase tracking-widest text-[#44474d] font-bold font-sans text-center">Share via</p>

      <!-- WhatsApp primary -->
      <a
        id="share-whatsapp"
        href="#"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center gap-2.5 w-full bg-[#25D366] text-white py-3.5 rounded-xl font-bold text-sm hover:bg-[#1ebe5d] active:scale-[0.98] transition-all"
      >
        <svg class="w-5 h-5 fill-white flex-shrink-0" viewBox="0 0 24 24">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Share on WhatsApp
      </a>

      <!-- Secondary row -->
      <div class="grid grid-cols-3 gap-2">
        <a id="share-telegram" href="#" target="_blank" rel="noopener noreferrer"
          class="flex flex-col items-center gap-1.5 py-3 rounded-xl bg-[#f3f4f5] hover:bg-[#e7e8e9] active:scale-[0.97] transition-all">
          <svg class="w-5 h-5 fill-[#229ED9]" viewBox="0 0 24 24">
            <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
          </svg>
          <span class="text-[10px] font-semibold text-[#44474d]">Telegram</span>
        </a>
        <a id="share-twitter" href="#" target="_blank" rel="noopener noreferrer"
          class="flex flex-col items-center gap-1.5 py-3 rounded-xl bg-[#f3f4f5] hover:bg-[#e7e8e9] active:scale-[0.97] transition-all">
          <svg class="w-5 h-5 fill-[#041632]" viewBox="0 0 24 24">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
          <span class="text-[10px] font-semibold text-[#44474d]">X / Twitter</span>
        </a>
        <button id="share-copy-btn"
          class="flex flex-col items-center gap-1.5 py-3 rounded-xl bg-[#f3f4f5] hover:bg-[#e7e8e9] active:scale-[0.97] transition-all">
          <span class="material-symbols-outlined text-[#041632] text-[20px]">content_copy</span>
          <span id="copy-label" class="text-[10px] font-semibold text-[#44474d]">Copy Link</span>
        </button>
      </div>
    </div>

  </div>
</div>

<script define:vars={{ shareText }}>
  const btn = document.getElementById("share-btn");
  const modal = document.getElementById("share-modal");
  const panel = document.getElementById("share-panel");
  const closeBtn = document.getElementById("share-modal-close");
  const copyBtn = document.getElementById("share-copy-btn");
  const copyLabel = document.getElementById("copy-label");
  const waLink = document.getElementById("share-whatsapp");
  const tgLink = document.getElementById("share-telegram");
  const twLink = document.getElementById("share-twitter");

  function openModal() {
    const url = window.location.href;
    const fullMessage = `${shareText} ${url}`;
    const encodedText = encodeURIComponent(fullMessage);
    const encodedUrl = encodeURIComponent(url);
    if (waLink) waLink.href = `https://wa.me/?text=${encodedText}`;
    if (tgLink) tgLink.href = `https://t.me/share/url?url=${encodedUrl}&text=${encodeURIComponent(shareText)}`;
    if (twLink) twLink.href = `https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodedUrl}`;
    modal?.classList.remove("hidden");
    document.body.style.overflow = "hidden";
    requestAnimationFrame(() => {
      panel?.classList.remove("translate-y-4", "opacity-0");
      panel?.classList.add("translate-y-0", "opacity-100");
    });
  }

  function closeModal() {
    panel?.classList.add("translate-y-4", "opacity-0");
    panel?.classList.remove("translate-y-0", "opacity-100");
    setTimeout(() => {
      modal?.classList.add("hidden");
      document.body.style.overflow = "";
    }, 250);
  }

  btn?.addEventListener("click", openModal);
  closeBtn?.addEventListener("click", closeModal);
  modal?.addEventListener("click", (e) => { if (e.target === modal) closeModal(); });
  document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeModal(); });

  copyBtn?.addEventListener("click", async () => {
    const url = window.location.href;
    try {
      await navigator.clipboard.writeText(url);
    } catch {
      const inp = document.createElement("input");
      inp.value = url;
      document.body.appendChild(inp);
      inp.select();
      document.execCommand("copy");
      document.body.removeChild(inp);
    }
    if (copyLabel) copyLabel.textContent = "Copied!";
    setTimeout(() => { if (copyLabel) copyLabel.textContent = "Copy Link"; }, 2000);
  });
</script>
