---
import ProductCard from "./ProductCard.astro";

interface Product {
  id: string;
  name: string;
  category: string;
  weight: string;
  width: string;
  color: string;
  image: string;
  imageSrcset?: string;
  href: string;
  filterCategory?: string;
  filterColor?: string;
  filterStructure?: string;
  filterContent?: string;
  filterGsm?: string;
  filterDesign?: string;
  filterFinish?: string;
  searchSlug?: string;
  searchOzs?: string;
  searchCm?: string;
  searchInch?: string;
  searchMotif?: string;
  searchKeywords?: string;
  searchMerchTags?: string;
  searchCollection?: string;
  searchSupply?: string;
  searchFabricCode?: string;
  searchVendorCode?: string;
  searchMOQ?: string;
}

interface Props {
  products: Product[];
  currentPage?: number;
  totalPages?: number;
  baseUrl?: string;
}

const { products } = Astro.props;

// First batch rendered visible, rest scroll-hidden — revealed by IntersectionObserver
const INITIAL_BATCH = 12;
---

<div id="product-grid">
  <div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3" id="product-grid-inner">
    {products.map((product, i) => (
      <div
        class="product-card-wrapper"
        data-scroll-hidden={i >= INITIAL_BATCH ? "true" : undefined}
        style={i >= INITIAL_BATCH ? "display:none" : undefined}
      >
        <ProductCard product={product} />
      </div>
    ))}
  </div>

  <!-- Scroll sentinel — IntersectionObserver watches this to load next batch -->
  <div id="scroll-sentinel" class="h-4 w-full" aria-hidden="true"></div>

  <!-- Loading indicator -->
  <div id="load-more-indicator" style="display:none" class="flex justify-center py-8">
    <span class="text-sm font-label text-slate-400 tracking-widest uppercase">Loading more fabrics…</span>
  </div>

  <!-- Empty state — shown via JS when all cards are filtered out -->
  <div id="no-results" class="hidden flex-col items-center justify-center py-24 text-center">
    <svg class="w-16 h-16 text-slate-200 mb-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14zm-1-7h2v2h2v2h-2v2h-2v-2h-2v-2h2V7z"/>
    </svg>
    <h3 class="font-headline text-2xl text-[#041632] mb-2">No fabrics match your filters</h3>
    <p class="text-sm text-slate-500 max-w-xs mb-6">Try removing a few filters to broaden your search, or browse our full collection.</p>
    <a href="/fabric" class="inline-flex items-center gap-2 bg-[#041632] px-6 py-3 text-xs font-label font-bold uppercase tracking-widest text-white transition hover:bg-[#775a19]">
      <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M3 3v8h8V3H3zm6 6H5V5h4v4zm-6 4v8h8v-8H3zm6 6H5v-4h4v4zm4-16v8h8V3h-8zm6 6h-4V5h4v4zm-6 4v8h8v-8h-8zm6 6h-4v-4h4v4z"/>
      </svg>
      Browse all products
    </a>
  </div>
</div>

<script>
  const BATCH = 12;

  // Track how many wrappers have been scroll-revealed
  let revealedCount = document.querySelectorAll<HTMLElement>(".product-card-wrapper:not([data-scroll-hidden])").length;

  function revealNextBatch(): void {
    const toReveal = document.querySelectorAll<HTMLElement>('.product-card-wrapper[data-scroll-hidden="true"]');
    let count = 0;
    for (const wrapper of toReveal) {
      if (count >= BATCH) break;
      wrapper.removeAttribute("data-scroll-hidden");
      wrapper.style.display = "";
      revealedCount++;
      count++;
    }
  }

  // ── Infinite scroll ──────────────────────────────────────────────────────────
  const sentinel = document.getElementById("scroll-sentinel");
  const indicator = document.getElementById("load-more-indicator") as HTMLElement | null;

  if (sentinel) {
    const io = new IntersectionObserver(
      (entries) => {
        if (!entries[0].isIntersecting) return;
        const remaining = document.querySelectorAll<HTMLElement>('.product-card-wrapper[data-scroll-hidden="true"]');
        if (remaining.length === 0) { io.disconnect(); return; }
        if (indicator) indicator.style.display = "flex";
        requestAnimationFrame(() => {
          revealNextBatch();
          if (indicator) indicator.style.display = "none";
        });
      },
      { rootMargin: "300px" }
    );
    io.observe(sentinel);
  }

  // ── Filter integration ───────────────────────────────────────────────────────
  // When filters are active, reveal ALL wrappers so filtering works across all products.
  // When filters are cleared, re-hide wrappers beyond the revealed count.
  function onFilterStateChange(hasActiveFilters: boolean): void {
    if (hasActiveFilters) {
      // Reveal all so filter JS can see every card — also remove the attribute
      // so the filter's own display:none isn't overridden when filters are cleared
      document.querySelectorAll<HTMLElement>('.product-card-wrapper[data-scroll-hidden="true"]').forEach((w) => {
        w.removeAttribute("data-scroll-hidden");
        w.style.display = "";
      });
    } else {
      // Filters cleared — re-hide wrappers beyond the revealed count
      let count = 0;
      document.querySelectorAll<HTMLElement>(".product-card-wrapper").forEach((w) => {
        count++;
        if (count > revealedCount) {
          w.setAttribute("data-scroll-hidden", "true");
          w.style.display = "none";
        } else {
          w.style.display = "";
        }
      });
    }
  }

  // Expose so ProductFilters script can call it
  (window as any).__onFilterStateChange = onFilterStateChange;

  // ── Empty state ──────────────────────────────────────────────────────────────
  function updateEmptyState(): void {
    // Only count wrappers that are not scroll-hidden (i.e. actively hidden by the filter)
    const wrappers = document.querySelectorAll<HTMLElement>(".product-card-wrapper:not([data-scroll-hidden])");
    const visible = [...wrappers].some((w) => w.style.display !== "none");
    const noResults = document.getElementById("no-results");
    if (!noResults) return;
    noResults.classList.toggle("hidden", visible);
    noResults.classList.toggle("flex", !visible);
  }

  const observer = new MutationObserver(updateEmptyState);
  document.querySelectorAll<HTMLElement>(".product-card-wrapper").forEach((wrapper) => {
    observer.observe(wrapper, { attributes: true, attributeFilter: ["style"] });
  });
</script>
