---
import { getCategoryTopicPages } from "../../lib/api";
import CloudinaryImage from "../common/CloudinaryImage.astro";
import Carousel from "../common/Carousel.astro";

interface Props {}

const categories = await getCategoryTopicPages();
---

{categories.length > 0 && (
  <section class="py-16 md:py-24 bg-[#f8f9fa]">
    <div class="container mx-auto px-4 md:px-8">

      <div class="flex flex-col items-center text-center mb-12 md:mb-16 gap-6">
        <div class="max-w-2xl">
          <h2 class="font-headline text-4xl md:text-5xl text-[#041632] mb-4">The Material Core</h2>
          <p class="font-body text-base md:text-lg text-[#44474d]">Our signature fabrics are engineered for durability, hand-feel, and consistent quality.</p>
        </div>
      </div>

      <Carousel
        cols={{ mobile: 1, tablet: 2, desktop: 3 }}
        gap="gap-6"
        showArrows={categories.length > 1}
        id="featured-categories"
      >
        {categories.map((cat) => (
          <a href={`/category/${cat.slug}`} class="group block">
            <div class="aspect-[3/4] overflow-hidden rounded-xl relative">
              {cat.image1CloudUrlCard || cat.image1CloudUrl ? (
                <CloudinaryImage
                  src={cat.image1CloudUrlCard ?? cat.image1CloudUrl}
                  alt={cat.name}
                  title={cat.name}
                  width={480}
                  height={640}
                  widths={[240, 480, 720]}
                  sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 82vw"
                  crop="fill"
                  loading="lazy"
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                />
              ) : (
                <div class="w-full h-full bg-[#d1d5db]" />
              )}
              <div class="absolute inset-0 bg-gradient-to-t from-[#041632]/80 to-transparent flex items-end p-6 md:p-8">
                <h3 class="!text-white font-headline text-2xl md:text-3xl">{cat.name}</h3>
              </div>
            </div>
          </a>
        ))}
      </Carousel>

      <div class="flex justify-center mt-10 md:mt-12">
        <a
          class="font-label text-xs md:text-sm font-bold text-[#775a19] uppercase tracking-widest flex items-center gap-2 border-b-2 border-[#775a19] pb-1"
          href="/fabric"
        >
          Explore Full Library
        </a>
      </div>

    </div>
  </section>
)}
