---
interface Props {
  p1?: string | null;
  p2?: string | null;
}
const { p1, p2 } = Astro.props;
---

<section class="py-16 md:py-24 bg-[#041632] text-white">
  <div class="container mx-auto px-4 md:px-8">
    {(p1 || p2) ? (
      <div class="cap-layout">

        <!-- LEFT: sticky visual column -->
        <div class="cap-left">
          <!-- Two-image grid (original layout) -->
          <div class="relative">
            <div class="grid grid-cols-2 gap-4">
              <div class="aspect-[3/4] rounded-xl overflow-hidden mt-8">
                <img
                  class="w-full h-full object-cover grayscale brightness-75"
                  src="https://res.cloudinary.com/age-fabric/image/upload/v1775652005/9_wizefk.jpg"
                  alt="Industrial textile manufacturing floor"
                  width="512" height="512" loading="lazy"
                />
              </div>
              <div class="aspect-[3/4] rounded-xl overflow-hidden">
                <img
                  class="w-full h-full object-cover grayscale brightness-75"
                  src="https://res.cloudinary.com/age-fabric/image/upload/v1775652187/14_ith7ry.jpg"
                  alt="Laboratory quality check"
                  width="512" height="512" loading="lazy"
                />
              </div>
            </div>
            <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
              <div class="bg-[#775a19]/90 p-6 md:p-10 rounded-full backdrop-blur-sm">
                <span class="material-symbols-outlined text-white text-4xl md:text-6xl">verified</span>
              </div>
            </div>
          </div>
          <!-- Stats badge card -->
          <div class="cap-stats">
            <div class="cap-stat">
              <span class="cap-stat-value">50+</span>
              <span class="cap-stat-label">Years Experience</span>
            </div>
            <div class="cap-stat-divider"></div>
            <div class="cap-stat">
              <span class="cap-stat-value">600K+</span>
              <span class="cap-stat-label">Meters / Month</span>
            </div>
            <div class="cap-stat-divider"></div>
            <div class="cap-stat">
              <span class="cap-stat-value">96%</span>
              <span class="cap-stat-label">Repeat Orders</span>
            </div>
          </div>
        </div>

        <!-- RIGHT: scrollable text -->
        <div class="cap-right">
          <div class="cap-right-content">
            <div id="cap-content">
              {p1 && <div set:html={p1} />}
              {p2 && <div class="mt-6" set:html={p2} />}
            </div>
          </div>
          <button id="cap-toggle">
            <span id="cap-toggle-label">View More</span>
            <svg id="cap-toggle-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"/>
            </svg>
          </button>
        </div>

      </div>
    ) : (
      <div class="cap-layout">
        <div class="cap-left">
          <div class="relative">
            <div class="grid grid-cols-2 gap-4">
              <div class="aspect-[3/4] rounded-xl overflow-hidden mt-8">
                <img class="w-full h-full object-cover grayscale brightness-75"
                  src="https://res.cloudinary.com/age-fabric/image/upload/v1775652005/9_wizefk.jpg"
                  alt="Industrial textile manufacturing" width="512" height="512" loading="lazy" />
              </div>
              <div class="aspect-[3/4] rounded-xl overflow-hidden">
                <img class="w-full h-full object-cover grayscale brightness-75"
                  src="https://res.cloudinary.com/age-fabric/image/upload/v1775652187/14_ith7ry.jpg"
                  alt="Laboratory quality check" width="512" height="512" loading="lazy" />
              </div>
            </div>
            <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
              <div class="bg-[#775a19]/90 p-6 md:p-10 rounded-full backdrop-blur-sm">
                <span class="material-symbols-outlined text-white text-4xl md:text-6xl">verified</span>
              </div>
            </div>
          </div>
          <div class="cap-stats">
            <div class="cap-stat">
              <span class="cap-stat-value">50+</span>
              <span class="cap-stat-label">Years Experience</span>
            </div>
            <div class="cap-stat-divider"></div>
            <div class="cap-stat">
              <span class="cap-stat-value">600K+</span>
              <span class="cap-stat-label">Meters / Month</span>
            </div>
            <div class="cap-stat-divider"></div>
            <div class="cap-stat">
              <span class="cap-stat-value">96%</span>
              <span class="cap-stat-label">Repeat Orders</span>
            </div>
          </div>
        </div>
        <div class="cap-right">
          <h2 class="font-headline text-4xl md:text-5xl text-white leading-tight">Manufacturing Integrity</h2>
          <p class="mt-4 text-white/70 text-lg">Precision-engineered fabrics built for global standards.</p>
        </div>
      </div>
    )}
  </div>
</section>

<style is:global>
  /* Two-column layout: left sticky, right scrolls */
  .cap-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }
  @media (min-width: 1024px) {
    .cap-layout {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
  }

  /* LEFT sticky column */
  .cap-left {
    position: relative;
  }
  @media (min-width: 1024px) {
    .cap-left {
      position: sticky;
      top: 6rem;
    }
  }

  /* Stats badge card */
  .cap-stats {
    margin-top: 1.25rem;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 0.75rem;
    padding: 1.25rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    backdrop-filter: blur(8px);
  }
  .cap-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    flex: 1;
  }
  .cap-stat-value {
    font-family: var(--font-headline, Georgia, serif);
    font-size: 1.5rem;
    color: #ffdea5;
    font-weight: 700;
    line-height: 1;
  }
  .cap-stat-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    text-align: center;
  }
  .cap-stat-divider {
    width: 1px;
    height: 2rem;
    background: rgba(255,255,255,0.15);
    flex-shrink: 0;
  }

  /* RIGHT text column */
  .cap-right {
    padding-top: 0;
  }

  .cap-right-content {
    /* no extra styles needed */
  }

  /* Collapsed clamp — mobile only */
  #cap-content {
    overflow: hidden;
    position: relative;
    transition: max-height 0.5s ease;
    color: rgba(255,255,255,0.82);
    font-size: 1rem;
    line-height: 1.8;
    max-height: 220px; /* collapsed on mobile */
  }
  #cap-content.expanded { max-height: 9999px; }

  /* Rich content */
  #cap-content h2, #cap-content h3, #cap-content h4 {
    font-family: var(--font-headline, Georgia, serif);
    color: #ffffff;
    margin-top: 1.5rem;
    margin-bottom: 0.4rem;
    line-height: 1.3;
  }
  #cap-content h2 { font-size: 1.6rem; }
  #cap-content h3 { font-size: 1.25rem; }
  #cap-content h4 { font-size: 1.05rem; }
  #cap-content p { margin-top: 0.6rem; }
  #cap-content ul, #cap-content ol { margin-top: 0.6rem; padding-left: 1.4rem; }
  #cap-content ul { list-style-type: disc; }
  #cap-content ol { list-style-type: decimal; }
  #cap-content li { margin-bottom: 0.35rem; }
  #cap-content strong { color: #ffdea5; font-weight: 600; }
  #cap-content a { color: #ffdea5; text-decoration: underline; }

  /* Toggle button — mobile only */
  #cap-toggle {
    margin-top: 1.5rem;
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #ffdea5;
    background: none;
    border: none;
    border-bottom: 1px solid rgba(255,222,165,0.5);
    padding-bottom: 0.25rem;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
  }
  #cap-toggle:hover { color: #fff; border-color: #fff; }
  #cap-toggle-icon { transition: transform 0.3s ease; flex-shrink: 0; }

  /* On md+ screens: always show full content, hide the toggle */
  @media (min-width: 768px) {
    #cap-toggle { display: none !important; }
    #cap-content { max-height: none !important; overflow: visible !important; }
  }
</style>

<script>
  const content = document.getElementById('cap-content');
  const toggle  = document.getElementById('cap-toggle');
  const label   = document.getElementById('cap-toggle-label');
  const icon    = document.getElementById('cap-toggle-icon');
  if (content && toggle) {
    toggle.addEventListener('click', () => {
      const expanded = content.classList.toggle('expanded');
      if (label) label.textContent = expanded ? 'View Less' : 'View More';
      if (icon)  (icon as HTMLElement).style.transform = expanded ? 'rotate(180deg)' : '';
      // When collapsing, scroll back to the section so user isn't lost
      if (!expanded) {
        const section = content.closest('section');
        if (section) section.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  }
</script>
