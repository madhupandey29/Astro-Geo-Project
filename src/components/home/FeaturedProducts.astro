---

<section class="py-16 md:py-24 bg-[#f8f9fa]">
  <div class="container mx-auto px-4 md:px-8">
    <div class="text-center mb-12 md:mb-16">
      <h2 class="font-headline text-4xl md:text-5xl text-[#041632] mb-3 md:mb-4">Featured Textiles</h2>
      <p class="font-label text-xs md:text-sm uppercase tracking-[0.3em] md:tracking-[0.4em] text-[#775a19]">Our Best-Selling Catalog</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
      {products.map((product) => (
        <div class="bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-all border border-[#edeeef]">
          <div class="aspect-square bg-[#f3f4f5] overflow-hidden">
            <img class="w-full h-full object-cover" src={product.image} alt={product.title} title={product.title} width="400" height="400" loading="lazy" />
          </div>
          <div class="p-4 md:p-6">
            <span class="font-label text-[9px] md:text-[10px] text-[#775a19] font-bold uppercase tracking-widest">{product.label}</span>
            <h3 class="font-headline text-lg md:text-xl text-[#041632] mt-1 mb-2">{product.title}</h3>
            <div class="flex justify-between items-center pt-3 md:pt-4 border-t border-[#edeeef]">
              <span class="font-body text-[10px] md:text-xs text-[#44474d] italic">{product.meta}</span>
              <button class="text-[#041632] font-label text-[10px] font-bold uppercase tracking-widest hover:text-[#775a19]">Details</button>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
