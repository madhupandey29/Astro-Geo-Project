---
import { getBlogPosts } from "../../lib/api";

const posts = await getBlogPosts(20);
const post = posts[0];
---

{post && (
  <section class="py-16 md:py-24 bg-[#f8f9fa]">
    <div class="container mx-auto px-4 md:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 md:gap-16 items-center">

        <div class="text-center lg:text-left">
          {post.category && (
            <span class="font-label text-[10px] md:text-xs font-bold text-[#775a19] uppercase tracking-[0.3em] mb-4 block">
              {post.category}
            </span>
          )}
          <h2 class="font-headline text-3xl md:text-5xl text-[#041632] mb-6 md:mb-8 leading-tight">
            {post.title}
          </h2>
          {post.excerpt && (
            <p class="font-body text-[#44474d] text-base md:text-lg leading-relaxed mb-8 italic">
              "{post.excerpt}"
            </p>
          )}
          <a
            href={`/blog/${post.slug}`}
            class="font-label text-[#041632] text-[10px] md:text-xs font-bold uppercase tracking-widest border-b-2 border-[#041632] pb-2 inline-block"
          >
            Read the Full Article
          </a>
        </div>

        <div class="bg-[#edeeef] h-[250px] sm:h-[400px] rounded-2xl overflow-hidden relative shadow-inner">
          <img
            class="w-full h-full object-cover brightness-90"
            src={post.blogimage1CloudURL ?? ""}
            alt={post.altimage1 ?? post.title}
            title={post.altimage1 ?? post.title}
            width="800"
            height="600"
            loading="lazy"
          />
        </div>

      </div>
    </div>
  </section>
)}
