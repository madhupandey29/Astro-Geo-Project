---
import { getDynamicTopicPages, getProductsByMerchTag } from "../../lib/api";
import { mapApiProduct } from "../../data/products";
import CloudinaryImage from "../common/CloudinaryImage.astro";

const topics = await getDynamicTopicPages();

const sections = await Promise.all(
  topics.map(async (topic) => {
    const raw = await getProductsByMerchTag(topic.slug1, 12);
    const products = raw
      .filter((p) => (p.productslug ?? "").trim().toLowerCase() !== "pending")
      .map(mapApiProduct);
    return { topic, products };
  })
);
---

{sections.map(({ topic, products }, index) => {
  const id = `carousel-${index}`;
  return (
    <div class="section-wrapper">
      <section class:list={["topic-section", index % 2 === 0 ? "topic-section--light" : "topic-section--white"]}>
        <div class="container mx-auto px-4 md:px-8">

          <div class="mb-10 md:mb-14">
            <a href={`/collection/${topic.slug}`} class="group inline-block">
              <h2 class="font-headline text-4xl md:text-5xl text-[#041632] mb-3 md:mb-4 group-hover:text-[#775a19] transition-colors">
                {topic.name}
              </h2>
            </a>
            {topic.description && (
              <p class="font-label text-xs md:text-sm uppercase tracking-[0.15em] text-[#775a19]">
                {topic.description}
              </p>
            )}
          </div>

          {products.length > 0 ? (
            <div class="c-outer">
              <button
                id={`${id}-prev`}
                class="c-arrow c-arrow-prev"
                aria-label="Previous"
                onclick={`(function(){var t=document.getElementById('${id}-track');var c=t.querySelector('.c-card');var cols=window.innerWidth>=1024?4:window.innerWidth>=640?2:1;var g=parseFloat(getComputedStyle(t).gap)||0;t.scrollBy({left:-(c.offsetWidth+g)*cols,behavior:'smooth'});})()`}
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="15 18 9 12 15 6"/>
                </svg>
              </button>

              <div id={`${id}-track`} class="c-track">
                {products.map((product) => (
                  <a
                    href={`/collection/${topic.slug}/${product.slug}`}
                    class="c-card bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-lg transition-all border border-[#edeeef] block"
                  >
                    <div class="aspect-square bg-[#f3f4f5] overflow-hidden">
                      <CloudinaryImage
                        src={product.image || "/images/placeholders/fabric.jpg"}
                        alt={product.imageAlt || product.name}
                        title={product.imageAlt || product.name}
                        width={400}
                        height={400}
                        widths={[200, 400, 600, 800]}
                        sizes="(min-width: 1024px) 25vw, (min-width: 640px) 50vw, 80vw"
                        crop="fill"
                        loading="lazy"
                        class="w-full h-full object-cover"
                      />
                    </div>
                    <div class="p-4 md:p-5">
                      <span class="font-label text-[9px] md:text-[10px] text-[#775a19] font-bold uppercase tracking-widest">
                        {product.seriesLabel}
                      </span>
                      <h3 class="font-headline text-base md:text-lg text-[#041632] mt-1 mb-2 leading-snug">
                        {product.name}
                      </h3>
                      <div class="flex justify-between items-center pt-3 border-t border-[#edeeef]">
                        <span class="font-body text-[10px] md:text-xs text-[#44474d] italic">
                          {product.specs.weight} | {product.specs.weave}
                        </span>
                        <span class="text-[#041632] font-label text-[10px] font-bold uppercase tracking-widest hover:text-[#775a19]">
                          Details
                        </span>
                      </div>
                    </div>
                  </a>
                ))}
              </div>

              <button
                id={`${id}-next`}
                class="c-arrow c-arrow-next"
                aria-label="Next"
                onclick={`(function(){var t=document.getElementById('${id}-track');var c=t.querySelector('.c-card');var cols=window.innerWidth>=1024?4:window.innerWidth>=640?2:1;var g=parseFloat(getComputedStyle(t).gap)||0;t.scrollBy({left:(c.offsetWidth+g)*cols,behavior:'smooth'});})()`}
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="9 18 15 12 9 6"/>
                </svg>
              </button>
            </div>
          ) : (
            <p class="text-center text-[#44474d] font-body text-sm">No products found for this collection.</p>
          )}

          <div class="flex justify-center mt-10 md:mt-14">
            <a
              href={`/collection/${topic.slug}`}
              class="font-label text-xs md:text-sm font-bold text-[#775a19] uppercase tracking-widest flex items-center gap-2 border-b-2 border-[#775a19] pb-1"
            >
              Explore Full Library
            </a>
          </div>
        </div>
      </section>
    </div>
  );
})}

<style>
  .section-wrapper { position: relative; }

  .topic-section { padding: 4rem 0; position: relative; }
  .topic-section--light {
    background: #f8f9fa;
    box-shadow: inset 0 8px 24px rgba(4,22,50,0.04), inset 0 -8px 24px rgba(4,22,50,0.04);
  }
  .topic-section--white {
    background: #ffffff;
    box-shadow: inset 0 8px 24px rgba(119,90,25,0.04), inset 0 -8px 24px rgba(119,90,25,0.04);
  }
  @media (min-width: 768px) { .topic-section { padding: 6rem 0; } }

  /* Outer: clip overflow so cards don't peek */
  .c-outer {
    position: relative;
    margin: 0 -1rem;
    overflow: hidden;
  }
  @media (min-width: 640px) {
    .c-outer { margin: 0 -2rem; }
  }
  @media (min-width: 1024px) {
    /* Make room for arrows outside the track */
    .c-outer { margin: 0 3rem; overflow: visible; }
  }

  /* Scrollable track — clips cards on desktop */
  .c-track {
    display: flex;
    gap: 0;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    scroll-behavior: smooth;
  }
  .c-track::-webkit-scrollbar { display: none; }
  @media (min-width: 1024px) {
    .c-track { overflow: hidden; }
  }

  /* Cards */
  .c-card {
    scroll-snap-align: start;
    flex-shrink: 0;
    width: 100%;
    padding: 0 0.5rem;
    box-sizing: border-box;
  }
  @media (min-width: 640px) {
    .c-card { width: 50%; }
  }
  @media (min-width: 1024px) {
    .c-card { width: 25%; }
  }

  /* Arrows */
  .c-arrow {
    position: absolute;
    top: 38%;
    transform: translateY(-50%);
    z-index: 10;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: #020d1f;
    border: none;
    box-shadow: 0 4px 16px rgba(2,13,31,0.45);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #ffffff;
    transition: background 0.18s, box-shadow 0.18s;
    padding: 0;
    line-height: 1;
  }
  /* Mobile: arrows overlay the card */
  .c-arrow-prev { left: 1rem; }
  .c-arrow-next { right: 1rem; }
  /* Desktop: arrows sit outside the track */
  @media (min-width: 1024px) {
    .c-arrow-prev { left: -3rem; }
    .c-arrow-next { right: -3rem; }
  }

  .c-arrow:hover {
    background: #775a19;
    box-shadow: 0 6px 20px rgba(119,90,25,0.4);
  }
  .c-arrow svg { display: block; flex-shrink: 0; }
</style>
