---
import { getLocations } from "../../lib/api";

interface Props {
  p1?: string | null;
}
const { p1 } = Astro.props;

const locations = await getLocations();
const locationNames = locations.length > 0
  ? locations.map((l) => l.name).join(", ") + " & Global Markets"
  : "Ahmedabad, Surat, Mumbai, Delhi & Global Markets";
---

<section class="py-16 md:py-24 bg-[#f3f4f5]">
  <div class="container mx-auto px-4 md:px-8">
    <h2 class="font-headline text-4xl md:text-5xl text-[#041632] mb-12 md:mb-16 text-center">Industries Served</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
      <div class="lg:col-span-2 bg-white p-8 md:p-12 rounded-2xl shadow-sm hover:shadow-md transition-shadow flex flex-col justify-between">
        <div>
          <span class="material-symbols-outlined text-[#775a19] text-4xl md:text-5xl mb-4 md:mb-6 block">checkroom</span>
          <h3 class="font-headline text-2xl md:text-3xl text-[#041632] mb-3 md:mb-4">Fashion Brands</h3>
          <p class="font-body text-sm md:text-base text-[#44474d] leading-relaxed">High-end apparel manufacturing with custom GSM and finishings for global retail chains.</p>
        </div>
      </div>

      <div class="bg-[#041632] text-white p-8 md:p-12 rounded-2xl flex flex-col justify-between">
        <div>
          <span class="material-symbols-outlined text-[#775a19] text-4xl md:text-5xl mb-4 md:mb-6 block">badge</span>
          <h3 class="font-headline text-2xl md:text-3xl mb-3 md:mb-4 text-white">Uniforms</h3>
          <p class="font-body text-sm md:text-base opacity-80 leading-relaxed">Durable, industrial-grade textiles for security, medical, and corporate wear.</p>
        </div>
      </div>

      <div class="bg-white p-8 md:p-12 rounded-2xl shadow-sm flex flex-col justify-between">
        <div>
          <span class="material-symbols-outlined text-[#775a19] text-4xl md:text-5xl mb-4 md:mb-6 block">hotel</span>
          <h3 class="font-headline text-2xl md:text-3xl text-[#041632] mb-3 md:mb-4">Hospitality</h3>
          <p class="font-body text-sm md:text-base text-[#44474d] leading-relaxed">Premium linens and upholstery for luxury hotels and resorts.</p>
        </div>
      </div>

      <div class="md:col-span-2 bg-[#e7e8e9] p-8 md:p-12 rounded-2xl flex flex-col sm:flex-row items-center gap-6 md:gap-8 text-center sm:text-left">
        <div class="flex-1">
          <h3 class="font-headline text-2xl md:text-3xl text-[#041632] mb-3 md:mb-4">Export Houses</h3>
          <p class="font-body text-sm md:text-base text-[#44474d] leading-relaxed">Reliable supply chain partner for large-scale international export operations.</p>
        </div>
        <span class="material-symbols-outlined text-[#775a19] text-6xl md:text-7xl opacity-30">public_off</span>
      </div>

      <div class="md:col-span-2 bg-white border border-[#775a19]/10 p-8 md:p-12 rounded-2xl flex flex-col sm:flex-row items-center justify-between text-center sm:text-left gap-4">
        <div>
          <h4 class="font-label text-[10px] md:text-xs font-bold tracking-widest text-[#775a19] uppercase mb-2">Regional Hubs</h4>
          <p class="font-headline text-xl md:text-2xl text-[#041632]">{locationNames}</p>
        </div>
        <span class="material-symbols-outlined text-[#041632] text-3xl md:text-4xl">location_on</span>
      </div>

    </div>

    {p1 && p1.trim() && (
      <div class="mt-12 md:mt-16 rich-content text-[#44474d]" set:html={p1} />
    )}
  </div>
</section>

<style>
  .rich-content h2,
  .rich-content h3,
  .rich-content h4 {
    font-family: var(--font-headline, Georgia, serif);
    color: #041632;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    line-height: 1.3;
  }
  .rich-content h2 { font-size: 1.5rem; }
  .rich-content h3 { font-size: 1.25rem; }
  .rich-content p { margin-top: 0.75rem; line-height: 1.75; }
  .rich-content ul,
  .rich-content ol { margin-top: 0.75rem; padding-left: 1.5rem; }
  .rich-content ul { list-style-type: disc; }
  .rich-content ol { list-style-type: decimal; }
  .rich-content li { margin-bottom: 0.4rem; }
  .rich-content strong { color: #041632; font-weight: 600; }
  .rich-content a { color: #775a19; text-decoration: underline; }
</style>
