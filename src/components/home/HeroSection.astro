---
import { getCompanyInfo, getTopicPageBySlug, buildWaLink, buildPhoneHref } from "../../lib/api";
import ResponsiveImage from "../common/ResponsiveImage.astro";

const [company, homePage] = await Promise.all([
  getCompanyInfo(),
  getTopicPageBySlug("home"),
]);
const heroImage = homePage?.image1CloudUrl ?? null;
const whatsappLink = buildWaLink(company?.whatsappNumber, "/support");
const heroKeywords = homePage?.keywords?.slice(0, 3) ?? ["Industrial Legacy"];
---

<section class="relative flex items-center bg-[#f3f4f5] py-8 md:py-0" style="min-height: calc(100dvh - 94px); overflow-x: clip; overflow-y: visible;" data-hero>
  <style>
    @media (min-width: 768px) {
      [data-hero] {
        min-height: calc(100dvh - 102px);
        max-height: calc(100dvh - 102px);
      }
    }
  </style>
  <div class="container mx-auto px-4 md:px-8 grid grid-cols-1 lg:grid-cols-12 gap-8 items-center relative z-10 w-full">
    <div class="lg:col-span-7">
      <p class="font-label text-[#775a19] font-bold tracking-[0.2em] uppercase text-xs md:text-sm text-center lg:text-left" style="margin-bottom:2px">
        {heroKeywords.join(", ")}
      </p>
      <h1 class="font-headline text-4xl sm:text-5xl md:text-6xl lg:text-7xl text-[#041632] leading-tight mb-3 md:mb-4 text-center lg:text-left">
        Premium Textile <span class="italic font-light">Manufacturing</span> Excellence since 1971
      </h1>
      <p class="font-body text-base md:text-lg text-[#44474d] max-w-xl mb-5 md:mb-6 leading-relaxed text-center lg:text-left mx-auto lg:mx-0">
        Supplying the world's leading fashion brands with ethically sourced, high-precision fabrics tailored for global scale.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
        <a
          href={whatsappLink}
          class="font-label bg-[#041632] text-white px-6 md:px-10 py-4 md:py-5 rounded-md font-bold tracking-widest uppercase hover:bg-[#775a19] transition-all shadow-xl flex items-center justify-center gap-3 text-xs md:text-sm"
          onclick="window.gtag?.('event','hero_cta_wholesale_quote',{page_path:window.location.pathname})"
        >
          Get a Wholesale Quote
          <span class="material-symbols-outlined text-sm">arrow_forward</span>
        </a>
        <a
          href="/fabric"
          class="font-label border border-[#c5c6ce] text-[#041632] px-6 md:px-10 py-4 md:py-5 rounded-md font-bold tracking-widest uppercase hover:bg-[#edeeef] transition-all text-xs md:text-sm text-center"
          onclick="window.gtag?.('event','hero_cta_view_collections',{page_path:window.location.pathname})"
        >
          View Collections
        </a>
      </div>
    </div>

    <div class="lg:col-span-5 relative pb-10 md:pb-12">
      <div class="w-full h-[280px] md:h-[calc(100dvh-200px)] max-h-[560px] bg-[#e1e3e4] rounded-xl overflow-hidden shadow-2xl lg:rotate-2">
        <ResponsiveImage
          src={heroImage}
          alt={homePage?.altTextImage1 ?? "Premium textile fabric"}
          title={homePage?.altTextImage1 ?? "Premium textile fabric"}
          width={512}
          height={640}
          widths={[480, 640, 800, 1024]}
          sizes="(min-width: 1024px) 42vw, 100vw"
          crop="fill"
          loading="eager"
          fetchpriority="high"
          decoding="sync"
          class="w-full h-full object-cover"
        />
      </div>
      <div class="absolute bottom-0 left-0 md:-left-4 bg-white p-4 md:p-6 rounded-xl shadow-xl max-w-[160px] md:max-w-xs border border-[#edeeef]">
        <p class="font-label text-[8px] md:text-xs text-[#775a19] font-bold mb-1 md:mb-2">DAILY OUTPUT</p>
        <p class="font-headline text-2xl md:text-4xl text-[#041632] font-bold">20,000+ <span class="text-sm md:text-lg">Meters</span></p>
      </div>
    </div>
  </div>

  <!-- Background Accent -->
  <div class="absolute top-0 right-0 w-1/3 h-full bg-[#041632]/5 -skew-x-12 transform translate-x-20 hidden lg:block"></div>
</section>
