---
import Carousel from "../common/Carousel.astro";

const testimonials = [
  {
    review: 4.5,
    desc: "On-time dispatch for 600K+ meters/month with stable hand-feel on peach finish poplin. Shade lots stayed consistent across repeats.",
    industry: "Garment Exporter",
    location: "Tirupur, TN",
    tags: ["Online Delivery", "Peach Finish", "Bulk Orders"],
  },
  {
    review: 5,
    desc: "Uniform shirting quality is predictable. GSM and shrinkage are under control which reduced our returns dramatically.",
    industry: "Uniform Manufacturer",
    location: "Ludhiana, Punjab",
    tags: ["GSM Control", "Shrinkage", "Low Returns"],
  },
  {
    review: 4.5,
    desc: "Fast lab dips and 50+ shade support helped us launch a new line quickly. Lead times were met even in peak season.",
    industry: "Private Label Brand",
    location: "Mumbai, MH",
    tags: ["Lab Dips", "Shade Range", "Lead Time"],
  },
  {
    review: 5,
    desc: "Carbon/peach finishes matched our tech pack. Lot-to-lot variance stayed minimal and packing was export-grade.",
    industry: "Textile Buying House",
    location: "Delhi NCR",
    tags: ["Laffer/Peach", "QC", "Export Packing"],
  },
  {
    review: 4.5,
    desc: "Poplin and twill supply remained steady with helpful MoQs. PO changes were handled smoothly by the team.",
    industry: "Corporate Procurement",
    location: "Bengaluru, KA",
    tags: ["MoQ Flex", "Poplin/Twill", "PO Support"],
  },
  {
    review: 5,
    desc: "Fabric inspection reports and test certificates provided on request. Helped us pass third-party audits without issues.",
    industry: "Export Compliance Partner",
    location: "Jaipur, RJ",
    tags: ["Reports", "Certificates", "Compliance"],
  },
];

const metrics = [
  { value: "96%",   label: "Repeat Orders" },
  { value: "99.2%", label: "On-Time" },
  { value: "600K+",  label: "Monthly Volume" },
  { value: "98%",   label: "Client Retention" },
];

// render filled + half stars
function stars(rating: number) {
  const full = Math.floor(rating);
  const half = rating % 1 >= 0.5;
  return { full, half, empty: 5 - full - (half ? 1 : 0) };
}
---

<section class="py-16 md:py-24 bg-[#e7e8e9]">
  <div class="container mx-auto px-4 md:px-8">

    <!-- heading -->
    <div class="text-center mb-12 md:mb-16">
      <h2 class="font-headline text-4xl md:text-5xl text-[#041632] mb-4">Global Partnerships</h2>
      <p class="font-body text-[#44474d] max-w-2xl mx-auto">Trusted by industry leaders for five decades of manufacturing excellence.</p>
    </div>

    <!-- carousel wrapper -->
    <Carousel
      cols={{ mobile: 1, tablet: 2, desktop: 3 }}
      gap="gap-6"
      showArrows={testimonials.length > 3}
      id="testimonials"
    >
      {testimonials.map((t) => {
        const s = stars(t.review);
        return (
          <div class="bg-white rounded-2xl shadow-sm border border-[#edeeef] flex flex-col p-8 md:p-10 h-full">
            <!-- stars row -->
            <div class="flex items-center gap-3 mb-6">
              <div class="flex gap-0.5 text-[#775a19]">
                {Array.from({ length: s.full }).map(() => (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
                    <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                  </svg>
                ))}
                {s.half && (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="w-5 h-5">
                    <defs>
                      <linearGradient id="half-grad">
                        <stop offset="50%" stop-color="currentColor"/>
                        <stop offset="50%" stop-color="#e5e7eb"/>
                      </linearGradient>
                    </defs>
                    <path fill="url(#half-grad)" d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                  </svg>
                )}
                {Array.from({ length: s.empty }).map(() => (
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="#e5e7eb" class="w-5 h-5">
                    <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                  </svg>
                ))}
              </div>
              <span class="font-label text-[10px] font-bold text-[#775a19] uppercase tracking-widest border border-[#775a19]/30 bg-[#775a19]/10 px-2 py-1 rounded-full">Verified</span>
            </div>

            <!-- quote -->
            <p class="font-body italic text-[#44474d] mb-6 flex-1">"{t.desc}"</p>

            <!-- client -->
            <div class="flex items-center gap-2 mb-4">
              <span class="font-headline text-base text-[#041632] font-bold">{t.industry}</span>
              <span class="w-1 h-1 rounded-full bg-[#c5c6ce]"></span>
              <span class="font-label text-xs text-[#44474d]">{t.location}</span>
            </div>

            <!-- tags -->
            <div class="flex flex-wrap gap-2">
              {t.tags.map((tag) => (
                <span class="font-label text-[10px] font-bold text-[#44474d] bg-[#f3f4f5] border border-[#edeeef] px-3 py-1 rounded-full uppercase tracking-wide">{tag}</span>
              ))}
            </div>
          </div>
        );
      })}
    </Carousel>

    <!-- metrics -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-12 md:mt-16">
      {metrics.map((m) => (
        <div class="bg-white rounded-xl border border-[#edeeef] shadow-sm p-6 text-center">
          <p class="font-headline text-3xl md:text-4xl text-[#041632] font-bold mb-1">{m.value}</p>
          <p class="font-label text-[10px] font-bold text-[#775a19] uppercase tracking-widest">{m.label}</p>
        </div>
      ))}
    </div>

  </div>
</section>
