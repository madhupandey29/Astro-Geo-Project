---
import Breadcrumbs from "../common/Breadcrumbs.astro";
import { getCompanyInfo } from "../../lib/api";

interface Props {
  heroImage?: string;
  breadcrumbs?: { name: string; href?: string }[];
}
const { heroImage, breadcrumbs } = Astro.props;
const bgImage = heroImage ?? "https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1600&q=80";
const company = await getCompanyInfo("AGE");
const companyName = company?.legalName ?? "";
---
<style>
  .gold-text {
    background: linear-gradient(to right, #775a19, #fed488);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: transparent;
  }
</style>
<header class="careers-hero relative flex flex-col bg-[#041632] pt-[12px] md:pt-[12px]">
  <style>
    .careers-hero {
      min-height: calc(100dvh - 94px);
    }
    @media (min-width: 768px) {
      .careers-hero { min-height: calc(100dvh - 102px); }
    }
  </style>
  <div class="absolute inset-0 opacity-30 pointer-events-none overflow-hidden">
    <img
      src={bgImage}
      alt="Textile manufacturing floor"
      title={`Careers at ${companyName}`}
      width="1600"
      height="900"
      loading="eager"
      fetchpriority="high"
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-[#041632] via-[#041632]/80 to-transparent"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-8 w-full pt-3 pb-8 flex-1 flex items-start">
    <div class="max-w-3xl">
      {breadcrumbs && breadcrumbs.length > 1 && (
        <div class="mb-6">
          <Breadcrumbs items={breadcrumbs} variant="dark" />
        </div>
      )}
      <span class="inline-block px-4 py-1 mb-6 border border-[#775a19] text-[#ffdea5] font-sans text-xs tracking-[0.2em] uppercase">
        Established 1971 · Ahmedabad, India
      </span>
      <h1 class="font-serif text-4xl sm:text-5xl md:text-6xl leading-tight mb-6 !text-white">
        <span>Forge the Future of</span><br/>
        <span class="italic gold-text">Global Textiles</span>
      </h1>
      <p class="text-[#8393b5] text-base md:text-xl leading-relaxed font-light mb-10 max-w-2xl">
        Join the Best Textile Supplier Award 2023 winner. We don't just manufacture — we craft industrial excellence.
      </p>
      <a
        href="#positions"
        class="inline-flex items-center gap-2 bg-[#775a19] text-white px-8 py-4 font-sans uppercase tracking-widest text-sm hover:bg-[#ffdea5] hover:text-[#041632] transition-all group"
      >
        View Open Roles
        <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">arrow_forward</span>
      </a>
    </div>
  </div>

  <div class="relative z-10 bg-[#1b2b48]/80 backdrop-blur-sm border-t border-white/10">
    <div class="max-w-7xl mx-auto px-6 md:px-8 py-5 grid grid-cols-2 md:grid-cols-4 gap-6">
      <div>
        <p class="font-serif text-2xl md:text-3xl !text-white font-bold">50+</p>
        <p class="font-sans text-[10px] text-[#8393b5] uppercase tracking-widest mt-1">Years of Legacy</p>
      </div>
      <div>
        <p class="font-serif text-2xl md:text-3xl !text-white font-bold">40+</p>
        <p class="font-sans text-[10px] text-[#8393b5] uppercase tracking-widest mt-1">Export Countries</p>
      </div>
      <div>
        <p class="font-serif text-2xl md:text-3xl !text-white font-bold">200+</p>
        <p class="font-sans text-[10px] text-[#8393b5] uppercase tracking-widest mt-1">Skilled Weavers</p>
      </div>
      <div>
        <p class="font-serif text-2xl md:text-3xl text-[#ffdea5] font-bold">Awarded</p>
        <p class="font-sans text-[10px] text-[#8393b5] uppercase tracking-widest mt-1">Best Supplier 2023</p>
      </div>
    </div>
  </div>
</header>
