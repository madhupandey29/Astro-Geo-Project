---
import Breadcrumbs from "../common/Breadcrumbs.astro";

interface Props {
  breadcrumbs?: { name: string; href?: string }[];
}
const { breadcrumbs } = Astro.props;
---
<header class="pt-3 md:pt-3 pb-16 md:pb-20 px-6 max-w-5xl mx-auto text-center">
  {breadcrumbs && breadcrumbs.length > 1 && (
    <div class="flex justify-center mb-6">
      <Breadcrumbs items={breadcrumbs} variant="light" />
    </div>
  )}
  <span class="font-label text-[#775a19] font-bold uppercase tracking-[0.2em] text-xs mb-4 block">
    Compliance &amp; Integrity
  </span>
  <h1 class="font-headline text-4xl md:text-7xl text-[#041632] leading-tight mb-6">
    Wholesale Terms &amp; Legal Policies
  </h1>
  <p class="text-[#44474d] text-base md:text-lg">Last updated: October 2024</p>
  <div class="h-1 w-20 md:w-24 bg-[#775a19] mx-auto mt-8 opacity-30"></div>
</header>
