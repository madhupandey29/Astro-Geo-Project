---
/**
 * BreadcrumbSchema.astro
 * Renders a JSON-LD BreadcrumbList schema.
 *
 * Usage:
 *   <BreadcrumbSchema items={[
 *     { name: "Home", url: "https://www.amrita-fashions.com/" },
 *     { name: "Fabric", url: "https://www.amrita-fashions.com/fabric" },
 *     { name: "Product Name" },   // last item — no url needed
 *   ]} />
 */

interface BreadcrumbItem {
  name: string;
  url?: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: items.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    name: item.name,
    ...(item.url ? { item: { "@type": "Thing", "@id": item.url } } : {}),
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
