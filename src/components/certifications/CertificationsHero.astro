 ---
import Breadcrumbs from "../common/Breadcrumbs.astro";

interface Props {
  heroImage?: string;
  breadcrumbs?: { name: string; href?: string }[];
}
const { heroImage, breadcrumbs } = Astro.props;
const bgImage = heroImage ?? "https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1600&q=80";
---
<section class="certifications-hero relative flex flex-col bg-[#041632]" style="padding-top:2px">
  <style>
    .certifications-hero {
      min-height: calc(100dvh - 94px);
    }
    @media (min-width: 768px) {
      .certifications-hero { min-height: calc(100dvh - 102px); }
    }
    .cert-gold-text {
      background: linear-gradient(to right, #775a19, #fed488);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      color: transparent;
    }
  </style>

  <!-- Background image -->
  <div class="absolute inset-0 overflow-hidden">
    <img
      src={bgImage}
      alt="Industrial textile weaving machinery"
      title="Industrial textile weaving machinery"
      width="1600"
      height="614"
      class="w-full h-full object-cover opacity-25"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-[#041632] via-[#041632]/80 to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-[#041632]/60 via-transparent to-transparent"></div>
  </div>

  <!-- Main content -->
  <div class="relative z-10 flex-1 max-w-7xl mx-auto px-6 md:px-8 w-full pt-0 pb-4 md:py-10 flex flex-col justify-between">
    <div class="max-w-3xl">
      {breadcrumbs && breadcrumbs.length > 1 && (
        <div class="mt-4 md:mt-0 mb-4">
          <Breadcrumbs items={breadcrumbs} variant="dark" />
        </div>
      )}
      <span class="inline-block px-4 py-1 mb-4 border border-[#775a19] text-[#ffdea5] font-sans text-xs tracking-[0.2em] uppercase">
        Established 1971
      </span>
      <h1 class="font-serif text-4xl md:text-7xl leading-tight mb-4">
        <span class="text-white">Certified for</span><br/>
        <span class="italic cert-gold-text">Global Excellence</span><br/>
        <span class="text-white">Worldwide Trust.</span>
      </h1>
      <p class="text-[#8393b5] text-base md:text-xl leading-relaxed font-light max-w-2xl mb-6">
        At AGE, we don't just manufacture textiles — we engineer trust. Our facility adheres to the most stringent international standards for quality, safety, and ethics, earning certifications recognised across 40+ countries.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="#certifications"
          class="inline-flex items-center justify-center gap-2 bg-[#775a19] text-white px-8 py-4 font-sans uppercase tracking-widest text-sm hover:bg-[#ffdea5] hover:text-[#041632] transition-all group"
        >
          View Certifications
          <span class="material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform">arrow_forward</span>
        </a>
        <a
          href="/support"
          class="inline-flex items-center justify-center gap-2 bg-white/5 border border-white/20 text-white px-8 py-4 font-sans uppercase tracking-widest text-sm hover:bg-white/10 transition-all"
        >
          Request Documents
        </a>
      </div>
    </div>

    <!-- Stats bar -->
    <div class="mt-6 pt-6 border-t border-white/10 grid grid-cols-2 md:grid-cols-4 gap-6">
      <div class="flex flex-col items-center text-center md:items-start md:text-left">
        <p class="font-serif text-2xl md:text-3xl text-white font-bold">ISO</p>
        <p class="font-sans text-[10px] text-[#8393b5] uppercase tracking-widest mt-1">9001:2015 Certified</p>
      </div>
      <div class="flex flex-col items-center text-center md:items-start md:text-left">
        <p class="font-serif text-2xl md:text-3xl text-white font-bold">OEKO</p>
        <p class="font-sans text-[10px] text-[#8393b5] uppercase tracking-widest mt-1">TEX Standard 100</p>
      </div>
      <div class="flex flex-col items-center text-center md:items-start md:text-left">
        <p class="font-serif text-2xl md:text-3xl text-white font-bold">40+</p>
        <p class="font-sans text-[10px] text-[#8393b5] uppercase tracking-widest mt-1">Export Countries</p>
      </div>
      <div class="flex flex-col items-center text-center md:items-start md:text-left">
        <p class="font-serif text-2xl md:text-3xl text-[#ffdea5] font-bold">Awarded</p>
        <p class="font-sans text-[10px] text-[#8393b5] uppercase tracking-widest mt-1">Best Supplier 2023</p>
      </div>
    </div>
  </div>
</section>
