---
import { buildWaLink, buildPhoneHref } from "../../lib/api";

interface Props {
  whatsapp?: string | null;
  phone?: string | null;
}

const { whatsapp, phone } = Astro.props;

const whatsappHref = buildWaLink(whatsapp, "https://wa.me/");
const phoneHref = buildPhoneHref(phone, "tel:");
---

<section class="bg-[#f3f4f5] py-16 px-4 md:px-8 border-y border-[#c5c6ce]/30">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-8 md:gap-12">
    <div class="md:w-1/2 text-center md:text-left">
      <h2 class="font-headline text-2xl md:text-3xl text-[#041632] mb-4">
        Need detailed compliance data?
      </h2>
      <p class="text-[#44474d] font-body">
        Our team provides full technical documentation for audit purposes and supply chain requirements.
      </p>
    </div>
    <div class="flex flex-col sm:flex-row gap-4 w-full md:w-auto">
      <a
        href={whatsappHref}
        target="_blank"
        rel="noopener noreferrer"
        class="bg-[#041632] text-white px-6 py-4 font-bold flex items-center justify-center gap-2 hover:bg-[#775a19] transition-all w-full md:w-auto"
        onclick="window.gtag?.('event','cta_click',{event_label:'Full Certificate Pack',section:'certifications_cta',page_path:window.location.pathname})"
      >
        <span class="material-symbols-outlined">description</span>
        Full Certificate Pack
      </a>
      <a
        href={phoneHref}
        class="bg-white text-[#041632] border border-[#c5c6ce]/50 px-6 py-4 font-bold hover:shadow-md transition-all w-full md:w-auto flex items-center justify-center gap-2"
        onclick="window.gtag?.('event','cta_click',{event_label:'Request Custom Doc',section:'certifications_cta',page_path:window.location.pathname})"
      >
        <span class="material-symbols-outlined text-base">call</span>
        Request Custom Doc
      </a>
    </div>
  </div>
</section>
