---
const stats = [
  { value: "100%", label: "Traceability" },
  { value: "50+",  label: "Countries" },
  { value: "Zero", label: "Child Labor" },
];
---
<section class="py-20 md:py-24 px-4 md:px-8 bg-[#f8f9fa]">
  <div class="max-w-5xl mx-auto text-center">
    <div class="mb-8 md:mb-12 inline-block">
      <span
        class="material-symbols-outlined text-5xl md:text-6xl text-[#775a19]"
        style="font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;"
      >workspace_premium</span>
    </div>

    <h2 class="font-headline text-3xl md:text-5xl text-[#041632] mb-8 leading-tight">
      "Committed to <span class="italic">Ethical Manufacturing</span>"
    </h2>

    <div class="w-16 md:w-24 h-1 bg-[#775a19] mx-auto mb-10"></div>

    <p class="max-w-2xl mx-auto text-[#44474d] text-lg leading-relaxed mb-12 italic font-headline px-4">
      Sustainability isn't a badge for us — it's the thread that binds our legacy. We continuously invest in technology that reduces waste and empowers our artisans.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-center max-w-3xl mx-auto">
      {stats.map((stat, i) => (
        <div class:list={["flex flex-col items-center", i === 1 && "md:border-x border-[#c5c6ce]/50 py-4 md:py-0"]}>
          <span class="text-3xl md:text-4xl font-black text-[#041632] font-headline">{stat.value}</span>
          <span class="text-xs uppercase tracking-widest text-[#775a19] font-label font-bold mt-1">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>
