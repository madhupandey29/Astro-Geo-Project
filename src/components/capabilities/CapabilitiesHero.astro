---
import Breadcrumbs from "../common/Breadcrumbs.astro";

interface Props {
  breadcrumbs?: { name: string; href?: string }[];
}
const { breadcrumbs } = Astro.props;
---
<section class="capabilities-hero relative overflow-hidden bg-[#f8f9fa] pt-[12px] pb-16 md:pt-[12px] md:pb-24">
  <style>
    .capabilities-hero {
      min-height: calc(100dvh - 94px);
    }
    @media (min-width: 768px) {
      .capabilities-hero { min-height: calc(100dvh - 102px); }
    }
  </style>
  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      {breadcrumbs && breadcrumbs.length > 1 && (
        <div class="mb-4">
          <Breadcrumbs items={breadcrumbs} variant="light" />
        </div>
      )}
      <span class="mb-6 inline-block rounded-full bg-[#fed488] px-4 py-1.5 text-xs font-label font-bold uppercase tracking-widest text-[#785a1a]">
        Established 1971
      </span>

      <h1 class="mt-6 font-headline italic text-5xl leading-[1.1] tracking-tight text-[#041632] md:text-7xl">
        Crafting Industrial <br />
        Excellence Through <br />
        <span class="text-[#775a19]">Mastery of Scale.</span>
      </h1>

      <p class="mt-8 max-w-2xl text-xl leading-relaxed text-[#44474d]">
        Amrita Global Enterprises combines five decades of heritage with cutting-edge manufacturing
        technology to deliver textile solutions that define industry standards across the globe.
      </p>

      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="#infrastructure"
          class="inline-flex items-center gap-2 rounded-lg bg-[#041632] px-8 py-4 font-semibold text-white transition hover:bg-[#775a19] group"
        >
          Explore Capabilities
          <span class="material-symbols-outlined text-lg transition-transform group-hover:translate-x-1">arrow_forward</span>
        </a>
        <a
          href="#quality-hub"
          class="inline-flex items-center rounded-lg border border-[#c5c6ce]/30 px-8 py-4 font-semibold text-[#041632] transition hover:bg-[#f3f4f5]"
        >
          View Technical Specs
        </a>
      </div>
    </div>
  </div>

  <div class="pointer-events-none absolute top-0 right-0 h-full w-1/2 opacity-5">
    <div class="h-full w-full" style="background-image: radial-gradient(#041632 1px, transparent 0); background-size: 32px 32px;"></div>
  </div>
</section>
