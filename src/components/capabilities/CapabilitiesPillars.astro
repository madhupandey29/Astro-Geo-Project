---
import { buildWaLink, buildPhoneHref } from "../../lib/api";
import ResponsiveImage from "../common/ResponsiveImage.astro";

interface Props {
  whatsapp?: string | null;
  phone?: string | null;
  image1?: string;
}
const { whatsapp, phone, image1 } = Astro.props;

const whatsappHref = buildWaLink(whatsapp, "https://wa.me/");
const phoneHref = buildPhoneHref(phone, "tel:");

const pillars = [
  {
    title: "Precision Weaving",
    desc: "High-density looms capable of handling complex fiber structures with micron-level accuracy for industrial applications.",
    icon: "factory",
    wide: true,
  },
  {
    title: "Quality Control",
    desc: "Multi-stage rigorous testing protocols.",
    icon: "check_circle",
  },
  {
    title: "Sourcing",
    desc: "Ethical fiber procurement pathways.",
    icon: "payments",
  },
  {
    title: "Bulk Scaling",
    desc: "Massive monthly throughput capacities.",
    icon: "local_shipping",
  },
  {
    title: "Industrial Customization",
    desc: "Bespoke fabric construction tailored to specific engineering requirements and tensile strengths.",
    icon: "description",
    wide: true,
    image: image1,
  },
  {
    title: "Global Logistics",
    desc: "Seamless export to 40+ countries.",
    icon: "location_on",
  },
];
---

<section id="infrastructure" class="bg-[#f3f4f5] py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-16 flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <div>
        <h2 class="font-headline italic text-3xl text-[#041632]">Core Infrastructure Pillars</h2>
        <div class="mt-4 h-1 w-20 bg-[#775a19]"></div>
      </div>

      <div class="flex flex-wrap gap-4">
        <a href={whatsappHref} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-lg border border-[#c5c6ce]/10 bg-white px-4 py-2 text-xs font-label font-bold uppercase tracking-widest text-[#775a19] shadow-sm">
          <span class="material-symbols-outlined text-lg">chat</span>
          WhatsApp Support
        </a>
        <a href={phoneHref} class="inline-flex items-center gap-2 rounded-lg border border-[#c5c6ce]/10 bg-white px-4 py-2 text-xs font-label font-bold uppercase tracking-widest text-[#041632] shadow-sm">
          <span class="material-symbols-outlined text-lg">call</span>
          Call Specialist
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-4">
      {pillars.map((item) => (
        <div
          class:list={[
            "rounded-xl border border-[#c5c6ce]/10 bg-white p-8 shadow-sm",
            item.wide ? "md:col-span-2" : "",
          ]}
        >
          {item.image ? (
            <div class="flex flex-col gap-8 md:flex-row md:items-center">
              <div class="flex-1">
                <span class="material-symbols-outlined mb-6 block text-4xl text-[#775a19]">{item.icon}</span>
                <h3 class="text-xl font-bold text-[#041632]">{item.title}</h3>
                <p class="mt-3 leading-relaxed text-[#44474d]">{item.desc}</p>
              </div>
              <ResponsiveImage
                src={item.image}
                alt={item.title}
                title={item.title}
                width={192}
                height={192}
                widths={[192, 256, 384]}
                sizes="(min-width: 768px) 192px, 100vw"
                crop="fill"
                class="h-48 w-full rounded-lg object-cover md:w-48"
                loading="lazy"
              />
            </div>
          ) : (
            <>
              <span class="material-symbols-outlined mb-6 block text-4xl text-[#775a19]">{item.icon}</span>
              <h3 class="text-xl font-bold text-[#041632]">{item.title}</h3>
              <p class="mt-3 leading-relaxed text-[#44474d]">{item.desc}</p>
            </>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
